name: "lowrisc:dv:spi_base_agent:0.1"
description: "SPI UVM agent"
filesets:
  files_dv:
    depend:
      - lowrisc:dv:dv_utils
      - lowrisc:dv:dv_lib
    files:
      - spi_if.sv
      - spi_agent_pkg.sv
      - spi_item.sv: {is_include_file: true}
      - spi_agent_cfg.sv: {is_include_file: true}
      - spi_agent_cov.sv: {is_include_file: true}
      # - spi_host_driver: {is_include_file: true}
      # - spi_device_driver: {is_include_file: true}
      # - spi_driver.sv: {is_include_file: true}
      # - spi_sequencer.sv: {is_include_file : true}
      - spi_monitor.sv: {is_include_file: true}
      - spi_agent.sv: {is_include_file: true}
      - spi_reg_sckmode_c.sv: {is_include_file: true}
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_dv
