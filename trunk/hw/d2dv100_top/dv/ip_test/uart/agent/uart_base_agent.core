name: "lowrisc:dv:uarta_base_agent:0.1"
description: "SPI UVM agent"
filesets:
  files_dv:
    depend:
      - lowrisc:dv:dv_utils
      - lowrisc:dv:dv_lib
    files:
      - uart_if.sv
      - uart_agent_pkg.sv
      - uart_item.sv: {is_include_file: true}
      - uart_agent_cfg.sv: {is_include_file: true}
      - uart_agent_cov.sv: {is_include_file: true}
      # - uart_host_driver: {is_include_file: true}
      # - uart_device_driver: {is_include_file: true}
      # - uart_driver.sv: {is_include_file: true}
      # - uart_sequencer.sv: {is_include_file : true}
      - uart_monitor.sv: {is_include_file: true}
      - uart_agent.sv: {is_include_file: true}
      #- uart_reg_sckmode_c.sv: {is_include_file: true}
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_dv
