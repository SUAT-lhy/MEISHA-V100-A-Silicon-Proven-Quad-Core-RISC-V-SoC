module QDLAHSLHHMX3 (Q, D, G, S, VCCNW, GND, VCC);
   inout VCCNW;
   input D;
   input G;
   output Q;
   input S;
   inout GND;
   inout VCC;
   reg flag; // Notifier flag

   wire d_G, d_D;

//Function Block
`protect
   dlhsb_udp g1(qt,  d_D,  d_G,  sb,  flag );
   buf g2 (Q_pg_tmp, qt);
