         Event_DisableAll;

   buf  b1 (pu_tmp, pu);
   buf  b2 (pd_tmp, pd);
   buf  b3 (e_tmp, e);
   buf  b4 (ie_tmp, ie);

   bufif1  g4 (io_i, i, e_tmp);
   not     g5 (ne, e_tmp);
   rnmos   g6 (io_i_tmp, io_e, ne);  //-- pull level
   rnmos   g7 (io_i, io_i_tmp, vcc);  //-- added for down scale to weak level   
   nmos #0.1 g8 (io,   io_i, vcc);

   always @(e_tmp or ie_tmp or pu_tmp or pd_tmp)
   begin
     ->Event_DisableAll;
     if (e_tmp == 1'b0)
     begin
       case ({pu_tmp,pd_tmp,ie_tmp})
         3'b100 ,
	 3'b101 ,
         3'b10z ,
	 3'b10x :
	 begin
           if (io == 1'b1)
             io_e <= 1'b1;
           else
           begin
             if (io_e !== 1'bz)
               io_e <= 1'bz;
             else
