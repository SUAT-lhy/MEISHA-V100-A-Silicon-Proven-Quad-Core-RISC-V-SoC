//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module A2LVLUDESDLHHMX1  (VCCNW, SLB, I, O, GND, VCCI, VCC);
   inout VCCNW;
   input SLB;
   input I;
   output O;
   inout GND;
   inout VCCI;
   inout VCC;
   supply0 GNDPW;

   wire poweron;
   reg main;

//Function Block
`protect
   and g1(O_temp, I, SLB);

   assign poweron = ((VCC === 1'b1) && (GND === 1'b0) && (VCCNW === 1'b1) && (GNDPW === 1'b0));

   always @ (*)
   begin
       if ( poweron == 1'b1 ) begin
          if ( SLB == 1'b1 ) begin
             if (VCCI == 1'b1) begin
                main <= O_temp;
             end
             else begin
                main <= 1'bx;
             end
          end
          else begin
             main <= O_temp;
          end
       end
       else begin
          main <= 1'bx;
       end
   end
   assign O = main;

//Specify Block
   specify

      //  Module Path Delay
      (I *> O) = (1.00, 1.00);
      (SLB *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


