`resetall
`timescale 10ps/1ps
`celldefine
module GPGBUFLHHMX1  (VCCNW, I, O, GND, GNDG, VCCG, VCC);
   inout VCCNW;
   input I;
   output O;
   inout GND;
   inout GNDG;
   inout VCCG;
   inout VCC;
   supply0 GNDPW;

//Function Block
`protect
    
   buf g1(O_temp, I);

   assign O = ((VCCG !== 1'b1) || (GNDG !== 1'b0) || (VCCNW !== 1'b1) || (GNDPW !== 1'b0))? 1'bx : O_temp;

//Specify Block
   specify

      //  Module Path Delay
      (I *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


