`celldefine
module DLAHRBLHHMX0P4 (Q, QB, D, G, RB, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input D;
   input G;
   output Q;
   inout GND;
   inout VCC;
   reg flag; // Notifier flag

   wire d_G, d_D;

//Function Block
`protect
   buf g3 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   not g1 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dlhrb_udp g2(qt,  d_D,  d_G,  RB,  flag );

//Specify Block
   specify

      //  Module Path Delay
      (posedge G *> (Q :1'bx)) = (1.00, 1.00);
      (posedge G *> (QB :1'bx)) = (1.00, 1.00);
      (D *> Q) = (1.00, 1.00);
      (D *> QB) = (1.00, 1.00);
      (RB *> Q) = (1.00, 1.00);
      (RB *> QB) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_G = 37.21;
      specparam hold_D_G = 7.84;
      $setuphold(negedge G &&& RB, posedge D, 1.00, 1.00, flag,,,d_G, d_D);
      $setuphold(negedge G &&& RB, negedge D, 1.00, 1.00, flag,,,d_G, d_D);

      //  Recovery Time
      specparam recovery_RB_G = 35.06;
      specparam recovery_G_RB = 18.27;
      $recrem(posedge RB, negedge G &&& d_D, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_pos_G = 47.06;
      specparam mpw_neg_RB = 27.35;
      $width(posedge G, 1.00, 0, flag);
      $width(negedge RB, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


