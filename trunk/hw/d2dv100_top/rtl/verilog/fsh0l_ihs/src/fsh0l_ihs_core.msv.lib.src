   wire d_G, d_D;

//Function Block
`protect
   buf g3 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   not g1 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dlhrb_udp g2(qt,  d_D,  d_G,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
      (posedge G *> (Q :1'bx)) = (1.00, 1.00);
      (posedge G *> (QB :1'bx)) = (1.00, 1.00);
      (D *> Q) = (1.00, 1.00);
      (D *> QB) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_G = 28.88;
      specparam hold_D_G = 8.13;
      $setuphold(negedge G, posedge D, 1.00, 1.00, flag,,,d_G, d_D);
      $setuphold(negedge G, negedge D, 1.00, 1.00, flag,,,d_G, d_D);

      //  Minimum Pulse Width
      specparam mpw_pos_G = 42.82;
      $width(posedge G, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


