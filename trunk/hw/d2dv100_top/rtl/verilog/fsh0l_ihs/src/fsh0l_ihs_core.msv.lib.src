  wire poweron, Q1;
  reg main;

//Function Block
`protect

   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_SB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   mux2_udp m1 (om1,  d_D,  d_TD, SEL_ );
    
   nand a1 (ona1, on1, on2);
   and a2 (oa2, d_SB, on2, d_CK); 
   dlhrsb_udp dlh1 (odlh1, om1, on3, vcc, d_SB, flag ); 
   dlhrsb_udp dlh2 (qt, odlh1, oa2, vcc, ona1, flag ); 
   buf (Q_temp, qt);
   
//Append pseudo gate for timing violation checking
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D or d_TD or SL)
   begin
    if (SL === 1'b0)
      if (SEL_ === 1'b0)
         D_flag = d_D;
      else
         D_flag = d_TD;
    else
      D_flag = 0;     
   end

//PG_pin
   assign poweron = ((VCCG === 1'b1) && (GNDG === 1'b0) && (VCCNW === 1'b1) && (GNDPW === 1'b0));
   assign Q1 = ((VCC === 1'b1) && (GND === 1'b0));
   
   always @ (*)
    begin
       if ( poweron == 1 ) begin
          if ( Q1 == 1) begin
             main <= Q_temp;                      
          end
          else begin
             main <= 1'bx;
          end
       end
       else begin
          main <= 1'bx;
       end
   end
   assign Q = main;

//Specify Block
  specify
    (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
    (negedge SB *> (Q :1'bx)) = (1.00, 1.00);
//  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      specparam setup_CK_SL = 0.00;
      specparam hold_CK_SL = 0.00;
      specparam setup_SB_SL = 0.00;
      specparam hold_SB_SL = 0.00;
      $setuphold(posedge CK &&& SB, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& SB, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& SB, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& SB, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge SL, posedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
       
      $setuphold(negedge SL, posedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      $setuphold(negedge SL, posedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      //  Recovery Time
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_SB = 1.29;
      $recrem(posedge SB, posedge CK, 1.00, 1.00, flag);
      $recrem(negedge SL, negedge CK, 1.00, 1.00, flag);
      $recrem(posedge SL, posedge CK, 1.00, 1.00, flag);


      

      //  Minimum Pulse Width
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

  endspecify

`endprotect
endmodule
`endcelldefine
