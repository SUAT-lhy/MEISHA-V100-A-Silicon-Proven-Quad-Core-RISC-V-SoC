   dffrsb_udp g2(qt,  data1,  d_CK,  vcc,  vcc,  flag );
   mux2_udp g4(data1,  n1,  d_TD,  d_SEL );

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
