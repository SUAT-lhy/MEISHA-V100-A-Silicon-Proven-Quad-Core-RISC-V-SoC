      $setuphold(posedge CK &&& ENABLE_RB, negedge D3 &&& ENABLE_RB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D4 &&& ENABLE_RB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D4 &&& ENABLE_RB, 1.00, 1.00, flag3,,,d_CK, d_D4);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_CK_RB = 8.80;
      $recrem(posedge RB &&& ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, posedge CK &&& ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFFRBLHHMX3 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   reg flag, flag1, flag2, flag3; // Notifier flag
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  vcc,  flag3 );

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire ENABLE_D1_AND_RB, ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, ENABLE_NOT_CK;
	wire ENABLE_RB, ENABLE_NOT_D1_AND_RB, int_twire_0, int_twire_1;
	wire int_twire_2;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	and (ENABLE_D1_AND_RB, D1, RB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB, D1__bar, RB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4);
	and (int_twire_1, D1__bar, D2__bar, D3);
	and (int_twire_2, D1__bar, D2);
	or (ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, D1, int_twire_2, int_twire_1, int_twire_0);
	not (ENABLE_NOT_CK, CK);


//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D1 &&& ENABLE_RB, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D1 &&& ENABLE_RB, 1.00, 1.00, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 5.90;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D2 &&& ENABLE_RB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D2 &&& ENABLE_RB, 1.00, 1.00, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 5.90;
      specparam hold_D3_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D3 &&& ENABLE_RB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D3 &&& ENABLE_RB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D4 &&& ENABLE_RB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D4 &&& ENABLE_RB, 1.00, 1.00, flag3,,,d_CK, d_D4);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_CK_RB = 8.80;
      $recrem(posedge RB &&& ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, posedge CK &&& ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFFRSBLHHMX1 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input SB;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   reg flag, flag1, flag2, flag3; // Notifier flag

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  SB,  flag3 );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, ENABLE_D1_AND_RB_AND_SB;
	wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB;
	wire ENABLE_NOT_CK_AND_SB, ENABLE_NOT_D1_AND_RB_AND_SB, ENABLE_RB_AND_SB;
	wire int_twire_0, int_twire_1, int_twire_2;
	wire int_twire_3, int_twire_4, int_twire_5;
	wire int_twire_6, int_twire_7;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB, D1, RB, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB, D1__bar, RB, SB);
	and (ENABLE_RB_AND_SB, RB, SB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4, SB);
	and (int_twire_1, D1__bar, D2__bar, D3, SB);
	and (int_twire_2, D1__bar, D2, SB);
	and (int_twire_3, D1, SB);
	or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, int_twire_3, int_twire_2, int_twire_1, int_twire_0);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (int_twire_4, D1__bar, RB);
	and (int_twire_5, D1, D2__bar, RB);
	and (int_twire_6, D1, D2, D3__bar, RB);
	not (D4__bar, D4);
	and (int_twire_7, D1, D2, D3, D4__bar, RB);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_7, int_twire_6, int_twire_5, int_twire_4);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);




//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);


      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 5.90;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 5.90;
      specparam hold_D3_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 9.50;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.26;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFFRSBLHHMX2 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input SB;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   reg flag, flag1, flag2, flag3; // Notifier flag

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  SB,  flag3 );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, ENABLE_D1_AND_RB_AND_SB;
	wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB;
	wire ENABLE_NOT_CK_AND_SB, ENABLE_NOT_D1_AND_RB_AND_SB, ENABLE_RB_AND_SB;
	wire int_twire_0, int_twire_1, int_twire_2;
	wire int_twire_3, int_twire_4, int_twire_5;
	wire int_twire_6, int_twire_7;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB, D1, RB, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB, D1__bar, RB, SB);
	and (ENABLE_RB_AND_SB, RB, SB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4, SB);
	and (int_twire_1, D1__bar, D2__bar, D3, SB);
	and (int_twire_2, D1__bar, D2, SB);
	and (int_twire_3, D1, SB);
	or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, int_twire_3, int_twire_2, int_twire_1, int_twire_0);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (int_twire_4, D1__bar, RB);
	and (int_twire_5, D1, D2__bar, RB);
	and (int_twire_6, D1, D2, D3__bar, RB);
	not (D4__bar, D4);
	and (int_twire_7, D1, D2, D3, D4__bar, RB);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_7, int_twire_6, int_twire_5, int_twire_4);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);




//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);


      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 5.90;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 5.90;
      specparam hold_D3_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 9.50;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.26;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFFRSBLHHMX3 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input SB;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   reg flag, flag1, flag2, flag3; // Notifier flag

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  SB,  flag3 );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, ENABLE_D1_AND_RB_AND_SB;
	wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB;
	wire ENABLE_NOT_CK_AND_SB, ENABLE_NOT_D1_AND_RB_AND_SB, ENABLE_RB_AND_SB;
	wire int_twire_0, int_twire_1, int_twire_2;
	wire int_twire_3, int_twire_4, int_twire_5;
	wire int_twire_6, int_twire_7;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB, D1, RB, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB, D1__bar, RB, SB);
	and (ENABLE_RB_AND_SB, RB, SB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4, SB);
	and (int_twire_1, D1__bar, D2__bar, D3, SB);
	and (int_twire_2, D1__bar, D2, SB);
	and (int_twire_3, D1, SB);
	or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, int_twire_3, int_twire_2, int_twire_1, int_twire_0);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (int_twire_4, D1__bar, RB);
	and (int_twire_5, D1, D2__bar, RB);
	and (int_twire_6, D1, D2, D3__bar, RB);
	not (D4__bar, D4);
	and (int_twire_7, D1, D2, D3, D4__bar, RB);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_7, int_twire_6, int_twire_5, int_twire_4);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);




//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);


      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 5.90;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 5.90;
      specparam hold_D3_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 9.50;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.26;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFFSBLHHMX1 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   inout VCCNW;
   input SB;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   reg flag, flag1, flag2, flag3; // Notifier flag
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  vcc,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  vcc,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  vcc,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  vcc,  SB,  flag3 );

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar, ENABLE_SB;
	wire D4__bar, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_OR_D1_AND_D2_AND_NOT_D3_OR_D1_AND_NOT_D2_OR_NOT_D1, ENABLE_D1_AND_SB;
	wire ENABLE_NOT_CK, ENABLE_NOT_D1_AND_SB, int_twire_0;
	wire int_twire_1, int_twire_2;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	and (ENABLE_D1_AND_SB, D1, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_SB, D1__bar, SB);
	not (D2__bar, D2);
	and (int_twire_0, D1, D2__bar);
	not (D3__bar, D3);
	and (int_twire_1, D1, D2, D3__bar);
	not (D4__bar, D4);
	and (int_twire_2, D1, D2, D3, D4__bar);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_OR_D1_AND_D2_AND_NOT_D3_OR_D1_AND_NOT_D2_OR_NOT_D1, int_twire_2, int_twire_1, int_twire_0, D1__bar);
	not (ENABLE_NOT_CK, CK);



//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D1 &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D1 &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 5.90;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D2 &&& ENABLE_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D2 &&& ENABLE_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      specparam setup_D3_CK = 5.90;
      specparam hold_D3_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D3 &&& ENABLE_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D3 &&& ENABLE_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D4 &&& ENABLE_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D4 &&& ENABLE_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_SB_CK = 5.90;
      specparam recovery_CK_SB = 8.80;
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_OR_D1_AND_D2_AND_NOT_D3_OR_D1_AND_NOT_D2_OR_NOT_D1, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_OR_D1_AND_D2_AND_NOT_D3_OR_D1_AND_NOT_D2_OR_NOT_D1, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_SB = 7.17;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
