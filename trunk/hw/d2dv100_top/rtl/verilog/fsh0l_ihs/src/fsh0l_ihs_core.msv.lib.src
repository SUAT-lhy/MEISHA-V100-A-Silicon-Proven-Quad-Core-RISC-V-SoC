   end

   always @(io)
   begin
     if (e_tmp==1'b0)
     begin
       if (io===1'b1)
       begin
         disable BlockTHZ;
         io_e = 1'b1;
       end
       else if (io===1'b0)
       begin
         disable BlockTHZ;
         io_e = 1'bz;
       end
       else if (io===1'bx)
       begin
         disable BlockTHZ;
         io_e = 1'bz;
       end
       else if (io===1'bz)
