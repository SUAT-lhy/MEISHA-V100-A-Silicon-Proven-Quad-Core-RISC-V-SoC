   inout VCCNW;
   input B;
   output O;
   input S;
   inout GND;
   input A1;
   input A2;
   inout VCC;
   reg flag; // Notifier flag

//Function Block
`protect
   and      g1(tmp_o, A1, A2);
   mux2_udp g2 (O_pg_tmp, tmp_o, B, S);
   assign O = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? O_pg_tmp : 1'bx;

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B == 1) (A1 *> O) = (1.00, 1.00);
      if (B == 0) (A1 *> O) = (1.00, 1.00);
      ifnone (A1 *> O) = (1.00, 1.00);
      if (B == 0) (A2 *> O) = (1.00, 1.00);
      if (B == 1) (A2 *> O) = (1.00, 1.00);
      ifnone (A2 *> O) = (1.00, 1.00);
      if (A1 == 0 && A2 == 1) (B *> O) = (1.00, 1.00);
      if (A1 == 1 && A2 == 1) (B *> O) = (1.00, 1.00);
      if (A1 == 0 && A2 == 0) (B *> O) = (1.00, 1.00);
      if (A1 == 1 && A2 == 0) (B *> O) = (1.00, 1.00);
      ifnone (B *> O) = (1.00, 1.00);
      if (A1 == 0 && A2 == 0 && B == 1) (S *> O) = (1.00, 1.00);
      if (A1 == 1 && A2 == 0 && B == 1) (S *> O) = (1.00, 1.00);
      if (A1 == 1 && A2 == 1 && B == 0) (S *> O) = (1.00, 1.00);
      if (A1 == 0 && A2 == 1 && B == 1) (S *> O) = (1.00, 1.00);
      ifnone (S *> O) = (1.00, 1.00);
  `ifdef delayfix
     pathdelay_enhanced;
  `endif
   //  Module Path Delay

   endspecify
`endprotect
endmodule
`endcelldefine

