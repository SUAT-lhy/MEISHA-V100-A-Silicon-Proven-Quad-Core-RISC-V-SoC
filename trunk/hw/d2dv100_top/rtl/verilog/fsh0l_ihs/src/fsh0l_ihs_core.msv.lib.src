`celldefine
module QBDFFRSBNLHHMX3 (QB, D, CK, RB, SB, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input SB;
   input D;
   inout GND;
   input CK;
   inout VCC;
   reg flag; // Notifier flag
   
   wire d_CK, d_D;

//Function Block
`protect
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  SB,  flag );
   and g7(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   and g6 (QB_pg_tmp, qb1, rs);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   
//Append pseudo gate for timing violation checking
