//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module GCBESLHHMX0P7 (Q, E, TE, CKB, VCCNW, GND, VCC);
   input CKB;
   inout VCCNW;
   input TE;
   input E;
   output Q;
   inout GND;
   inout VCC;
   reg flag; // Notifier flag
   supply1 vcc;

   wire d_CKB, d_E, d_TE;

//Function Block
`protect
   or g1(or_o, d_TE, d_E);
   dlhrb_udp g2(qt,  or_o,  d_CKB,  vcc,  flag );
   not g3(qt_bar, qt);
   or g4 (Q_pg_tmp, d_CKB, qt_bar);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   
//Specify Block
   specify

      //  Module Path Delay
      (CKB *> Q) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_E_CKB = 33.05;
      specparam hold_E_CKB = 4.97;
      specparam setup_TE_CKB = 33.05;
      specparam hold_TE_CKB = 4.97;
      $setuphold(negedge CKB, posedge E &&& ~TE, 1.00, 1.00, flag,,,d_CKB, d_E);
      $setuphold(negedge CKB, negedge E &&& ~TE, 1.00, 1.00, flag,,,d_CKB, d_E);
      $setuphold(negedge CKB, posedge TE &&& ~E, 1.00, 1.00, flag,,,d_CKB, d_TE);
      $setuphold(negedge CKB, negedge TE &&& ~E, 1.00, 1.00, flag,,,d_CKB, d_TE);

      //  Minimum Pulse Width
      specparam mpw_pos_CKB = 40.60;
      $width(posedge CKB, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine
