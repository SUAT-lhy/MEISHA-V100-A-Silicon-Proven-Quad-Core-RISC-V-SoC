//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module HA1LHHMX0P4 (S, C, A, B, VCCNW, GND, VCC);
   inout VCCNW;
   input A;
   input B;
   output C;
   output S;
   inout GND;
   inout VCC;

//Function Block
`protect
   and g1 (C_pg_tmp, A, B);
   assign C = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? C_pg_tmp : 1'bx;
   xor g2 (S_pg_tmp, A, B);
   assign S = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? S_pg_tmp : 1'bx;

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B == 0) (A *> S) = (1.00, 1.00);
      if (B == 1) (A *> S) = (1.00, 1.00);
      ifnone (A *> S) = (1.00, 1.00);
      if (A == 0) (B *> S) = (1.00, 1.00);
      if (A == 1) (B *> S) = (1.00, 1.00);
      ifnone (B *> S) = (1.00, 1.00);

      //  Module Path Delay
      (A *> C) = (1.00, 1.00);
      (B *> C) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


