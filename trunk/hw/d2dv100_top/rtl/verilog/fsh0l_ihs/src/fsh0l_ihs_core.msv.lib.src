      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.28;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& RB, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& RB, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 4.30;
      specparam recovery_CK_RB = 9.00;
      $recrem(posedge RB, posedge CK &&& D_flag1, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 3.94;
      specparam mpw_neg_CK = 14.51;
      specparam mpw_pos_CK = 13.64;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

