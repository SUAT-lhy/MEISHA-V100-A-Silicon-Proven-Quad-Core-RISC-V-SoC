   dlhrsb_udp dlh2 (qt, on5, oa2, oa3, oa1, flag ); 
   buf (Q_temp, on6);

//Append pseudo gate for timing violation checking
   and (_SB_and_RB_, SB, RB);
   or (_SB_or_RB_, SB, RB);
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D or d_TD or SL)
   begin
    if (SL === 1'b0)
      if (SEL_ === 1'b0)
         D_flag = d_D;
      else
         D_flag = d_TD;
    else
      D_flag = 0;     
    end

//Timing violation checking statement
   always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
    $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//PG_pin
   assign poweron = ((VCCG === 1'b1) && (GNDG === 1'b0) && (VCCNW === 1'b1) && (GNDPW === 1'b0));
   assign Q1 = ((VCC === 1'b1) && (GND === 1'b0));
   
   always @ (*)
    begin
       if ( poweron == 1 ) begin
          if ( Q1 == 1) begin
             main <= Q_temp;                      
          end
          else begin
             main <= 1'bx;
          end
       end
       else begin
          main <= 1'bx;
       end
   end
   assign Q = main;

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q :1'bx)) = (1.00, 1.00);

//  Setup and Hold Time
