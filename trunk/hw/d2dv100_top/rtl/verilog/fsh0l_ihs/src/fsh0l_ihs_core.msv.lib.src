      specparam recovery_S_G = 24.06;
      specparam recovery_G_S = 17.92;
      $recrem(negedge S, negedge G &&& ~d_D, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_pos_G = 40.15;
      specparam mpw_pos_S = 28.56;
      $width(posedge G, 1.00, 0, flag);
      $width(posedge S, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
