`celldefine
module QDBFRSBNLHHMX0P4 (Q, D, CKB, RB, SB, VCCNW, GND, VCC);
   input CKB;
   input RB;
   inout VCCNW;
   input SB;
   input D;
   output Q;
   inout GND;
   inout VCC;
   reg flag; // Notifier flag

   wire d_CKB, d_D;

//Function Block
`protect
   buf g3 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  ck,  RB,  SB,  flag );
   and g4(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
//   and g6(QB, qb1, rs);
   not g7(ck,  d_CKB );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
