      $setuphold(negedge CKB &&& _SB_and_RB_, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& _SB_and_RB_, posedge SEL, 1.00, 1.00, flag,,,d_CKB, d_SEL);
