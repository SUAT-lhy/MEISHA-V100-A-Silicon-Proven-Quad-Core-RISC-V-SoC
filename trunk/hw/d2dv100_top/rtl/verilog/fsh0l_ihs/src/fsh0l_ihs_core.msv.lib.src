//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module DBAHRBLHHMX0P4 (Q, QB, D, GB, RB, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input D;
   output Q;
   inout GND;
   input GB;
   inout VCC;
   reg flag; // Notifier flag

   wire d_GB, d_D;
   wire d_RB;

//Function Block
`protect
   buf g3 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   not g1 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dlhrb_udp g2(qt,  d_D,  ck,  d_RB,  flag );
   not g4(ck,  d_GB );

//Specify Block
   specify

      //  Module Path Delay
      (negedge GB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge GB *> (QB :1'bx)) = (1.00, 1.00);
      (D *> Q) = (1.00, 1.00);
      (D *> QB) = (1.00, 1.00);
      (RB *> Q) = (1.00, 1.00);
      (RB *> QB) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_GB = 36.39;
      specparam hold_D_GB = 11.21;
      $setuphold(posedge GB &&& RB, posedge D, 1.00, 1.00, flag,,,d_GB, d_D);
      $setuphold(posedge GB &&& RB, negedge D, 1.00, 1.00, flag,,,d_GB, d_D);

      //  Recovery Time
      specparam recovery_RB_GB = 34.10;
      specparam recovery_GB_RB = 19.92;
     // $recovery(posedge RB, posedge GB &&& d_D, recovery_RB_GB, flag);
     // $hold(posedge GB &&& d_D, posedge RB, recovery_GB_RB, flag);
      $recrem(posedge RB, posedge GB &&& d_D, 1.00, 1.00, flag,,,d_RB,d_GB);


      //  Minimum Pulse Width
      specparam mpw_neg_GB = 45.03;
      specparam mpw_neg_RB = 27.31;
      $width(negedge GB, 1.00, 0, flag);
      $width(negedge RB, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


