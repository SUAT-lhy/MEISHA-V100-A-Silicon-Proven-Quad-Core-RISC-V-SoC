module Q4DFFRBLHHMX1 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   reg flag, flag1, flag2, flag3; // Notifier flag
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  vcc,  flag3 );

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire ENABLE_D1_AND_RB, ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, ENABLE_NOT_CK;
	wire ENABLE_RB, ENABLE_NOT_D1_AND_RB, int_twire_0, int_twire_1;
	wire int_twire_2;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	and (ENABLE_D1_AND_RB, D1, RB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB, D1__bar, RB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4);
	and (int_twire_1, D1__bar, D2__bar, D3);
	and (int_twire_2, D1__bar, D2);
	or (ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, D1, int_twire_2, int_twire_1, int_twire_0);
	not (ENABLE_NOT_CK, CK);


//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
