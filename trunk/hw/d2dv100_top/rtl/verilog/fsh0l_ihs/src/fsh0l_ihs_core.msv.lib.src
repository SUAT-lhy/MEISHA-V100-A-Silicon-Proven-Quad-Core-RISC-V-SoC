      (posedge G *> (Q :1'bx)) = (1.00, 1.00);
      (D *> Q) = (1.00, 1.00);
      (S *> Q) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_G = 29.59;
      specparam hold_D_G = 7.05;
      $setuphold(negedge G &&&  ~S, posedge D, 1.00, 1.00, flag,,,d_G, d_D);
      $setuphold(negedge G &&&  ~S, negedge D, 1.00, 1.00, flag,,,d_G, d_D);

