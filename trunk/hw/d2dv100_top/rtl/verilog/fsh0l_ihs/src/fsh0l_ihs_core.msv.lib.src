   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  vcc,  flag1 );
   mux2_udp g7(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g8(data2,  d_D2,  qt1,  SEL_ );

//Append pseudo gate for timing violation checking
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D1 or d_D2 or d_TD)
     begin
       if (SEL_ === 1'b0) 
           D_flag = d_D1 | d_D2;
       else
           D_flag = d_TD;
     end

	// Additional timing wires
	wire D1__bar, ENABLE_RB, ENABLE_D1_AND_NOT_SEL;
	wire ENABLE_D1_AND_RB_AND_NOT_SEL_AND_TD, ENABLE_D1_AND_RB_AND_SEL;
	wire ENABLE_D1_AND_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_D2_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL;
	wire ENABLE_NOT_D1_AND_SEL_AND_TD, ENABLE_RB_AND_NOT_SEL, SEL__bar;
	wire TD__bar;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
	and (ENABLE_RB_AND_NOT_SEL, RB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_TD, D1, SEL, TD);
	and (ENABLE_D1_AND_NOT_SEL, D1, SEL__bar);
	and (ENABLE_NOT_D1_AND_SEL_AND_TD, D1__bar, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, D1__bar, D2, SEL__bar);
	and (ENABLE_D1_AND_RB_AND_SEL, D1, RB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL, D1__bar, RB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D1 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D1 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_RB, posedge SEL &&& ENABLE_RB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB, negedge SEL &&& ENABLE_RB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_CK_RB = 8.80;
      $recrem(posedge RB &&& ENABLE_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_D1_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
