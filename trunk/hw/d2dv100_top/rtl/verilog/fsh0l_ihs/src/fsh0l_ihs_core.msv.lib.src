      $setuphold(negedge CKB &&& RB, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& RB, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& RB, posedge SEL, 1.00, 1.00, flag,,,d_CKB, d_SEL);
      $setuphold(negedge CKB &&& RB, negedge SEL, 1.00, 1.00, flag,,,d_CKB, d_SEL);
      $setuphold(negedge CKB &&& RB, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CKB, d_TD);
      $setuphold(negedge CKB &&& RB, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CKB, d_TD);

      //  Recovery Time
      specparam recovery_RB_CKB = 4.30;
      specparam recovery_CKB_RB = 9.50;
      $recrem(posedge RB, negedge CKB &&& D_flag1, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 18.10;
      specparam mpw_pos_CKB = 15.30;
      specparam mpw_neg_CKB = 15.30;
      $width(negedge RB, 1.00, 0, flag);
      $width(posedge CKB, 1.00, 0, flag);
      $width(negedge CKB, 1.00, 0, flag);
   endspecify
`endprotect
