//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module GCKESLHHMX12 (Q, E, TE, CK, VCCNW, GND, VCC);
   inout VCCNW;
   input TE;
   input E;
   output Q;
   inout GND;
   input CK;
   inout VCC;
   reg flag; // Notifier flag
   supply1 vcc;

   wire d_CK, d_E, d_TE;

//Function Block
`protect

   not g1(ckb,  d_CK );
   or g2(or_o, d_TE, d_E);
   dlhrb_udp g3(qt,  or_o, ckb,  vcc,  flag );
   and g4 (Q_pg_tmp, d_CK, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   
//Specify Block
   specify

      //  Module Path Delay
      (CK *> Q) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_E_CK = 33.05;
      specparam hold_E_CK = 4.97;
      specparam setup_TE_CK = 33.05;
      specparam hold_TE_CK = 4.97;
      $setuphold(posedge CK, posedge E &&& ~TE, 1.00, 1.00, flag,,,d_CK, d_E);
      $setuphold(posedge CK, negedge E &&& ~TE, 1.00, 1.00, flag,,,d_CK, d_E);
      $setuphold(posedge CK, posedge TE &&& ~E, 1.00, 1.00, flag,,,d_CK, d_TE);
      $setuphold(posedge CK, negedge TE &&& ~E, 1.00, 1.00, flag,,,d_CK, d_TE);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 33.13;
      $width(negedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine
