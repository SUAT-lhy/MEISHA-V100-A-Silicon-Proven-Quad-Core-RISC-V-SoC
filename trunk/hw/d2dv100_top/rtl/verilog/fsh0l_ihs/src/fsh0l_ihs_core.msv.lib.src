`timescale 10ps/1ps
`celldefine
module Q4DFFSBLHHMX2 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   inout VCCNW;
