         end
         3'b010 ,
	 3'b011 ,
         3'b01z ,
	 3'b01x ,
	 3'b110 :
         begin
           if (io == 1'b0)
             io_e <= 1'b0;
           else
           begin
             if (io_e !== 1'bz)
               io_e <= 1'bz;
             else
             begin
               #0 ->Event_PD;
             end
           end
         end
         3'b000 ,
	 3'b001 ,
         3'b00z ,
	 3'b00x :
         begin
           io_e <= 1'bz;
         end
         3'b111 :
         begin
           #0 ->Event_KEEP;
