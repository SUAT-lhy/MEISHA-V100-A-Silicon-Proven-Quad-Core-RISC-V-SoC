`celldefine
module SESDBUFLHHMX2 (O, I, VCCNW, GND, VCC);
   inout VCCNW;
   input I;
   output O;
   inout GND;
   inout VCC;

//Function Block
`protect
   buf g1 (O_pg_tmp, I);
   assign O = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? O_pg_tmp : 1'bx;

//Specify Block
   specify

      //  Module Path Delay
      (I *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


