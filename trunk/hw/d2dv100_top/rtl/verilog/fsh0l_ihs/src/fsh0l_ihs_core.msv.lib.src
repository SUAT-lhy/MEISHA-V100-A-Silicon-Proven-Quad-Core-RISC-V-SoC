   input CI;
   output CO;
   inout VCC;

//Function Block
`protect
   and g1 (a1,A,B);
   and g2 (a2,B,CI);
   and g3 (a3,A,CI);
   or  g4  (CO_pg_tmp, a1, a2, a3);
   assign CO = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? CO_pg_tmp : 1'bx;
   xor g5  (S_pg_tmp, A, B, CI);
   assign S = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? S_pg_tmp : 1'bx;

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (A == 0 && CI == 1) (B *> S) = (1.00, 1.00);
      if (A == 1 && CI == 1) (B *> S) = (1.00, 1.00);
      if (A == 0 && CI == 0) (B *> S) = (1.00, 1.00);
      if (A == 1 && CI == 0) (B *> S) = (1.00, 1.00);
      ifnone (B *> S) = (1.00, 1.00);
      if (A == 1 && CI == 0) (B *> CO) = (1.00, 1.00);
      if (A == 0 && CI == 1) (B *> CO) = (1.00, 1.00);
      ifnone (B *> CO) = (1.00, 1.00);
      if (B == 0 && CI == 0) (A *> S) = (1.00, 1.00);
      if (B == 1 && CI == 0) (A *> S) = (1.00, 1.00);
      if (B == 0 && CI == 1) (A *> S) = (1.00, 1.00);
      if (B == 1 && CI == 1) (A *> S) = (1.00, 1.00);
      ifnone (A *> S) = (1.00, 1.00);
      if (B == 1 && CI == 0) (A *> CO) = (1.00, 1.00);
      if (B == 0 && CI == 1) (A *> CO) = (1.00, 1.00);
      ifnone (A *> CO) = (1.00, 1.00);
      if (A == 1 && B == 0) (CI *> S) = (1.00, 1.00);
      if (A == 0 && B == 1) (CI *> S) = (1.00, 1.00);
      if (A == 0 && B == 0) (CI *> S) = (1.00, 1.00);
      if (A == 1 && B == 1) (CI *> S) = (1.00, 1.00);
      ifnone (CI *> S) = (1.00, 1.00);
      if (A == 1 && B == 0) (CI *> CO) = (1.00, 1.00);
      if (A == 0 && B == 1) (CI *> CO) = (1.00, 1.00);
      ifnone (CI *> CO) = (1.00, 1.00);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


