//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module AN2QBDFFNLHHMX0P4 (QB, D1, D2, CK, VCCNW, GND, VCC);
   output QB;
   inout VCCNW;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   reg flag; // Notifier flag
   supply1 vcc;

   wire d_CK,d_D1,d_D2;

//Function Block
`protect
   and g4 (n1, d_D1, d_D2);
   not g3  (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dffrsb_udp g2(qt,  n1,  d_CK,  vcc,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.10;
      specparam setup_D2_CK = 9.10;
      specparam hold_D1_CK = 0.00;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK, posedge D1 &&& D2, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, negedge D1 &&& D2, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, posedge D2 &&& D1, 1.00, 1.00, flag,,,d_CK, d_D2);
      $setuphold(posedge CK, negedge D2 &&& D1, 1.00, 1.00, flag,,,d_CK, d_D2);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 13.86;
      specparam mpw_pos_CK = 12.21;
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


