//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFFRBNLEHMX0P7 (QB, D, CK, RB);

   reg flag; // Notifier flag
   output QB;
   input D, CK, RB;
   supply1 vcc;
//   reg D_flag;
//   wire D_flag1;

   wire d_CK, d_D;

//Function Block
`protect
   not g3(QB, qt);
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  vcc,  flag );
   

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 6.30;
      specparam hold_D_CK = 0.00;
      
      $setuphold(posedge CK &&& RB, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      
      //  Recovery Time
      specparam recovery_RB_CK = 4.30;
      specparam recovery_CK_RB = 9.00;
//      $recovery(posedge RB, posedge CK &&& D_flag1, recovery_RB_CK, flag);
//      $hold(posedge CK &&& D_flag1, posedge RB, recovery_CK_RB, flag);
      $recrem(posedge RB, posedge CK , 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 3.94;
      specparam mpw_neg_CK = 14.51;
      specparam mpw_pos_CK = 13.64;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine


