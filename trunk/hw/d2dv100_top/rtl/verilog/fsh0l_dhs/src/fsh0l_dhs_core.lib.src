//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDBZNLEHMX1 (Q, D, TD, CKB, SEL);
   reg flag; // Notifier flag
   output Q;
   input D, CKB, TD, SEL;
   supply1 vcc;
   reg D_flag;
   wire d_CKB, d_D, d_SEL, d_TD, D_flag1;

//Function Block


`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3(Q, qt);
   dffrsb_udp g2(qt, d1, ck, vcc, vcc, flag);
   not g1(ck,  d_CKB );
   mux2_udp g4(d1,  d_D,  d_TD,  d_SEL );


//Append pseudo gate for timing violation checking
   assign D_flag1   = D_flag;    // For Model-Tec complier
   always @(SEL_ or d_D or d_TD)
     begin
       if (SEL_ === 1'b0)
           D_flag = d_D;
       else
           D_flag = d_TD;
    end

//Specify Block
   specify

      //  Module Path Delay
      (negedge CKB *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CKB = 7.00;
      specparam hold_D_CKB = 0.00;
      specparam setup_SEL_CKB = 7.30;
      specparam hold_SEL_CKB = 0.00;
      specparam setup_TD_CKB = 8.28;
      specparam hold_TD_CKB = 0.00;
      $setuphold(negedge CKB, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB, posedge SEL, 1.00, 1.00, flag,,,d_CKB, d_SEL);
      $setuphold(negedge CKB, negedge SEL, 1.00, 1.00, flag,,,d_CKB, d_SEL);
      $setuphold(negedge CKB, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CKB, d_TD);
      $setuphold(negedge CKB, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CKB, d_TD);

      //  Minimum Pulse Width
      specparam mpw_pos_CKB = 15.30;
      specparam mpw_neg_CKB = 15.30;
      $width(posedge CKB, 1.00, 0, flag);
      $width(negedge CKB, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


