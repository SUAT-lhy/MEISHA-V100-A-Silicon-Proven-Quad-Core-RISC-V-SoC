      ifnone (posedge  B *> (S :1'bx)) = (1.00, 1.00);
      ifnone (negedge  B *> (S :1'bx)) = (1.00, 1.00);

      //  Module Path Delay
      (A *> C) = (1.00, 1.00);
      (B *> C) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


