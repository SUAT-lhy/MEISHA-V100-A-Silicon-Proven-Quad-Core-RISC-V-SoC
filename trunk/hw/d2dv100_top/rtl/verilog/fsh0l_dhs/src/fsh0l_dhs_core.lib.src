//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGQDFFLEHMX1 (Q, D, CK);
   reg flag; // Notifier flag
   output Q;
   input D, CK;
   supply1 vcc;

   wire d_CK, d_D;

//Function Block
`protect
   buf g2(Q, qt);
   dffrsb_udp g1(qt,  d_D,  d_CK,  vcc,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 9.20;
      specparam hold_D_CK = 0.00;
      $setuphold(posedge CK, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);

      //  Minimum Pulse Width
      specparam mpw_pos_CK = 12.27;
      specparam mpw_neg_CK = 14.02;
      $width(posedge CK, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


