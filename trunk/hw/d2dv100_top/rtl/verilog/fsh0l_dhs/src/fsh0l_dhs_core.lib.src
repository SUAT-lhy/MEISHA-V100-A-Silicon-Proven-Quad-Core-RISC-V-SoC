  output Q;
  input D, CK, SL;
  reg flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_SL;

//Function Block
`protect

   not n1 (on1, d_SL);
   not n2 (on2, d_CK);
    
   and a1 (oa1, d_CK, on1);
   dlhrsb_udp dlh1 (odlh1,d_D, on2, vcc, vcc, flag ); 
   dlhrsb_udp dlh2 (qt, odlh1, oa1, vcc, vcc, flag ); 
   buf (Q, qt);


//Specify Block
  specify
    (posedge CK *> (Q :1'bx)) = (1.00, 1.00);

//  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_CK_SL = 0.00;
      specparam hold_CK_SL = 0.00;
      $setuphold(posedge CK &&& ~SL, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ~SL, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge SL, posedge CK, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK, 1.00, 1.00, flag,,,d_SL, d_CK);
