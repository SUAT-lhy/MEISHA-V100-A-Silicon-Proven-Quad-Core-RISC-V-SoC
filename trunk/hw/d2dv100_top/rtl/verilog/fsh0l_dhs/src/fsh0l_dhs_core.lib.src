	and (ENABLE_D1_AND_RB_AND_NOT_SEL_AND_TD, D1, RB, SEL__bar, TD);
	and (ENABLE_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, D1, RB, SEL__bar, TD__bar);
	not (D1__bar, D1);
