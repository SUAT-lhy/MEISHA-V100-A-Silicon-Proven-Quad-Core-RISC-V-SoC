      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D1 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D1 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
