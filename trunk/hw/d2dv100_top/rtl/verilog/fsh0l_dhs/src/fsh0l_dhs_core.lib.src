//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDBFRBNLEHMX2 (Q, D, CKB, RB);
   reg flag; // Notifier flag
   output Q;
   input D, CKB, RB;
   supply1 vcc;

   wire d_CKB, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   dffrsb_udp g2(qt,  d_D,  ck,  RB,  vcc,  flag );
   not g7(ck,  d_CKB );

//Specify Block
   specify

      //  Module Path Delay
      (negedge CKB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CKB = 33.8500;
      specparam hold_D_CKB = 6.9700;
      $setuphold(negedge CKB &&& RB, posedge D, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& RB, negedge D, 1.00, 1.00, flag,,,d_CKB, d_D);

      //  Recovery Time
      specparam recovery_RB_CKB = 5.4700;
      specparam recovery_CKB_RB = 22.0700;
      $recrem(posedge RB, negedge CKB, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_CKB = 47.7800;
      specparam mpw_pos_CKB = 47.4500;
      specparam mpw_neg_RB = 45.3600;
      $width(negedge CKB, 1.00, 0, flag);
      $width(posedge CKB, 1.00, 0, flag);
      $width(negedge RB, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDBFRSBNLEHMX1 (Q, D, CKB, RB, SB);
   reg flag; // Notifier flag
   output Q;
   input D, CKB, RB, SB;

   wire d_CKB, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  ck,  RB,  SB,  flag );
   and g4(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
//   and g6(QB, qb1, rs);
   not g7(ck,  d_CKB );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
      (negedge CKB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CKB = 6.66;
      specparam hold_D_CKB = 0.00;
      $setuphold(negedge CKB &&& _SB_and_RB_, posedge D, 1.00, 1.00, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& _SB_and_RB_, negedge D, 1.00, 1.00, flag,,,d_CKB, d_D);

      //  Recovery Time
      specparam recovery_RB_CKB = 3.81;
      specparam recovery_SB_CKB = 11.30;
      specparam recovery_CKB_RB = 8.90;
      specparam recovery_CKB_SB = 0.50;
      $recrem(posedge RB, negedge CKB &&& d_D, 1.00, 1.00, flag);
      $recrem(posedge SB, negedge CKB &&& ~d_D, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 16.47;
      specparam mpw_neg_SB = 16.47;
      specparam mpw_pos_CKB = 12.39;
      specparam mpw_neg_CKB = 12.39;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(posedge CKB, 1.00, 0, flag);
      $width(negedge CKB, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


