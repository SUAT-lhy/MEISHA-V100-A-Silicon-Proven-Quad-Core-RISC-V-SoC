      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_OR_NOT_D1, posedge CK &&& ENABLE_D1_AND_NOT_D2_OR_NOT_D1, 1.00, 1.00, flag);


      //  Minimum Pulse Width
