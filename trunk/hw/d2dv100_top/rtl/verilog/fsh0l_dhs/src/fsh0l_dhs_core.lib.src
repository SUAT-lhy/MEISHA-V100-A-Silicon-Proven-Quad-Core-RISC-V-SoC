//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFZRSBNLEHMX1 (QB, D, TD, CK, SEL, RB, SB);
   reg flag; // Notifier flag
   output QB;
   input D, CK, TD, SB, SEL, RB;
   reg D_flag;
   wire D_flag1;
   wire d_CK, d_D, d_SEL, d_TD;

//Function Block
`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.

   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d1,  d_CK,  RB,  SB,  flag );
   and g7(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   and g6(QB, qb1, rs);
   mux2_udp g4(d1,  d_D,  d_TD,  SEL_);

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1   = D_flag;    // For Model-Tec complier
always @(SEL_ or d_D or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D;
    else
        D_flag = d_TD;
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_SEL_CK = 8.40;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.70;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& _SB_and_RB_, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.12;
      specparam recovery_SB_CK = 10.60;
      specparam recovery_CK_RB = 8.90;
      specparam recovery_CK_SB = 1.27;
      $recrem(posedge RB, posedge CK &&& D_flag1, 1.00, 1.00, flag);
      $recrem(posedge SB, posedge CK &&& ~D_flag1, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.85;
      specparam mpw_neg_SB = 16.69;
      specparam mpw_neg_CK = 15.09;
      specparam mpw_pos_CK = 12.96;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFZRSBNLEHMX2 (QB, D, TD, CK, SEL, RB, SB);
   reg flag; // Notifier flag
   output QB;
   input D, CK, TD, SB, SEL, RB;
   reg D_flag;
   wire D_flag1;
   wire d_CK, d_D, d_SEL, d_TD;

//Function Block
`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.

   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d1,  d_CK,  RB,  SB,  flag );
   and g7(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   and g6(QB, qb1, rs);
   mux2_udp g4(d1,  d_D,  d_TD,  SEL_);

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1   = D_flag;    // For Model-Tec complier
always @(SEL_ or d_D or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D;
    else
        D_flag = d_TD;
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_SEL_CK = 8.40;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.70;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& _SB_and_RB_, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.12;
      specparam recovery_SB_CK = 10.60;
      specparam recovery_CK_RB = 8.90;
      specparam recovery_CK_SB = 1.27;
      $recrem(posedge RB, posedge CK &&& D_flag1, 1.00, 1.00, flag);
      $recrem(posedge SB, posedge CK &&& ~D_flag1, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.85;
      specparam mpw_neg_SB = 16.69;
      specparam mpw_neg_CK = 15.09;
      specparam mpw_pos_CK = 12.96;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


