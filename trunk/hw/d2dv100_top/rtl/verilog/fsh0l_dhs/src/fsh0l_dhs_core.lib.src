//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module HA1LEHMX1 (S, C, A, B);
   output S, C;
   input A, B;

//Function Block
`protect
   and g1(C, A, B);
   xor g2(S, A, B);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B == 0) (A *> (S :1'bx)) = (1.00, 1.00);
      if (B == 1) (A *> (S :1'bx)) = (1.00, 1.00);
      ifnone (posedge  A *> (S :1'bx)) = (1.00, 1.00);
      ifnone (negedge  A *> (S :1'bx)) = (1.00, 1.00);
      if (A == 0) (B *> (S :1'bx)) = (1.00, 1.00);
      if (A == 1) (B *> (S :1'bx)) = (1.00, 1.00);
      ifnone (posedge  B *> (S :1'bx)) = (1.00, 1.00);
      ifnone (negedge  B *> (S :1'bx)) = (1.00, 1.00);

      //  Module Path Delay
      (A *> C) = (1.00, 1.00);
      (B *> C) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


