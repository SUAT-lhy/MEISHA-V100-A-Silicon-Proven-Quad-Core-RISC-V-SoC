     if (e_tmp==1'b0)
     begin
       case ({pu_tmp,pd_tmp,ie_tmp})
         3'b100 ,
	 3'b101 ,
         3'b10z ,
	 3'b10x :
         begin
           if (io===1'b1)
           begin
             disable BlockPU;
             io_e = 1'b1;
           end
           else if (io===1'b0)
           begin
             disable BlockPU;
             io_e = 1'bz;
           end
           else if (io===1'bx)
           begin
             disable BlockPU;
             io_e = 1'bz;
           end
           else if (io===1'bz)
           begin
             disable BlockPU;
             io_e = 1'bz;
             #0 ->Event_PU;
           end
         end
         3'b010 ,
	 3'b011 ,
         3'b01z ,
	 3'b01x ,
	 3'b110 :
         begin
           if (io===1'b0)
           begin
             disable BlockPD;
             io_e = 1'b0;
           end
           else if (io===1'b1)
           begin
             disable BlockPD;
             io_e = 1'bz;
           end
           else if (io===1'bx)
           begin
             disable BlockPD;
             io_e = 1'bz;
           end
           else if (io===1'bz)
           begin
             disable BlockPD;
             io_e = 1'bz;
             #0 ->Event_PD;
           end
         end
         3'b000 ,
	 3'b001 ,
         3'b00z ,
	 3'b00x :
         begin
           io_e <= 1'bz;
         end
         3'b111 :
         begin
           #0 ->Event_KEEP;
         end
         default : 
	 begin
	   io_e = 1'bx; 	 
	 end
       endcase
     end
   end

   always @(Event_DisableAll)
