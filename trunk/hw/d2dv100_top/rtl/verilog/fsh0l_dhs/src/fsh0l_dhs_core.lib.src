module MGMUX2LEHMX1 (O, S, A, B);
   reg flag; // Notifier flag
   input A, B, S;
   output O;

//Function Block
`protect
   mux2_udp g1(O, A, B, S);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B == 0) (A *> (O :1'bx)) = (1.00, 1.00);
      if (B == 1) (A *> (O :1'bx)) = (1.00, 1.00);
      ifnone (posedge  A *> (O :1'bx)) = (1.00, 1.00);
      ifnone (negedge  A *> (O :1'bx)) = (1.00, 1.00);
      if (A == 0) (B *> (O :1'bx)) = (1.00, 1.00);
      if (A == 1) (B *> (O :1'bx)) = (1.00, 1.00);
      ifnone (posedge  B *> (O :1'bx)) = (1.00, 1.00);
      ifnone (negedge  B *> (O :1'bx)) = (1.00, 1.00);
      if (A == 1 && B == 0) (S *> (O :1'bx)) = (1.00, 1.00);
      if (A == 0 && B == 1) (S *> (O :1'bx)) = (1.00, 1.00);
      ifnone (posedge  S *> (O :1'bx)) = (1.00, 1.00);
      ifnone (negedge  S *> (O :1'bx)) = (1.00, 1.00);
`ifdef delayfix
   pathdelay_enhanced;
`endif
      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


