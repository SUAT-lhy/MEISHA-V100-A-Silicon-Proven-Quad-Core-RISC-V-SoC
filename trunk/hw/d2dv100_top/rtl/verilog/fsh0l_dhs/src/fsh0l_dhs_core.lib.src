//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDFFRBNLEHMX0P7 (Q, D, CK, RB);
   reg flag; // Notifier flag
   output Q;
   input D, CK, RB;
   supply1 vcc;

   wire d_CK, d_D;

//Function Block
`protect
   buf g2(Q, qt);
   dffrsb_udp g1(qt,  d_D,  d_CK,  RB,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 5.60;
      specparam hold_D_CK = 0.00;
      $setuphold(posedge CK &&& RB, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);

      //  Recovery Time
      specparam recovery_RB_CK = 4.80;
      specparam recovery_CK_RB = 7.50;
      $recrem(posedge RB, posedge CK &&& d_D, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 3.80;
      specparam mpw_neg_CK = 10.60;
      specparam mpw_pos_CK = 9.71;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


