module FA1LEHMX1 (S, CO, A, B, CI);
   output S, CO;
   input A, B, CI;

//Function Block
`protect
   and g1 (a1,A,B);
   and g2 (a2,B,CI);
   and g3 (a3,A,CI);
   or  g4 (CO,a1,a2,a3);
   xor g5 (S,A,B,CI);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (A == 1 && CI == 0) (B *> (S :1'bx)) = (1.00, 1.00);
      if (A == 0 && CI == 1) (B *> (S :1'bx)) = (1.00, 1.00);
      if (A == 1 && CI == 1) (B *> (S :1'bx)) = (1.00, 1.00);
      if (A == 0 && CI == 0) (B *> (S :1'bx)) = (1.00, 1.00);
      ifnone (posedge  B *> (S :1'bx)) = (1.00, 1.00);
      ifnone (negedge  B *> (S :1'bx)) = (1.00, 1.00);
      if (A == 0 && CI == 1) (B *> (CO :1'bx)) = (1.00, 1.00);
      if (A == 1 && CI == 0) (B *> (CO :1'bx)) = (1.00, 1.00);
      ifnone (posedge  B *> (CO :1'bx)) = (1.00, 1.00);
      ifnone (negedge  B *> (CO :1'bx)) = (1.00, 1.00);
      if (B == 0 && CI == 1) (A *> (S :1'bx)) = (1.00, 1.00);
      if (B == 1 && CI == 1) (A *> (S :1'bx)) = (1.00, 1.00);
      if (B == 0 && CI == 0) (A *> (S :1'bx)) = (1.00, 1.00);
      if (B == 1 && CI == 0) (A *> (S :1'bx)) = (1.00, 1.00);
      ifnone (posedge  A *> (S :1'bx)) = (1.00, 1.00);
      ifnone (negedge  A *> (S :1'bx)) = (1.00, 1.00);
      if (B == 0 && CI == 1) (A *> (CO :1'bx)) = (1.00, 1.00);
      if (B == 1 && CI == 0) (A *> (CO :1'bx)) = (1.00, 1.00);
      ifnone (posedge  A *> (CO :1'bx)) = (1.00, 1.00);
      ifnone (negedge  A *> (CO :1'bx)) = (1.00, 1.00);
      if (A == 1 && B == 0) (CI *> (S :1'bx)) = (1.00, 1.00);
      if (A == 0 && B == 1) (CI *> (S :1'bx)) = (1.00, 1.00);
      if (A == 0 && B == 0) (CI *> (S :1'bx)) = (1.00, 1.00);
      if (A == 1 && B == 1) (CI *> (S :1'bx)) = (1.00, 1.00);
      ifnone (posedge  CI *> (S :1'bx)) = (1.00, 1.00);
      ifnone (negedge  CI *> (S :1'bx)) = (1.00, 1.00);
      if (A == 1 && B == 0) (CI *> (CO :1'bx)) = (1.00, 1.00);
      if (A == 0 && B == 1) (CI *> (CO :1'bx)) = (1.00, 1.00);
      ifnone (posedge  CI *> (CO :1'bx)) = (1.00, 1.00);
      ifnone (negedge  CI *> (CO :1'bx)) = (1.00, 1.00);

