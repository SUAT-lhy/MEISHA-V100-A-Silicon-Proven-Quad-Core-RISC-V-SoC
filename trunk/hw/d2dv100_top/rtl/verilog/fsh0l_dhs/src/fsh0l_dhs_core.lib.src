//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFFRSBNLEHMX1 (QB, D, CK, RB, SB);
   reg flag; // Notifier flag
   output QB;
   input D, CK, SB, RB;
   
   wire d_CK, d_D;

//Function Block
`protect
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  SB,  flag );
   and g7(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   and g6(QB, qb1, rs);
   
//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      
      $setuphold(posedge CK, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      

      //  Recovery Time
      specparam recovery_RB_CK = 5.12;
      specparam recovery_SB_CK = 10.60;
      specparam recovery_CK_RB = 8.90;
      specparam recovery_CK_SB = 1.27;
      $recrem(posedge RB, posedge CK &&& d_D, 1.00, 1.00, flag);
      $recrem(posedge SB, posedge CK &&& ~d_D, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.85;
      specparam mpw_neg_SB = 16.69;
      specparam mpw_neg_CK = 15.09;
      specparam mpw_pos_CK = 12.96;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFFRSBNLEHMX2 (QB, D, CK, RB, SB);
   reg flag; // Notifier flag
   output QB;
   input D, CK, SB, RB;
   
   wire d_CK, d_D;

//Function Block
`protect
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  SB,  flag );
   and g7(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   and g6(QB, qb1, rs);
   
//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      
      $setuphold(posedge CK, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      

      //  Recovery Time
      specparam recovery_RB_CK = 5.12;
      specparam recovery_SB_CK = 10.60;
      specparam recovery_CK_RB = 8.90;
      specparam recovery_CK_SB = 1.27;
      $recrem(posedge RB, posedge CK &&& d_D, 1.00, 1.00, flag);
      $recrem(posedge SB, posedge CK &&& ~d_D, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.85;
      specparam mpw_neg_SB = 16.69;
      specparam mpw_neg_CK = 15.09;
      specparam mpw_pos_CK = 12.96;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


