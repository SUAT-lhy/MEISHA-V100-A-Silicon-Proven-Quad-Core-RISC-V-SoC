      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
