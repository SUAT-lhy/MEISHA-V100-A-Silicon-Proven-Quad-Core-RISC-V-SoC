	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_TD, D1__bar, RB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, D1__bar, RB, SEL__bar, TD__bar);
