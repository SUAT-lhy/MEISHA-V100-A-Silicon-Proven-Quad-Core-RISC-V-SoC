	and (ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, D1__bar, D2__bar, D3, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, D1__bar, D2__bar, D3__bar, D4, SEL__bar);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_RB_AND_SEL, D1, RB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL, D1__bar, RB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
