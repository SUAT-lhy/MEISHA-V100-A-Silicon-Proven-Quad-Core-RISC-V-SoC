   supply1 vcc;
   
   wire d_CK, d_D;

//Function Block
`protect
   
   buf g3(Q, qt);
   dffrsb_udp g1(qt,  d_D,  d_CK,  vcc,  SB,  flag );


//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 6.90;
      specparam hold_D_CK = 0.00;
      $setuphold(posedge CK, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      
      //  Recovery Time
      specparam recovery_SB_CK = 1.50;
      specparam recovery_CK_SB = 4.00;
      $recrem(posedge SB, posedge CK &&& ~d_D, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 10.98;
      specparam mpw_neg_CK = 15.84;
      specparam mpw_pos_CK = 15.14;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


