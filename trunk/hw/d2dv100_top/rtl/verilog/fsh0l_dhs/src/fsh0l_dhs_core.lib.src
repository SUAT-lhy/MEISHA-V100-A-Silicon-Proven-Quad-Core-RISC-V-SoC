//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFFRSBLEHMX1 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB, SB);
   reg flag, flag1, flag2, flag3; // Notifier flag
   output Q1, Q2, Q3, Q4;
   input D1, D2, D3, D4, CK, RB, SB;

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   buf g5(Q3, qt3);
   buf g6(Q4, qt4);
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  SB,  flag3 );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, ENABLE_D1_AND_RB_AND_SB;
	wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB;
	wire ENABLE_NOT_CK_AND_SB, ENABLE_NOT_D1_AND_RB_AND_SB, ENABLE_RB_AND_SB;
	wire int_twire_0, int_twire_1, int_twire_2;
	wire int_twire_3, int_twire_4, int_twire_5;
	wire int_twire_6, int_twire_7;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB, D1, RB, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB, D1__bar, RB, SB);
	and (ENABLE_RB_AND_SB, RB, SB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4, SB);
	and (int_twire_1, D1__bar, D2__bar, D3, SB);
	and (int_twire_2, D1__bar, D2, SB);
	and (int_twire_3, D1, SB);
	or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, int_twire_3, int_twire_2, int_twire_1, int_twire_0);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (int_twire_4, D1__bar, RB);
	and (int_twire_5, D1, D2__bar, RB);
	and (int_twire_6, D1, D2, D3__bar, RB);
	not (D4__bar, D4);
	and (int_twire_7, D1, D2, D3, D4__bar, RB);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_7, int_twire_6, int_twire_5, int_twire_4);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);




//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);


      //  Setup and Hold Time
      specparam setup_D1_CK = 5.90;
      specparam hold_D1_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 5.90;
      specparam hold_D2_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 5.90;
      specparam hold_D3_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D3 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 5.90;
      specparam hold_D4_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D4 &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 9.50;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.26;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 11.42;
      specparam mpw_pos_CK = 10.53;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
