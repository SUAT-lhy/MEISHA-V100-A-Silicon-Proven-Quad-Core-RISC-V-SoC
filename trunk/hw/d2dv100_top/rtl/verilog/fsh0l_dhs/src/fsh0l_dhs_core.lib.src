module QDSFZRBLEHMX0P7 (Q, D, TD, CK, SEL, RB, SL);
  output Q;
  input D, TD, CK, SEL, RB, SL;
  reg flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_TD, d_SL, d_SEL;
  wire on1, on2, on3, om1, ona1, oa2;

//Function Block
`protect

   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_RB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   mux2_udp m1 (om1,  d_D,  d_TD, SEL_ );
    
   nand a1 (ona1, on1, on2);
   and a2 (oa2, d_RB, on2, d_CK); 
   dlhrsb_udp dlh1 (odlh1, om1, on3, d_RB, vcc, flag ); 
   dlhrsb_udp dlh2 (qt, odlh1, oa2, ona1, vcc, flag ); 
   buf (Q, qt);

	wire ENABLE_RB_NOT_SEL_NOT_SL;
	wire ENABLE_RB_SEL_NOT_SL;
	wire ENABLE_RB_NOT_SL;

	not (SL_b, SL);
	not (SEL_b, SEL);
	and (ENABLE_RB_NOT_SEL_NOT_SL, RB, SEL_b, SL_b);
	and (ENABLE_RB_SEL_NOT_SL, RB, SEL, SL_b);
	and (ENABLE_RB_NOT_SL, RB, SL_b);

//Specify Block
  specify
   (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
   (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
//  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      specparam setup_CK_SL = 0.00;
      specparam hold_CK_SL = 0.00;
      specparam setup_RB_SL = 0.00;
      specparam hold_RB_SL = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SEL_NOT_SL, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SEL_NOT_SL, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SL, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SL, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_SEL_NOT_SL, posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_RB_SEL_NOT_SL, negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge SL, posedge CK &&& RB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& RB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, posedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
       
      $setuphold(negedge SL, posedge CK &&& RB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& RB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, posedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
      $recrem(posedge RB &&& ~SL, posedge CK, 1.00, 1.00, flag);
      $recrem(negedge SL, negedge CK, 1.00, 1.00, flag);
      $recrem(posedge SL, posedge CK, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

  endspecify

`endprotect
endmodule
