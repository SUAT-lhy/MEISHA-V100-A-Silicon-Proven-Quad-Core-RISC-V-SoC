      $setuphold(posedge CK, posedge RB &&& RB_flag, 1.00, 1.00, flag,,,d_CK, d_RB);
      $setuphold(posedge CK, negedge RB &&& RB_flag, 1.00, 1.00, flag,,,d_CK, d_RB);
      $setuphold(posedge CK, posedge SEL &&& SEL_flag, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL &&& SEL_flag, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 26.43;
      specparam mpw_pos_CK = 23.99;
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
