	not (SL_b, SL);
	not (SEL_b, SEL);
	and (ENABLE_SB_NOT_SEL_NOT_SL, SB, SEL_b, SL_b);
	and (ENABLE_SB_SEL_NOT_SL, SB, SEL, SL_b);
	and (ENABLE_SB_NOT_SL, SB, SL_b);

//Specify Block
  specify
    (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
    (negedge SB *> (Q :1'bx)) = (1.00, 1.00);
//  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      specparam setup_CK_SL = 0.00;
      specparam hold_CK_SL = 0.00;
      specparam setup_SB_SL = 0.00;
      specparam hold_SB_SL = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB_NOT_SEL_NOT_SL, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_SB_NOT_SEL_NOT_SL, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_SB_NOT_SL, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB_NOT_SL, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB_SEL_NOT_SL, posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_SB_SEL_NOT_SL, negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge SL, posedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
       
      $setuphold(negedge SL, posedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& SB, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      $setuphold(negedge SL, posedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      //  Recovery Time
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_SB = 1.29;
      $recrem(posedge SB &&& ~SL, posedge CK, 1.00, 1.00, flag);
      $recrem(negedge SL, negedge CK, 1.00, 1.00, flag);
      $recrem(posedge SL, posedge CK, 1.00, 1.00, flag);


      

      //  Minimum Pulse Width
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

  endspecify

`endprotect
endmodule
