   dffrsb_udp g2(qt2,  d_D2,  d_CK,  vcc,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  vcc,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  vcc,  SB,  flag3 );

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar, ENABLE_SB;
	wire D4__bar, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_OR_D1_AND_D2_AND_NOT_D3_OR_D1_AND_NOT_D2_OR_NOT_D1, ENABLE_D1_AND_SB;
	wire ENABLE_NOT_CK, ENABLE_NOT_D1_AND_SB, int_twire_0;
	wire int_twire_1, int_twire_2;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	and (ENABLE_D1_AND_SB, D1, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_SB, D1__bar, SB);
	not (D2__bar, D2);
	and (int_twire_0, D1, D2__bar);
	not (D3__bar, D3);
	and (int_twire_1, D1, D2, D3__bar);
	not (D4__bar, D4);
	and (int_twire_2, D1, D2, D3, D4__bar);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_OR_D1_AND_D2_AND_NOT_D3_OR_D1_AND_NOT_D2_OR_NOT_D1, int_twire_2, int_twire_1, int_twire_0, D1__bar);
	not (ENABLE_NOT_CK, CK);



//Specify Block
   specify

