module SYN3QDFZNLEHMX3 (Q, D, TD, CK, SEL);
   reg flag; // Notifier flag
   output Q;
   input D, CK, TD, SEL;
   supply1 vcc;

   wire d_CK, d_D, d_TD, d_SEL;

   wire ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_D_AND_SEL_AND_TD;
   wire ENABLE_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_SEL_AND_TD;
   wire ENABLE_NOT_D_AND_TD;
   wire ENABLE_D_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_SEL;
   wire ENABLE_D_AND_SEL;

   assign ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD = !D & !SEL & !TD;
   assign ENABLE_NOT_D_AND_SEL_AND_NOT_TD = !D & SEL & !TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_TD = !D & !SEL & TD;
   assign ENABLE_NOT_D_AND_SEL_AND_TD = !D & SEL & TD;
   assign ENABLE_D_AND_NOT_SEL_AND_TD = D & !SEL & TD;
   assign ENABLE_D_AND_NOT_SEL_AND_NOT_TD = D & !SEL & !TD;
   assign ENABLE_D_AND_SEL_AND_NOT_TD = D & SEL & !TD;
   assign ENABLE_D_AND_SEL_AND_TD = D & SEL & TD;
   assign ENABLE_NOT_SEL_AND_NOT_TD = !SEL & !TD;
   assign ENABLE_NOT_SEL_AND_TD = !SEL & TD;
   assign ENABLE_NOT_D_AND_TD = !D & TD;
   assign ENABLE_D_AND_NOT_TD = D & !TD;
   assign ENABLE_NOT_D_AND_SEL = !D & SEL;
   assign ENABLE_D_AND_SEL = D & SEL;

//Function Block
`protect
   buf (Q, qt);
   dffrsb_udp g1(q1, d1, d_CK, vcc, vcc, flag );
   dffrsb_udp g2(q2, q1, d_CK, vcc, vcc, flag );
   dffrsb_udp g3(qt, q2, d_CK, vcc, vcc, flag );

   mux2_udp g4(d1,  d_D,  d_TD,  d_SEL );

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (D == 1 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      ifnone (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      //  Module Path Delay

      //  Setup and Hold Time
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_TD,     posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_TD,     negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_D_AND_TD,       posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold   (posedge CK &&& ENABLE_NOT_D_AND_TD,       negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold   (posedge CK &&& ENABLE_D_AND_NOT_TD,       posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold   (posedge CK &&& ENABLE_D_AND_NOT_TD,       negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold   (posedge CK &&& ENABLE_NOT_D_AND_SEL,      posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold   (posedge CK &&& ENABLE_NOT_D_AND_SEL,      negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold   (posedge CK &&& ENABLE_D_AND_SEL,          posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold   (posedge CK &&& ENABLE_D_AND_SEL,          negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Minimum Pulse Width
      $width (negedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_SEL_AND_TD, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
