`timescale 10ps / 1ps

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module PDTLF (OE18V);
  output OE18V;
  supply1 vcc;
        
  //Function Block
 `protect
   buf g1(OE18V, vcc);
                
  //Specify Block
     specify
     endspecify
  `endprotect
 endmodule
  `endcelldefine
 

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WRNE4GSLAX250 (O, I, IO, E, E4, E8, SR, IE, PU, PD, SMT);
   output O;
   input I, E, E4, E8, SR, IE, SMT, PU, PD;
   inout IO;

//Function Block
`protect
   // Avoide MIPD
   buf b1 (E4_,E4);
   buf b2 (E8_,E8);
   buf b3 (SR_,SR);
   buf b4 (SMT_,SMT);

   pullup_down_keep_IO g1 (IO, I, E, PU, PD);
   and    g2(O, IO, IE);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (E4 == 0 && E8 == 0 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 0 && E8 == 0 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E == 0) (I *> IO) = (0:0:0, 0:0:0);
      ifnone (I *> IO) = (1.00, 1.00);
      if (SMT == 0) (IE *> O) = (1.00, 1.00);
      if (SMT == 1) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);
      if (SMT == 1) (IO *> O) = (1.00, 1.00);
      if (SMT == 0) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 0 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 0 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      //  Module Path Delay (state dependent)
      //  Module Path Delay
      if (E == 0) (PU *> IO) = (0.0:0.0:0.0);
      ifnone (PU *> IO) = (0.0:0.0:0.0);
      if (E == 0) (PD *> IO) = (0.0:0.0:0.0);
      ifnone (PD *> IO) = (0.0:0.0:0.0);
   endspecify
`endprotect
endmodule
`endcelldefine

//-- FTC standard cell revision 1.2 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WROSCAHINTLA (O, I, IO, E, EB, S0, S1, FEB);
   input I, E, EB, FEB, S0, S1;
   inout IO;
   output O;

//Function Block
`protect
   // Avoide MIPD
   buf b1 (S0_,S0);
   buf b2 (S1_,S1);
   buf b3 (FEB_,FEB);

   nand g1 (io_tmp,I,E);
   bufif0 (weak1, weak0) g2 (IO,io_tmp,EB);
   not g3 (eb_, EB);
   or g4 (or_o, eb_, E);
   and g5 (O, IO, or_o);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (S0 == 0 && S1 == 0) (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 0) (E *> IO) = (1.00, 1.00);
      if (S0 == 0 && S1 == 1) (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (E *> IO) = (1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 0) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 1 && S1 == 0) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 1) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 1) (I *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (I *> IO) = (1.00, 1.00);
      if (S0 == 0 && S1 == 0) (I *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 0) (I *> IO) = (1.00, 1.00);
      ifnone (I *> IO) = (1.00, 1.00);
      //  Module Path Delay
      (E *> O) = (1.00, 1.00);
      (EB *> O) = (1.00, 1.00);
      (IO *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WRTRNE28SLB (O, I, IO, E, E2, E4, SR, IE, PU, PD, SMT);
   output O;
   input I, E, E2, E4, SR, IE, SMT, PU, PD;
   inout IO;

//Function Block
`protect
   // Avoide MIPD
   buf b1 (E2_,E2);
   buf b2 (E4_,E4);
   buf b3 (SR_,SR);
   buf b4 (SMT_,SMT);

   pullup_down_keep_IO_IE g1 (IO, I, E, IE, PU, PD);
   and    g2(O, IO, IE);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (E2 == 0 && E4 == 0 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E2 == 1 && E4 == 0 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E2 == 0 && E4 == 1 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E2 == 1 && E4 == 1 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E2 == 0 && E4 == 0 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E2 == 0 && E4 == 1 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E2 == 1 && E4 == 0 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E2 == 1 && E4 == 1 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E == 0) (I *> IO) = (0:0:0, 0:0:0);
      ifnone (I *> IO) = (1.00, 1.00);
      if (SMT == 0) (IE *> O) = (1.00, 1.00);
      if (SMT == 1) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);
      if (SMT == 1) (IO *> O) = (1.00, 1.00);
      if (SMT == 0) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
      if (E2 == 1 && E4 == 0 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 0 && E4 == 0 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 1 && E4 == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 0 && E4 == 1 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 0 && E4 == 0 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 0 && E4 == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 1 && E4 == 0 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E2 == 1 && E4 == 1 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);

      //  Module Path Delay (state dependent)

      //  Module Path Delay
      if (E == 0) (PU *> IO) = (0.0:0.0:0.0);
      ifnone (PU *> IO) = (0.0:0.0:0.0);
      if (E == 0) (PD *> IO) = (0.0:0.0:0.0);
      ifnone (PD *> IO) = (0.0:0.0:0.0);
   endspecify
`endprotect
endmodule
`endcelldefine

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WYNE2ASLA (O, I, IO, E, E4, E8, SR, IE, PU, PD, SMT);
   output O;
   input I, E, E4, E8, SR, IE, PU, PD, SMT;
