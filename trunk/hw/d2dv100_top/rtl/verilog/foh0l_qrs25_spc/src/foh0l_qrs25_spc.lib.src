//-- FTC standard cell revision 1.2 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XOSCAHINTLAX1 (O, I, IO, E, EB, S0, S1, FEB, E3VB);
   input I, E, EB, FEB, S0, S1, E3VB;
   inout IO;
   output O;

//Function Block
`protect
   not (e3v, E3VB);
	not (eb_b, EB);
	not (e_b, E);
	not (i_b, I);
	and (ioc, e3v, eb_b);
	or  (ioi, i_b, e_b);

	bufif1 (IO, ioi, ioc);

	and (e3v_1, e3v, E);
	and (e3v_2, e3v, eb_b);
	or  (o_1, e3v_1, e3v_2);
	and (O, IO, o_1);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (S0 == 0 && S1 == 0) (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 0) (E *> IO) = (1.00, 1.00);
      if (S0 == 0 && S1 == 1) (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (E *> IO) = (1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 0) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 1 && S1 == 0) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 1) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 1) (I *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (I *> IO) = (1.00, 1.00);
      if (S0 == 0 && S1 == 0) (I *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 0) (I *> IO) = (1.00, 1.00);
      ifnone (I *> IO) = (1.00, 1.00);
      //  Module Path Delay
      (E *> O) = (1.00, 1.00);
      (EB *> O) = (1.00, 1.00);
      (IO *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine

//-- FTC standard cell revision 1.2 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XOSCAHINTLAX2 (O, I, IO, E, EB, S0, S1, FEB, E3V);
   input I, E, EB, FEB, S0, S1, E3V;
   inout IO;
   output O;

//Function Block
`protect
   //nand g1 (io_tmp,I,E);
   //bufif0 (weak1, weak0) g2 (IO,io_tmp,EB);
   //not g3 (eb_, EB);
   //or g4 (or_o, eb_, E);
   //and g5 (O, IO, or_o);
   
	not (eb_b, EB);
	not (e_b, E);
	not (i_b, I);
	and (ioc, E3V, eb_b);
	or  (ioi, i_b, e_b);

	bufif1 (IO, ioi, ioc);

	and (e3v_1, E3V, E);
	and (e3v_2, E3V, eb_b);
	or  (o_1, e3v_1, e3v_2);
	and (O, IO, o_1);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (S0 == 0 && S1 == 0) (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 0) (E *> IO) = (1.00, 1.00);
      if (S0 == 0 && S1 == 1) (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (E *> IO) = (1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 0) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 1 && S1 == 0) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 1) (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (EB *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (S0 == 0 && S1 == 1) (I *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 1) (I *> IO) = (1.00, 1.00);
      if (S0 == 0 && S1 == 0) (I *> IO) = (1.00, 1.00);
      if (S0 == 1 && S1 == 0) (I *> IO) = (1.00, 1.00);
      ifnone (I *> IO) = (1.00, 1.00);
      //  Module Path Delay
      (E *> O) = (1.00, 1.00);
      (EB *> O) = (1.00, 1.00);
      (IO *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XTRNELAX1 (O, I, IE, PU, PD, SMT, E3V);
   output O;
   input I, IE, PU, PD, SMT, E3V;
   supply1 vcc;

//Function Block
`protect
   // Avoide MIPD
   buf b1 (SMT_,SMT);
`ifdef atpgmodel
   and g1 (O, I, IE);
`else
   nmos   g1(io1, I, vcc);
   not    g2(pub, PU);
   not    g3(pdb, PD);
   and    g4(pupd, PU, PD);
   and    g5(pu_pd_, pub, pdb);
   or     g6(pcon, pupd, pu_pd_);
   or     g7(pull_down1, pdb, PU);
   rpmos  g8(io1, pull_down1, pcon);
   and    g9(o_, io1, IE);
   and      (O, o_, E3V);
   //-- bus holder for "keep" function --//
   buf    g10 (z,io1);
   buf    g11 (H,z);
   rnmos  g12 (io1, H, pupd);
`endif

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (SMT == 0) (I *> O) = (1.00, 1.00);
      if (SMT == 1) (I *> O) = (1.00, 1.00);
      ifnone (I *> O) = (1.00, 1.00);
      if (SMT == 1) (IE *> O) = (1.00, 1.00);
      if (SMT == 0) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);

      //  Module Path Delay

   endspecify
`endprotect
endmodule
`endcelldefine


