   specify

      //  Module Path Delay (state dependent)
      if (E4 == 0 && E8 == 0 && SR == 0 && LS3V == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 0 && LS3V == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
