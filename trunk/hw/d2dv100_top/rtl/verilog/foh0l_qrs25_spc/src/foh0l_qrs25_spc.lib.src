      if (EA == 0 && EB == 0 && EC == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 0 && EC == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
