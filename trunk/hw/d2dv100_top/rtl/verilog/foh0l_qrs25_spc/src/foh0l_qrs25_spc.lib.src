//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module ZTRNE9ISLFX180 (O, I, IO, E, E4, E8, SR, IE, PU, PD, SMT);
   output O;
   input I, E, E4, E8, SR, IE, PU, PD, SMT;
   inout IO;

//Function Block
`protect
   // Avoide MIPD
   buf b1 (E4_,E4);
   buf b2 (E8_,E8);
   buf b3 (SR_,SR);
   buf b4 (SMT_,SMT);

   pullup_down_keep_IO_IE g1 (IO, I, E, IE, PU, PD);
   and    g2(O, IO, IE);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (E4 == 0 && E8 == 0 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 0 && E8 == 0 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 1) (I *> IO) = (1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 0) (I *> IO) = (1.00, 1.00);
      if (E == 0) (I *> IO) = (0:0:0, 0:0:0);
      ifnone (I *> IO) = (1.00, 1.00);
      if (SMT == 0) (IE *> O) = (1.00, 1.00);
      if (SMT == 1) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);
      if (SMT == 1) (IO *> O) = (1.00, 1.00);
      if (SMT == 0) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 0 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 0 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 1 && E8 == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 0 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (E4 == 0 && E8 == 1 && SR == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);

      //  Module Path Delay (state dependent)

      //  Module Path Delay
      if (E == 0) (PU *> IO) = (0.0:0.0:0.0);
      ifnone (PU *> IO) = (0.0:0.0:0.0);
      if (E == 0) (PD *> IO) = (0.0:0.0:0.0);
      ifnone (PD *> IO) = (0.0:0.0:0.0);
   endspecify
`endprotect
endmodule
`endcelldefine




