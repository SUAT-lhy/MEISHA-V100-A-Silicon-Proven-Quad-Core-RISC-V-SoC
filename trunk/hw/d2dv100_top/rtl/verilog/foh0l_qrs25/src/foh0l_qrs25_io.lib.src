//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WRPBIASLI (O, IO, E, E18V, S1, S2, S3);
  output O;
  input E, E18V; 
  inout IO;  
  input S1, S2, S3; 
    
//Function Block
`protect
  and    g1 (E_and1, E, E18V);
  `ifdef refen
    bufif1 g2 (IO, 1'b1, E_and1);
    buf    g3 (O, IO);
  `else
    bufif1 g2 (IO, 1'bx, E_and1);
    bufif1 g3 (O, 1'bx, E_and1);
  `endif
  
  //assign O = IO;
           
//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (E == 0 && E18V == 0) (IO *> O) = (1.00, 1.00);
      if (E == 1 && E18V == 0) (IO *> O) = (1.00, 1.00);
      if (E == 0 && E18V == 1) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
      //  Module Path Delay    
    endspecify
`endprotect
endmodule
`endcelldefine      
`resetall
`timescale 10ps/1ps
`celldefine
module WYCSSTL2DLO (O, I, IO, IOB, E, EA, EB, SIO, IE, CMOSIN, SMT, REF, E2V);
  output O;
  input I, E, EA, EB, SIO, IE, CMOSIN, SMT, REF, E2V;
  inout IO, IOB;  
    
//Function Block
`protect
  and (ie_and, IE, E2V);

  and (i1, E, E2V, I);

  and (e2v_and, ~E, ~E2V);
  or  (e2, E, e2v_and);

  bufif1 (IO, i1, e2);

  and (i2, I, E2V);
  and (a1, ~SIO, E);
  and (a2, SIO, ~E2V);
  and (a3, ~E, ~E2V, ~SIO);
  or  (e3, a1, a2, a3);

  notif1 (IOB, i2, e3);

  xor (io_xor, IO, IOB);
  or  (sio_or, SIO, CMOSIN);
  or  (b1, io_xor, sio_or);

  bufif1 (io_t, IO, b1);

  and (O, io_t, ie_and);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (EA == 0 && EB == 0 && SIO == 1) (I *> IO) = (1.00, 1.00);
      if (EA == 0 && EB == 1 && SIO == 0) (I *> IO) = (1.00, 1.00);
      if (EA == 1 && EB == 0 && SIO == 1) (I *> IO) = (1.00, 1.00);
      if (EA == 1 && EB == 1 && SIO == 0) (I *> IO) = (1.00, 1.00);
      if (EA == 0 && EB == 0 && SIO == 0) (I *> IO) = (1.00, 1.00);
      if (EA == 1 && EB == 0 && SIO == 0) (I *> IO) = (1.00, 1.00);
      if (EA == 0 && EB == 1 && SIO == 1) (I *> IO) = (1.00, 1.00);
      if (EA == 1 && EB == 1 && SIO == 1) (I *> IO) = (1.00, 1.00);
      if (E == 0) (I *> IO) = (0:0:0, 0:0:0);
      ifnone (I *> IO) = (1.00, 1.00);
      if (EA == 0 && EB == 1 && SIO == 0) (I *> IOB) = (1.00, 1.00);
      if (EA == 1 && EB == 1 && SIO == 0) (I *> IOB) = (1.00, 1.00);
      if (EA == 0 && EB == 0 && SIO == 0) (I *> IOB) = (1.00, 1.00);
      if (EA == 1 && EB == 0 && SIO == 0) (I *> IOB) = (1.00, 1.00);
      if (E == 0) (I *> IOB) = (0:0:0, 0:0:0);
      ifnone (I *> IOB) = (1.00, 1.00);
      if (EA == 0 && EB == 0) (SIO *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 0) (SIO *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 1) (SIO *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 1) (SIO *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (SIO *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (SIO == 0 && CMOSIN == 0) (IE *> O) = (1.00, 1.00);
      if (SIO == 1 && CMOSIN == 0) (IE *> O) = (1.00, 1.00);
      if (SIO == 1 && CMOSIN == 1 && SMT == 0) (IE *> O) = (1.00, 1.00);
      if (SIO == 1 && CMOSIN == 1 && SMT == 1) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);
      if (SIO == 1 && CMOSIN == 1 && SMT == 1) (IO *> O) = (1.00, 1.00);
      if (SIO == 0 && CMOSIN == 0) (IO *> O) = (1.00, 1.00);
      if (SIO == 1 && CMOSIN == 0) (IO *> O) = (1.00, 1.00);
      if (SIO == 1 && CMOSIN == 1 && SMT == 0) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
      if (EA == 0 && EB == 0 && SIO == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 0 && SIO == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 1 && SIO == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 1 && SIO == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 1 && SIO == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 0 && SIO == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 1 && SIO == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 0 && SIO == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 0 && SIO == 0) (E *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 0 && SIO == 0) (E *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 1 && SIO == 0) (E *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 1 && SIO == 0) (E *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IOB) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
   //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine
`resetall
`timescale 10ps/1ps
`celldefine
module WYCSSTL2LO (O, I, IO, E, EA, EB, IE, CMOSIN, SMT, REF, E2V);
  output O;
  input I, E, EA, EB, IE, CMOSIN, SMT, REF, E2V;
  inout IO;  
    
//Function Block
`protect
  and (ie_and, IE, E2V);

  and (i1, E, E2V, I);

  and (e2v_and, ~E, ~E2V);
  or  (e2, E, e2v_and);

  bufif1 (IO, i1, e2);

  and (O, IO, ie_and);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (EA == 1 && EB == 1) (I *> IO) = (1.00, 1.00);
      if (EA == 0 && EB == 0) (I *> IO) = (1.00, 1.00);
      if (EA == 1 && EB == 0) (I *> IO) = (1.00, 1.00);
      if (EA == 0 && EB == 1) (I *> IO) = (1.00, 1.00);
      if (E == 0) (I *> IO) = (0:0:0, 0:0:0);
      ifnone (I *> IO) = (1.00, 1.00);
      if (CMOSIN == 1 && SMT == 1) (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 0) (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && SMT == 0) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 0) (IO *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && SMT == 0) (IO *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && SMT == 1) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
      if (EA == 0 && EB == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 0 && EB == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (EA == 1 && EB == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
   //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine
//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WYPBIASLO (O, IO, E, E2V, S1, S2, S3);
  output O;
  input E, E2V; 
  inout IO;  
  input S1, S2, S3; 
    
//Function Block
`protect
  and    g1 (E_and1, E, E2V);
  bufif1 g2 (IO, 1'b1, E_and1);
  buf    g3 (O, IO);
           
//Specify Block
   specify
      //  Module Path Delay
      (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (E2V *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (E *> O) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (E2V *> O) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (IO *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine      
//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XAOTGA (O, I, S1, S2);
   output O;
   input I, S1, S2;
   supply1 vcc;

//Function Block
`protect
`ifdef atpgmodel
   buf g1 (O,I);
`else
   nmos   g1(io1, I, vcc);
   nand   g2(pull_up_, S1, S2);
   rnmos  g3(io1, vcc, pull_up_);
   buf    g4(O,io1);
`endif

//Specify Block
   specify

      //  Module Path Delay
      (I *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XFNLA (O, I, IE, PU, PD, SMT);
   output O;
   input I, IE, PU, PD, SMT;
   supply1 vcc;

//Function Block
`protect
   // Avoide MIPD
   buf b1 (SMT_,SMT);
`ifdef atpgmodel
   and g1 (O, I, IE);
`else
   nmos   g1(io1, I, vcc);
   not    g2(pub, PU);
   not    g3(pdb, PD);
   and    g4(pupd, PU, PD);
   and    g5(pu_pd_, pub, pdb);
   or     g6(pcon, pupd, pu_pd_);
   or     g7(pull_down1, pdb, PU);
   rpmos  g8(io1, pull_down1, pcon);
