`celldefine
module WOSSTLECLK (O, I, IO, E , NLEG5, NLEG4, NLEG3, NLEG2, NLEG1, NLEG0, PLEG5, PLEG4, PLEG3, PLEG2, PLEG1, PLEG0, REF ,IE , ODTEN ,ODTMD0 , ODTMD1 ,ODTMD2 , RONMD0, RONMD1, RONMD2, D15V, MDDR1 ,E3V);
  output O;
  input I, E, NLEG5, NLEG4, NLEG3, NLEG2, NLEG1, NLEG0, PLEG5, PLEG4, PLEG3, PLEG2, PLEG1, PLEG0, REF ,IE , ODTEN ,ODTMD0 , ODTMD1 ,ODTMD2 , RONMD0 ,RONMD1, RONMD2, D15V, MDDR1 ,E3V; 
  inout IO;  
    
//Function Block
`protect
  buf b1 (NLEG5_, NLEG5); 
  buf b2 (NLEG4_, NLEG4);
  buf b3 (NLEG3_, NLEG3);
  buf b4 (NLEG2_, NLEG2);
  buf b5 (NLEG1_, NLEG1);
  buf b6 (NLEG0_, NLEG0);   
  buf b7 (PLEG5_, PLEG5);
  buf b8 (PLEG4_, PLEG4);
  buf b9 (PLEG3_, PLEG3);
  buf b10 (PLEG2_, PLEG2);
  buf b11 (PLEG1_, PLEG1);
  buf b12 (PLEG0_, PLEG0);
  buf b13 (REF_, REF);  
  buf b14 (RONMD0_, RONMD0);
  buf b15 (RONMD1_, RONMD1);
  buf b16 (RONMD2_, RONMD2);
  buf b17 (ODTEN_, ODTEN);
  buf b18 (ODTMD0_, ODTMD0);
  buf b19 (ODTMD1_, ODTMD1);
  buf b20 (ODTMD2_, ODTMD2);
  buf b21 (D15V_, D15V);

  /* -----  output mode ----- */
  and 	 g1 (end_0, E, E3V);
  bufif1 g2 (IO, I, end_0); 
  
  /* ----- receive mode ----- */         
  and	 g3 (end_1, IE, E3V);

  `ifdef refen
     and g4 (tmp_o, IO, end_1);
     mux2_udp g5(O, 1'bx, tmp_o, REF);
  `else
     and g4 (O, IO, end_1);
  `endif
            
//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 0 && RONMD2 == 0) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 1 && RONMD2 == 0) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 1) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 1 && RONMD2 == 1) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 0 && RONMD2 == 1) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 0) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 1 && RONMD2 == 1) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 1 && RONMD2 == 0) (I *> IO) = (1.00, 1.00);
      if (E == 0) (I *> IO) = (0:0:0, 0:0:0);
      ifnone (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 1 && RONMD2 == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 0 && RONMD2 == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 1 && RONMD2 == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 1 && RONMD2 == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 0 && RONMD2 == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 0 && RONMD1 == 1 && RONMD2 == 0) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 0 && PLEG2 == 1 && PLEG1 == 0 && PLEG0 == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 1) (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      ifnone (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
   //  Module Path Delay
      (IE *> O) = (1.00, 1.00);
      (IO *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine
//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WROF40ODT4DLI (O, I, IO, IOB, E, NLEG3, NLEG2, NLEG1, NLEG0, PLEG3, PLEG2, PLEG1, PLEG0, SIO, REF, IE, ODTEN, ODTMD1, ODTMD0, RONMD2, RONMD1, RONMD0, CMOSIN, E18V, PU, PD, LS12V);
  output O;
  input I, E, NLEG3, NLEG2, NLEG1, NLEG0, PLEG3, PLEG2, PLEG1, PLEG0, SIO ,REF ,IE ,ODTEN , ODTMD0, ODTMD1 , RONMD0, RONMD1, RONMD2, CMOSIN, E18V, PU, PD, LS12V;
  inout IO, IOB;

//Function Block
`protect

  buf b1 (NLEG3_, NLEG3);
  buf b2 (NLEG2_, NLEG2);
  buf b3 (NLEG1_, NLEG1);
  buf b4 (NLEG0_, NLEG0);
  buf b5 (PLEG3_, PLEG3);
  buf b6 (PLEG2_, PLEG2);
  buf b7 (PLEG1_, PLEG1);
  buf b8 (PLEG0_, PLEG0);
  buf b9 (REF_, REF);
  buf b10 (RONMD0_, RONMD0);
  buf b11 (RONMD1_, RONMD1);
  buf b12 (RONMD2_, RONMD2);
  buf b13 (ODTEN_, ODTEN);
  buf b14 (ODTMD0_, ODTMD0);
  buf b15 (ODTMD1_, ODTMD1);

  nor g1 (E_and, ~E, ~E18V);
  not g2 (E_and_b, E_and);
  // ----- pu & pd control pin -----
  and    g3 (pu_pd_and, PU, PD);
  not    g4 (cmosin_bar, CMOSIN);
  and    g5 (io_pd_ctrl, pu_pd_and, cmosin_bar);
  and    g6 (pu_tmp, ~IE, CMOSIN);
  or     g7 (pu_tmp2, pu_tmp, cmosin_bar);
  and    g8 (io_pu_ctrl, pu_tmp2, pu_pd_and);
  mux2_udp g9 (io_pu_sel_tmp, PU, 1'b0, io_pu_ctrl);  //----- io_pu_ctrl = 1, PU function invalid(for IO)
  mux2_udp g10 (io_pd_sel_tmp, PD, 1'b0, io_pd_ctrl); //----- io_pu_ctrl = 1, PD function invalid(for IO)
  or     g9x (io_pu_sel, io_pu_sel_tmp, ~E18V);
  and    g10x (io_pd_sel, io_pd_sel_tmp, E18V);
  pullup_down_keep_IO g11 (IO_tmp, I, E_and, io_pu_sel, io_pd_sel);
  not   gne (E_bar, E);
  and   godt (odtsel, E_bar, E18V, ODTEN);
  not   godtn (odtsel_bar, odtsel);
  nmos gio (IO,IO_tmp,odtsel_bar);

  and    g12 (iob_ctrl, pu_pd_and, CMOSIN);
  mux2_udp g13 (iob_pd_sel_tmp, PU, 1'b0, iob_ctrl);  //----- iob_ctrl = 1, PU function invalid(for IOB)
  mux2_udp g14 (iob_pu_sel_tmp, PD, 1'b0, iob_ctrl);  //----- iob_ctrl = 1, PD function invalid(for IOB)
  or     g13x (iob_pd_sel, iob_pd_sel_tmp, ~E18V);
  and    g14x (iob_pu_sel, iob_pu_sel_tmp, E18V);

  and    g17 (IE_and, IE, E18V);   
  pullup_down_IO g18 (iob_tmp, ~I, E_and, iob_pu_sel, iob_pd_sel); 
  nmos giob0 (IOB_pre,iob_tmp,odtsel_bar);
  and g21 (sio_ctrl1, E18V, E, SIO);
  pmos giob (IOB, IOB_pre, sio_ctrl1);

  `ifdef refen
     and g19 (tmp_o, IE_and, IO);
     mux2_udp g20(oo, 1'bx, tmp_o, REF);
  `else
     xnor g24 (o_ctrl_pre, IO, IOB);
     and g25 (o_ctrl, IE_and, o_ctrl_pre, ~SIO, ~CMOSIN);
     and g19 (o_tmp, IE_and, IO);
     mux2_udp (oo, o_tmp, 1'bx, o_ctrl);
  `endif

   //---- fool proofing for IO or IOB is unknown----
   xor (ioxiob, IO, IOB);
	or (sw, ioxiob, SIO);
