//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module VCCSD3PWLC (VCC3OUT, E, ESD33, VCC18IN, VCC3IN);
   input E, ESD33;
   output VCC3OUT;
   input VCC18IN, VCC3IN;

//Function Block
`protect
   and g1(ctrl1, VCC18IN, VCC3IN);
   not g2(E_, E);
   mux2_udp g3(tmp_o, 1'bx, E, ctrl1);
   and g4(ctrl2, ctrl1, E_);
   bufif0 g5(VCC3OUT, tmp_o, ctrl2);

   always @ (VCC3IN or VCC18IN or ESD33) begin
      if  (VCC18IN === 1'b0 || VCC3IN === 1'b0) $display($time, " ****Warning! %m not allow this condition");
      if  (ESD33 === 1'b0) $display($time, " ****Warning! %m VCC3OUT voltage from VCC18IN");
      if  (ESD33 === 1'b1) $display($time, " ****Warning! %m VCC3OUT voltage from VCC3IN");
   end
//Specify Block
   specify
      //  Module Path Delay
      (E *> VCC3OUT) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (VCC3IN *> VCC3OUT) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WOPBIASLK (O, IO, E, E18V, S1, S2, S3);
  output O;
  input E, E18V; 
  inout IO;  
  input S1, S2, S3; 
    
//Function Block
`protect
  and    g1 (E_and1, E, E18V);
  `ifdef refen
     bufif1 g2 (IO, 1'b1, E_and1);
     buf    g3 (O, IO);
  `else
     bufif1 g2 (IO, 1'bx, E_and1);
     bufif1 g3 (O, 1'bx, E_and1);
  `endif  
  //assign O = IO;
           
//Specify Block
   specify
      //  Module Path Delay
      (E *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (E18V *> IO) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (E *> O) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (E18V *> O) = (1.00, 1.00, 1.00, 1.00, 1.00, 1.00);
      (IO *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine      
//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module WOSSTLECDLK (O, I, IO, IOB, E, NLEG5, NLEG4, NLEG3, NLEG2, NLEG1, NLEG0, PLEG5, PLEG4, PLEG3, PLEG2, PLEG1, PLEG0, SIO, REF, IE, ODTEN, ODTMD0, ODTMD1, ODTMD2, RONMD0, RONMD1, RONMD2, D15V, MDDR1, E3V);
  output O;
  input I, E, NLEG5, NLEG4, NLEG3, NLEG2, NLEG1, NLEG0, PLEG5, PLEG4, PLEG3, PLEG2, PLEG1, PLEG0, SIO ,REF ,IE ,ODTEN ,ODTMD0 , ODTMD1 ,ODTMD2 , RONMD0 , RONMD1, RONMD2, D15V, MDDR1, E3V;
  inout IO, IOB;

//Function Block
`protect
  buf b1 (NLEG5_, NLEG5);
  buf b2 (NLEG4_, NLEG4);
  buf b3 (NLEG3_, NLEG3);
  buf b4 (NLEG2_, NLEG2);
  buf b5 (NLEG1_, NLEG1);
  buf b6 (NLEG0_, NLEG0);
  buf b7 (PLEG5_, PLEG5);
  buf b8 (PLEG4_, PLEG4);
  buf b9 (PLEG3_, PLEG3);
  buf b10 (PLEG2_, PLEG2);
  buf b11 (PLEG1_, PLEG1);
  buf b12 (PLEG0_, PLEG0);
  buf b13 (REF_, REF);
  buf b14 (RONMD0_, RONMD0);
  buf b15 (RONMD1_, RONMD1);
  buf b16 (RONMD2_, RONMD2);
  buf b17 (ODTEN_, ODTEN);
  buf b18 (ODTMD0_, ODTMD0);
  buf b19 (ODTMD1_, ODTMD1);
  buf b20 (ODTMD2_, ODTMD2);
  buf b21 (D15V_, D15V);

  and    g1 (E_and, E, E3V);
  not    g2 (E_and_b, E_and);
  bufif1 g3 (IO, I, E_and);

  or     g4 (O3, SIO, E_and_b);
  notif0 g5 (IOB, I, O3);

  and    g6 (IE_and, IE, E3V);

  `ifdef refen
     and g7 (tmp_o, IE_and, IO);
     mux2_udp g8(oo, 1'bx, tmp_o, REF);
  `else
     and g7 (oo, IE_and, IO);
  `endif

   xor (ioxiob, IO, IOB);
	or (OR, MDDR1, SIO);
	or (sw, ioxiob, OR);
	nmos (O, oo, sw);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 1 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 1 && PLEG2 == 0 && PLEG1 == 0 && PLEG0 == 1 && SIO == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 0) (I *> IO) = (1.00, 1.00);
      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 1 && NLEG2 == 1 && NLEG1 == 0 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 1 && PLEG2 == 1 && PLEG1 == 1 && PLEG0 == 0 && SIO == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 0) (I *> IO) = (1.00, 1.00);
