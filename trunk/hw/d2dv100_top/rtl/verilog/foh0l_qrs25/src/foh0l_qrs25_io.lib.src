`resetall
`timescale 10ps/1ps
`celldefine
module WROF40ODT4LI (O, I, IO, E, NLEG3, NLEG2, NLEG1, NLEG0, PLEG3, PLEG2, PLEG1, PLEG0, REF, IE, ODTEN, ODTMD1, ODTMD0, RONMD2, RONMD1, RONMD0, CMOSIN, E18V, PU, PD, LS12V);
  output O;
  input I, E, NLEG3, NLEG2, NLEG1, NLEG0, PLEG3, PLEG2, PLEG1, PLEG0, REF, IE, ODTEN, ODTMD1, ODTMD0, RONMD2, RONMD1, RONMD0, CMOSIN, E18V, PU, PD, LS12V; 
  inout IO;  
    
//Function Block
`protect
  buf b1 (NLEG3_, NLEG3);
  buf b2 (NLEG2_, NLEG2);
  buf b3 (NLEG1_, NLEG1);
  buf b4 (NLEG0_, NLEG0);   
  buf b5 (PLEG3_, PLEG3);
  buf b6 (PLEG2_, PLEG2);
  buf b7 (PLEG1_, PLEG1);
  buf b8 (PLEG0_, PLEG0);
  buf b9 (REF_, REF);  
  buf b10 (RONMD0_, RONMD0);
  buf b11 (RONMD1_, RONMD1);
  buf b12 (RONMD2_, RONMD2);
  buf b13 (ODTEN_, ODTEN);
  buf b14 (ODTMD0_, ODTMD0);
  buf b15 (ODTMD1_, ODTMD1);

  nor g1 (end_0, ~E, ~E18V);
  // ----- pu & pd control pin -----
  and    g2 (pu_pd_and, PU, PD);
  not    g3 (cmosin_bar, CMOSIN);
  and    g4 (pd_ctrl, pu_pd_and, cmosin_bar);
  and    g5 (pu_tmp, ~IE, CMOSIN);
  or     g6 (pu_tmp2, pu_tmp, cmosin_bar);
  and    g7 (pu_ctrl, pu_tmp2, pu_pd_and);
  mux2_udp g8 (pu_sel_tmp, PU, 1'b0, pu_ctrl); //----- pu_ctrl = 1, PU function invalid.
  mux2_udp g9 (pd_sel_tmp, PD, 1'b0, pd_ctrl); //----- pd_ctrl = 1, PD function invalid.
  or     g9x (pu_sel, pu_sel_tmp, ~E18V);
  and    g91 (pd_sel, pd_sel_tmp, E18V);
  // -------------------------------
  pullup_down_keep_IO g10 (IO_tmp, I, end_0, pu_sel, pd_sel);        
  // -------------------------------
  not   gne (E_bar, E);
  and   godt (odtsel, E_bar, E18V, ODTEN);
  not   godtn (odtsel_bar, odtsel);
  nmos gio (IO,IO_tmp,odtsel_bar);
  and	 g11 (end_1, IE, E18V);

  `ifdef refen
     and g12 (tmp_o, IO, end_1);
     mux2_udp g13(O, 1'bx, tmp_o, REF);
  `else
     and g12 (O, IO, end_1);
  `endif
   
   always @ (NLEG3 or NLEG2 or NLEG1 or NLEG0 or PLEG3 or PLEG2 or PLEG1 or PLEG0 or I or E or REF or IE or ODTEN or CMOSIN or E18V or PU or PD) begin
      if ((NLEG3 == 1'b0 && NLEG2 == 1'b0 && NLEG1 == 1'b0 && NLEG0 == 1'b0) || (PLEG3 == 1'b0 && PLEG2 == 1'b0 && PLEG1 == 1'b0 && PLEG0 == 1'b0)) 
       begin
       $display($time, " ***** Error! %m NLEG[3:0]= 0000 or PLEG[3:0]= 0000 are forbidden\!\!");
       $finish;
       end
   end

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (CMOSIN == 0 && LS12V == 0) (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && LS12V == 1) (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 0 && LS12V == 1) (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && LS12V == 0) (IE *> O) = (1.00, 1.00);
      ifnone (IE *> O) = (1.00, 1.00);
      if (CMOSIN == 0 && LS12V == 0) (IO *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && LS12V == 1) (IO *> O) = (1.00, 1.00);
      if (CMOSIN == 0 && LS12V == 1) (IO *> O) = (1.00, 1.00);
      if (CMOSIN == 1 && LS12V == 0) (IO *> O) = (1.00, 1.00);
      ifnone (IO *> O) = (1.00, 1.00);
