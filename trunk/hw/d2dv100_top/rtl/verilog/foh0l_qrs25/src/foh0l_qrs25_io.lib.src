`timescale 10ps / 1ps

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module PDRETLP (ORETEN, DI);
   output ORETEN;
   input DI;

//Function Block
`protect
   buf g1(ORETEN, DI);

//Specify Block
   specify
      //  Module Path Delay
     (DI *> ORETEN) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


