      if (NLEG5 == 0 && NLEG4 == 1 && NLEG3 == 0 && NLEG2 == 1 && NLEG1 == 1 && NLEG0 == 0 && PLEG5 == 0 && PLEG4 == 1 && PLEG3 == 1 && PLEG2 == 0 && PLEG1 == 0 && PLEG0 == 1 && SIO == 1 && RONMD0 == 1 && RONMD1 == 0 && RONMD2 == 1) (I *> IO) = (1.00, 1.00);
