   assign ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_TD = CK & !D & !SEL & TD;
   assign ENABLE_CK_AND_NOT_D_AND_SEL_AND_NOT_TD = CK & !D & SEL & !TD;
   assign ENABLE_CK_AND_NOT_D_AND_SEL_AND_TD = CK & !D & SEL & TD;
   assign ENABLE_D_AND_NOT_SEL_AND_NOT_TD = D & !SEL & !TD;
   assign ENABLE_D_AND_NOT_SEL_AND_TD = D & !SEL & TD;
   assign ENABLE_D_AND_SEL_AND_NOT_TD = D & SEL & !TD;
   assign ENABLE_D_AND_SEL_AND_TD = D & SEL & TD;
   assign ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD = !CK & D & !SEL & !TD;
   assign ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD = !CK & D & !SEL & TD;
   assign ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD = !CK & D & SEL & !TD;
   assign ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD = !CK & D & SEL & TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD = !CK & !D & !SEL & !TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD = !CK & !D & !SEL & TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD = !CK & !D & SEL & !TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD = !CK & !D & SEL & TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD = !D & !SEL & !TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_TD = !D & !SEL & TD;
   assign ENABLE_NOT_D_AND_SEL_AND_NOT_TD = !D & SEL & !TD;
   assign ENABLE_NOT_D_AND_SEL_AND_TD = !D & SEL & TD;
   assign ENABLE_SB_AND_NOT_SEL_AND_TD = SB & !SEL & TD;
   assign ENABLE_SB_AND_NOT_SEL_AND_NOT_TD = SB & !SEL & !TD;
   assign ENABLE_NOT_D_AND_SB_AND_TD = !D & SB & TD;
   assign ENABLE_D_AND_SB_AND_NOT_TD = D & SB & !TD;
   assign ENABLE_NOT_D_AND_SB_AND_SEL = !D & SB & SEL;
   assign ENABLE_D_AND_SB_AND_SEL = D & SB & SEL;

//Function Block
`protect
   buf (SEL_, d_SEL );  //Avoid MIPD.

	mux2_udp m1 (d1,  d_D,  d_TD,  SEL_ );
   dffrsb_udp q1 (qt_1,  d1,   d_CK,  vcc,  SB,  flag );
   dffrsb_udp q2 (qt_2,  qt_1, d_CK,  vcc,  SB,  flag );
   dffrsb_udp q3 (qt_3,  qt_2, d_CK,  vcc,  SB,  flag );

	buf (Q, qt_3);

//Append pseudo gate for timing violation checking
	assign D_flag1 = D_flag;
	always @(SEL_ or d_D or d_TD) begin
		if (SEL_ === 1'b0)
			D_flag = d_D;
		else
      	D_flag = d_TD;
	end

//Specify Block
   specify

      //  Module Path Delay (state dependent)
     `ifdef allzero
              if (D == 0 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 0 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 0 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 0 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              ifnone (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              ifnone (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
      if (CK == 1 && D == 1 && SEL == 1 && TD == 1) (negedge SB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 0 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 0 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 0 && SEL == 1 && TD == 0) (negedge SB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (0.0, 0.0);
