`resetall
`timescale 10ps/1ps
`celldefine
module QDFZESSLHLMX4 (Q, D, TD, CK, SEL, EB);

  output Q;
  input D, TD, CK, SEL, EB;
  reg  D_flag1;
  wire D_flag;
  reg flag; // Notifier flag
  supply1 vcc;

   wire d_CK, d_D, d_EB, d_SEL, d_TD;

//Function Block
`protect
  buf b3 (SEL_, d_SEL );  //Avoid MIPD.
  buf b4 (EB_, d_EB );    //Avoid MIPD.
 
  mux2_udp g1(qt_i1,  d_D,  qt,  EB_ );
  mux2_udp g2(qt_i,  qt_i1,  d_TD,  SEL_ );
  dffrsb_udp g3(qt,  qt_i,  d_CK,  vcc,  vcc,  flag );  
  buf g4(Q, qt);

// Define the flag for timing check
  assign D_flag = D_flag1;      // For Model-Tec complier
  always @(EB_ or SEL_)
    begin
      if ((EB_ === 1'b0) && (SEL_ === 1'b0))
         D_flag1 = 1'b1;
      else
         D_flag1 = 1'b0;
    end

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_EB_CK = 0.0;
      specparam hold_EB_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK, posedge D &&& D_flag, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D &&& D_flag, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, posedge EB &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_EB);
      $setuphold(posedge CK, negedge EB &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_EB);
      $setuphold(posedge CK, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect

endmodule
`endcelldefine
