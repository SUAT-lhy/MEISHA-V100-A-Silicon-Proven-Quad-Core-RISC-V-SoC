	wire ENABLE_NOT_D1_AND_D2_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL;
	wire ENABLE_NOT_D1_AND_SEL_AND_TD, ENABLE_RB_AND_NOT_SEL, SEL__bar;
	wire TD__bar;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
