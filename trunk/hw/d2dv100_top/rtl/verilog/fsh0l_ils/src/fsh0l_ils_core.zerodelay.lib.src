      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_TD, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_TD, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 0.0, 0.0, flag,,,d_CK, d_D1);
