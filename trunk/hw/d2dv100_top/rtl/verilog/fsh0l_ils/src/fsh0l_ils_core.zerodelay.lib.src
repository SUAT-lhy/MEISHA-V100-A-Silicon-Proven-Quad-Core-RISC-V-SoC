      if (CK == 1 && D == 0 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 0 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      ifnone (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      //  Module Path Delay


      //  Setup and Hold Time
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_TD,     posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_TD,     negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_NOT_TD, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_NOT_TD, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_TD,       posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_TD,       negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_NOT_TD,       posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_NOT_TD,       negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_SEL,      posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_SEL,      negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_SEL,          posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_SEL,          negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Recovery Time
      $recrem (posedge RB, posedge CK &&& ENABLE_D_AND_SEL_AND_TD, 0.0, 0.0, flag);
      $recrem (posedge RB, posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0.0, flag);
      $recrem (posedge RB, posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 0.0, 0.0, flag);
      $recrem (posedge RB, posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      $width (negedge RB, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD, 0.0, 0, flag);
