module QDSFZRBLHLMX0P7 (Q, D, TD, CK, SEL, RB, SL);
  output Q;
  input D, TD, CK, SEL, RB, SL;
  reg flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_TD, d_SL, d_SEL;
  wire on1, on2, on3, om1, ona1, oa2;

//Function Block
`protect

   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_RB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   mux2_udp m1 (om1,  d_D,  d_TD, SEL_ );
    
   nand a1 (ona1, on1, on2);
   and a2 (oa2, d_RB, on2, d_CK); 
   dlhrsb_udp dlh1 (odlh1, om1, on3, d_RB, vcc, flag ); 
   dlhrsb_udp dlh2 (qt, odlh1, oa2, ona1, vcc, flag ); 
   buf (Q, qt);

	wire ENABLE_RB_NOT_SEL_NOT_SL;
	wire ENABLE_RB_SEL_NOT_SL;
	wire ENABLE_RB_NOT_SL;

	not (SL_b, SL);
	not (SEL_b, SEL);
	and (ENABLE_RB_NOT_SEL_NOT_SL, RB, SEL_b, SL_b);
	and (ENABLE_RB_SEL_NOT_SL, RB, SEL, SL_b);
	and (ENABLE_RB_NOT_SL, RB, SL_b);

//Specify Block
  specify
     `ifdef allzero
           (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
           (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
   (negedge RB *> (Q :1'bx)) = (0.0, 0.0);
//  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_CK_SL = 0.0;
      specparam hold_CK_SL = 0.0;
      specparam setup_RB_SL = 0.0;
      specparam hold_RB_SL = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SEL_NOT_SL, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SEL_NOT_SL, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SL, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_NOT_SL, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_SEL_NOT_SL, posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_RB_SEL_NOT_SL, negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge SL, posedge CK &&& RB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& RB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
       
      $setuphold(negedge SL, posedge CK &&& RB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& RB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ~SL, posedge CK, 0.0, 0.0, flag);
      $recrem(negedge SL, negedge CK, 0.0, 0.0, flag);
      $recrem(posedge SL, posedge CK, 0.0, 0.0, flag);



      //  Minimum Pulse Width
