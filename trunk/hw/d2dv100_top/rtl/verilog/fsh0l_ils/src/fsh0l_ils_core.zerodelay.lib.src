`protect
   table
//    CK    SB  FLAG :   Qt : Qt+1
       r     1     ? :     0 :     1;// Toggle condition.
       r     1     ? :     1 :     0;
       r     x     ? :     0 :     1;
    (?0)     1     ? :     ? :     -;

     // deal with clk "x"
       b  (?1)     ? :     ? :     -;

       ?     0     ? :     ? :     1;
       ?     ?     * :     ? :     x;
   endtable
`endprotect
endprimitive
