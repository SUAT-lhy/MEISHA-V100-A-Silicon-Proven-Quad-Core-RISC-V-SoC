`celldefine
module MGXNR2LHLMX1 (O, I1, I2);
   output O;
   input I1, I2;

//Function Block
`protect
   xnor g1(O, I1, I2);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (I2 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge  I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge  I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge  I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge  I2 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


