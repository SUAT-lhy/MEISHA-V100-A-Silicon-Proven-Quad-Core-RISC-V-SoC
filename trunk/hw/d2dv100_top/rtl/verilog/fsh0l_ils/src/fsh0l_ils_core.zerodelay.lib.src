   wire d_CK, d_D1, d_D2, d_D3, d_D4,d_TD, d_SEL;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   buf g9(Q3, qt3);
   buf g10(Q4, qt4);
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  vcc,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  vcc,  vcc,  flag3 );
   mux2_udp g5(data1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g6(data2,  d_D2,  qt1,  d_SEL );
   mux2_udp g11(data3,  d_D3,  qt2,  d_SEL );
   mux2_udp g12(data4,  d_D4,  qt3,  d_SEL );

	// Additional timing wires
	wire D1__bar, ENABLE_D1_AND_SEL, ENABLE_NOT_D1_AND_SEL;
	wire ENABLE_NOT_SEL;


	// Additional timing gates
	not (ENABLE_NOT_SEL, SEL);
	and (ENABLE_D1_AND_SEL, D1, SEL);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_SEL, D1__bar, SEL);

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge CK *> (Q3 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q3 :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge CK *> (Q4 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q4 :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      specparam setup_D3_CK = 0.0;
      specparam hold_D3_CK = 0.0;
      specparam setup_D4_CK = 0.0;
      specparam hold_D4_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D1 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D1 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D2 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D2 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D3 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D3 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D4 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D4 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_D1_AND_SEL, posedge TD &&& ENABLE_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SEL, negedge TD &&& ENABLE_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      $setuphold(posedge CK, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);

      //  Minimum Pulse Width
      specparam mpw_pos_CK = 0.0;
      specparam mpw_neg_CK = 0.0;
      $width(posedge CK, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


