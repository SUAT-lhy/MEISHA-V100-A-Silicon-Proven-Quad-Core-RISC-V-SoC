   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   buf g9(Q3, qt3);
   buf g10(Q4, qt4);
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  vcc,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  vcc,  vcc,  flag3 );
   mux2_udp g5(data1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g6(data2,  d_D2,  qt1,  d_SEL );
   mux2_udp g11(data3,  d_D3,  qt2,  d_SEL );
   mux2_udp g12(data4,  d_D4,  qt3,  d_SEL );

	// Additional timing wires
