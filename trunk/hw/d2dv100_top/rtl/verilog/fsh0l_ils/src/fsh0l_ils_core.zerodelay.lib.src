//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFFLHLMX1 (Q1, Q2, D1, D2, CK);
   reg flag, flag1; // Notifier flag
   output Q1, Q2;
   input D1, D2;
   input CK;
   supply1 vcc;

   wire d_CK, d_D1, d_D2;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  vcc,  vcc,  flag1 );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK, posedge D1, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, negedge D1, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, posedge D2, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK, negedge D2, 0.0, 0.0, flag1,,,d_CK, d_D2);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


