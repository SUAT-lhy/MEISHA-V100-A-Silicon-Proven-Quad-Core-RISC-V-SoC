`timescale 10ps/1ps

module SYN3QDFZRBNLHLMX1 (Q, D, TD, CK, SEL, RB);
   reg flag; // Notifier flag
   output Q;
   input D, CK, TD, RB, SEL;
   supply1 vcc;
   reg D_flag;
   wire D_flag1;
   wire d_CK, d_D, d_SEL, d_TD;
   wire ENABLE_CK_AND_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_CK_AND_D_AND_SEL_AND_TD;
   wire ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_CK_AND_NOT_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_CK_AND_NOT_D_AND_SEL_AND_TD;
   wire ENABLE_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_SEL_AND_TD;
   wire ENABLE_RB_AND_NOT_SEL_AND_TD;
   wire ENABLE_RB_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_RB_AND_TD;
   wire ENABLE_D_AND_RB_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_RB_AND_SEL;
   wire ENABLE_D_AND_RB_AND_SEL;

   assign ENABLE_CK_AND_D_AND_NOT_SEL_AND_NOT_TD = CK & D & !SEL & !TD;
   assign ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD = CK & D & !SEL & TD;
   assign ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD = CK & D & SEL & !TD;
   assign ENABLE_CK_AND_D_AND_SEL_AND_TD = CK & D & SEL & TD;
   assign ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD = CK & !D & !SEL & !TD;
   assign ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_TD = CK & !D & !SEL & TD;
   assign ENABLE_CK_AND_NOT_D_AND_SEL_AND_NOT_TD = CK & !D & SEL & !TD;
   assign ENABLE_CK_AND_NOT_D_AND_SEL_AND_TD = CK & !D & SEL & TD;
   assign ENABLE_D_AND_NOT_SEL_AND_NOT_TD = D & !SEL & !TD;
   assign ENABLE_D_AND_NOT_SEL_AND_TD = D & !SEL & TD;
   assign ENABLE_D_AND_SEL_AND_NOT_TD = D & SEL & !TD;
   assign ENABLE_D_AND_SEL_AND_TD = D & SEL & TD;
   assign ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD = !CK & D & !SEL & !TD;
   assign ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD = !CK & D & !SEL & TD;
   assign ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD = !CK & D & SEL & !TD;
   assign ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD = !CK & D & SEL & TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD = !CK & !D & !SEL & !TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD = !CK & !D & !SEL & TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD = !CK & !D & SEL & !TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD = !CK & !D & SEL & TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD = !D & !SEL & !TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_TD = !D & !SEL & TD;
   assign ENABLE_NOT_D_AND_SEL_AND_NOT_TD = !D & SEL & !TD;
   assign ENABLE_NOT_D_AND_SEL_AND_TD = !D & SEL & TD;
   assign ENABLE_RB_AND_NOT_SEL_AND_TD = RB & !SEL & TD;
   assign ENABLE_RB_AND_NOT_SEL_AND_NOT_TD = RB & !SEL & !TD;
   assign ENABLE_NOT_D_AND_RB_AND_TD = !D & RB & TD;
   assign ENABLE_D_AND_RB_AND_NOT_TD = D & RB & !TD;
   assign ENABLE_NOT_D_AND_RB_AND_SEL = !D & RB & SEL;
   assign ENABLE_D_AND_RB_AND_SEL = D & RB & SEL;

//Function Block
`protect
   buf (SEL_, d_SEL );  //Avoid MIPD.

   mux2_udp m1 (d1,  d_D,  d_TD,  SEL_ );
   dffrsb_udp q1 (qt_1,  d1,    d_CK,  RB,  vcc,  flag );
	dffrsb_udp q2 (qt_2,  qt_1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp q3 (qt_3,  qt_2,  d_CK,  RB,  vcc,  flag );

   buf (Q, qt_3);

//Append pseudo gate for timing violation checking
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D or d_TD) begin
      if (SEL_ === 1'b0) 
         D_flag = d_D;
      else
         D_flag = d_TD;
   end

//Specify Block
   specify

      //  Module Path Delay (state dependent)
     `ifdef allzero
              if (D == 0 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 0 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 0 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 0 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 0 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              if (D == 1 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              if (D == 1 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              ifnone (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              ifnone (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
      if (CK == 0 && D == 0 && SEL == 0 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 0 && SEL == 1 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 0 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 0 && SEL == 0 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 0 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 0 && SEL == 1 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 1 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 1 && TD == 1) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 0 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 0 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 0 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 0 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 0 && D == 1 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 0 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      if (CK == 1 && D == 1 && SEL == 1 && TD == 0) (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      ifnone (negedge RB *> (Q:1'bx)) = (0.0, 0.0);
      //  Module Path Delay


      //  Setup and Hold Time
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_TD,     posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_TD,     negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_NOT_TD, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_NOT_TD, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_TD,       posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_TD,       negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_NOT_TD,       posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_NOT_TD,       negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_SEL,      posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_RB_AND_SEL,      negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_SEL,          posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_D_AND_RB_AND_SEL,          negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Recovery Time
      $recrem (posedge RB, posedge CK &&& ENABLE_D_AND_SEL_AND_TD, 0.0, 0.0, flag);
      $recrem (posedge RB, posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0.0, flag);
      $recrem (posedge RB, posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 0.0, 0.0, flag);
      $recrem (posedge RB, posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      $width (negedge RB, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_NOT_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_NOT_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge RB &&& ENABLE_CK_AND_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);

      $width (negedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_SEL_AND_TD, 0.0, 0, flag);
      
      $width (posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_SEL_AND_TD, 0.0, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 0.0, 0, flag);
   endspecify
`endprotect
endmodule


