      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_TD,     posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_RB_AND_NOT_SEL_AND_TD,     negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
