`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFZRBLHLMX2 (Q1, Q2, D1, D2, TD, CK, SEL, RB);
   reg flag, flag1; // Notifier flag
   output Q1, Q2;
   input D1, D2, TD, CK, RB, SEL;
   reg D_flag;
   wire D_flag1;
