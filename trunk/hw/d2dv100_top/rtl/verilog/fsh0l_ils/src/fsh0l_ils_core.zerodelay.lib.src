      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D4 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D4 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
