//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module AO22QDFFLHLMX0P4 (Q, A1, A2, B1, B2, CK);
   reg flag; // Notifier flag
   output Q;
   input A1, A2, B1, B2, CK;
   supply1 vcc;

   wire d_CK, d_A1, d_A2, d_B1, d_B2;

//Function Block
`protect
   and g5(tmp_oa, d_A1, d_A2);
   and g4(tmp_ob, d_B1, d_B2);
   or  g3(tmp_o, tmp_oa, tmp_ob);

   buf g2(Q, qt);
   dffrsb_udp g1(qt, tmp_o,  d_CK,  vcc,  vcc,  flag );

//Specify Block
   specify

     //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
     // Setup and Hold Time
      specparam setup_A1_CK = 0.0;
      specparam hold_A1_CK = 0.0;
      specparam setup_A2_CK = 0.0;
      specparam hold_A2_CK = 0.0;
      specparam setup_B1_CK = 0.0;
      specparam hold_B1_CK = 0.0;
      specparam setup_B2_CK = 0.0;
      specparam hold_B2_CK = 0.0;
      $setuphold(posedge CK, posedge A1, 0.0, 0.0, flag,,,d_CK, d_A1);
      $setuphold(posedge CK, negedge A1, 0.0, 0.0, flag,,,d_CK, d_A1);
      $setuphold(posedge CK, posedge A2, 0.0, 0.0, flag,,,d_CK, d_A2);
      $setuphold(posedge CK, negedge A2, 0.0, 0.0, flag,,,d_CK, d_A2);
      $setuphold(posedge CK, posedge B1, 0.0, 0.0, flag,,,d_CK, d_B1);
      $setuphold(posedge CK, negedge B1, 0.0, 0.0, flag,,,d_CK, d_B1);
      $setuphold(posedge CK, posedge B2, 0.0, 0.0, flag,,,d_CK, d_B2);
      $setuphold(posedge CK, negedge B2, 0.0, 0.0, flag,,,d_CK, d_B2);
      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine
