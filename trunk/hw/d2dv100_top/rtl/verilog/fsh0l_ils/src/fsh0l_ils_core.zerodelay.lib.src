//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFFRBNLHLMX6 (QB, D, CK, RB);

   reg flag; // Notifier flag
   output QB;
   input D, CK, RB;
   supply1 vcc;
//   reg D_flag;
//   wire D_flag1;

   wire d_CK, d_D;

//Function Block
`protect
   not g3(QB, qt);
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  vcc,  flag );
   

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (QB :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      
      $setuphold(posedge CK &&& RB, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      
      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
//      $recovery(posedge RB, posedge CK &&& D_flag1, recovery_RB_CK, flag);
//      $hold(posedge CK &&& D_flag1, posedge RB, recovery_CK_RB, flag);
      $recrem(posedge RB, posedge CK , 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFFRSBNLHLMX0P4 (QB, D, CK, RB, SB);
   reg flag; // Notifier flag
   output QB;
   input D, CK, SB, RB;
   
   wire d_CK, d_D;

//Function Block
`protect
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  SB,  flag );
   and g7(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   and g6(QB, qb1, rs);
   
//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif
      (negedge SB *> (QB :1'bx)) = (0.0, 0.0);
      (negedge RB *> (QB :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      
      $setuphold(posedge CK, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB, posedge CK &&& d_D, 0.0, 0.0, flag);
      $recrem(posedge SB, posedge CK &&& ~d_D, 0.0, 0.0, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


