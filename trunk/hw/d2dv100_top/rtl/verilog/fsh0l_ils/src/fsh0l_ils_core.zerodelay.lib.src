`celldefine
module QDSFZRSBLHLMX0P7 (Q, D, TD, CK, SEL, RB, SB, SL);
  output Q;
  input D, TD, CK, SEL, RB, SB, SL;
  reg flag; // Notifier flag
  supply1 vcc;
  wire d_CK, d_D, d_TD, d_SEL, d_SL, on1, on2, on3, on4, on5, on6;
  wire oa1, oa2, oa3;

//Function Block
`protect
   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_RB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   not n4 (on4, d_SB);
   not n5 (on5, odlh1);
   not n6 (on6, qt);
   mux2_udp m1 (om1, d_D, d_TD, SEL_);
    
   nand a1 (oa1, on1, on2);
   and a2  (oa2, d_RB, on2, d_SB, d_CK); 
   nand a3 (oa3, d_RB, on2, on4); 
   dlhrsb_udp dlh1 (odlh1, om1, on3, d_RB, d_SB, flag ); 
   dlhrsb_udp dlh2 (qt, on5, oa2, oa3, oa1, flag ); 
   buf (Q, on6);

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

	wire ENABLE_RB_SB_NOT_SEL_NOT_SL;
	wire ENABLE_RB_SB_SEL_NOT_SL;
	wire ENABLE_RB_SB_NOT_SL;

	not (SL_b, SL);
	not (SEL_b, SEL);
	and (ENABLE_RB_SB_NOT_SEL_NOT_SL, _SB_and_RB_, SEL_b, SL_b);
	and (ENABLE_RB_SB_SEL_NOT_SL, _SB_and_RB_, SEL, SL_b);
	and (ENABLE_RB_SB_NOT_SL, _SB_and_RB_, SL_b);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify
      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q :1'bx)) = (0.0, 0.0);

//  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_CK_SL = 0.0;
      specparam hold_CK_SL = 0.0;
      specparam setup_RB_SL = 0.0;
      specparam hold_RB_SL = 0.0;
      specparam setup_SB_SL = 0.0;
      specparam hold_SB_SL = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_SB_NOT_SEL_NOT_SL, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_RB_SB_NOT_SEL_NOT_SL, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& ENABLE_RB_SB_NOT_SL, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_SB_NOT_SL, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_SB_SEL_NOT_SL, posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_RB_SB_SEL_NOT_SL, negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      //$setuphold(posedge CK &&& _SB_and_RB_, posedge SL, setup_SL_CK, hold_SL_CK, flag,,,d_CK, d_SL);
      $setuphold(posedge SL, posedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
       
      $setuphold(negedge SL, posedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(negedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ~SL, posedge CK, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ~SL, posedge CK, 0.0, 0.0, flag);
      $recrem(negedge SL, negedge CK, 0.0, 0.0, flag);
      $recrem(posedge SL, posedge CK, 0.0, 0.0, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
    
`endprotect
endmodule
`endcelldefine
//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
