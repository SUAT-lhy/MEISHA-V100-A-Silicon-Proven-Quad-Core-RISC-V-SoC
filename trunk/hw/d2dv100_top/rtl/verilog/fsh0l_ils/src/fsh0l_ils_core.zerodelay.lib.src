//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDBFRSBNLHLMX1 (Q, D, CKB, RB, SB);
   reg flag; // Notifier flag
   output Q;
   input D, CKB, RB, SB;

   wire d_CKB, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   not g1(qb1, qt);
   dffrsb_udp g2(qt,  d_D,  ck,  RB,  SB,  flag );
   and g4(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
//   and g6(QB, qb1, rs);
   not g7(ck,  d_CKB );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (negedge CKB *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (negedge CKB *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CKB = 0.0;
      specparam hold_D_CKB = 0.0;
      $setuphold(negedge CKB &&& _SB_and_RB_, posedge D, 0.0, 0.0, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& _SB_and_RB_, negedge D, 0.0, 0.0, flag,,,d_CKB, d_D);

      //  Recovery Time
      specparam recovery_RB_CKB = 0.0;
      specparam recovery_SB_CKB = 0.0;
      specparam recovery_CKB_RB = 0.0;
      specparam recovery_CKB_SB = 0.0;
      $recrem(posedge RB, negedge CKB &&& d_D, 0.0, 0.0, flag);
      $recrem(posedge SB, negedge CKB &&& ~d_D, 0.0, 0.0, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_pos_CKB = 0.0;
      specparam mpw_neg_CKB = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(posedge CKB, 0.0, 0, flag);
      $width(negedge CKB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


