      $setuphold(posedge CK, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);

      //  Minimum Pulse Width
      specparam mpw_pos_CK = 0.0;
      specparam mpw_neg_CK = 0.0;
      $width(posedge CK, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


