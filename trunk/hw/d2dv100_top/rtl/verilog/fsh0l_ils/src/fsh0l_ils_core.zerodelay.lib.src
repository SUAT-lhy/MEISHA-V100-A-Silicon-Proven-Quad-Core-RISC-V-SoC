`resetall
`timescale 10ps/1ps
`celldefine
module QB4DFZRBLHLMX1 (QB1, QB2, QB3, QB4, D1, D2, D3, D4, TD, CK, SEL, RB);
   reg flag, flag1, flag2, flag3; // Notifier flag
   output QB1, QB2, QB3, QB4;
   input D1, D2, D3, D4, CK, TD, SEL, RB;
   supply1 vcc;
   reg D_flag;
   wire D_flag1;

   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_TD, d_SEL;

//Function Block
`protect
   buf b13 (SEL_, SEL );  //Avoid MIPD.

   not g1(QB1, qt1);
   not g2(QB2, qt2);
   not g3(QB3, qt3);
   not g4(QB4, qt4);

   dffrsb_udp g5(qt1,  d1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g6(qt2,  d2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  d3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  d4,  d_CK,  RB,  vcc,  flag3 );

   mux2_udp g9(d1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g10(d2,  d_D2,  qt1,  d_SEL );
   mux2_udp g11(d3,  d_D3,  qt2,  d_SEL );
   mux2_udp g12(d4,  d_D4,  qt3,  d_SEL );


//Append pseudo gate for timing violation checking
assign D_flag1   = D_flag;    // For Model-Tec complier
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 | d_D2 | d_D3 | d_D4;
    else
        D_flag = d_TD;
  end

//Specify Block
   specify
//  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB1 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (QB1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (QB2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB2 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (QB2 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (QB3 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB3 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (QB3 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (QB4 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB4 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (QB4 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      specparam setup_D3_CK = 0.0;
      specparam hold_D3_CK = 0.0;
      specparam setup_D4_CK = 0.0;
      specparam hold_D4_CK = 0.0;

      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK &&& RB, posedge D1, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& RB, negedge D1, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& RB, posedge D2, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& RB, negedge D2, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& RB, posedge D3, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& RB, negedge D3, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& RB, posedge D4, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& RB, negedge D4, 0.0, 0.0, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& RB, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, posedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& RB, negedge TD, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      $recrem(posedge RB, posedge CK, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


