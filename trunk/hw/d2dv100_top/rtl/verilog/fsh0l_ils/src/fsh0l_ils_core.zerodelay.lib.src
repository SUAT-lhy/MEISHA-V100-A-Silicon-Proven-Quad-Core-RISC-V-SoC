//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDFERBNLHLMX0P4 (Q, D, CK, EB, RB);

  output Q;
  input D, CK, EB, RB;
  reg flag; // Notifier flag
  supply1 vcc;
  reg flag_two1;
  wire d_CK, d_D, d_EB, flag_two;

//Function Block
`protect
  buf b3 (EB_, d_EB );    //Avoid MIPD.

  mux2_udp g1(qt_i,  d_D,  qt,  d_EB );
  dffrsb_udp g2(qt,  qt_i,  d_CK,  RB,  vcc,  flag );  
  buf g3(Q, qt);

//Append pseudo gate for timing violation checking
  assign flag_two = flag_two1;      // For Model-Tec complier
  always @(EB_ or d_D or qt)
    begin
      if (EB_ === 1'b0)
           flag_two1 = d_D;
      else
           flag_two1 = qt;
    end


//Specify Block
   specify

      //  Module Path Delay
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_EB_CK = 0.0;
      specparam hold_EB_CK = 0.0;
      $setuphold(posedge CK &&& RB, posedge D &&& ~EB, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D &&& ~EB, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, posedge EB, 0.0, 0.0, flag,,,d_CK, d_EB);
      $setuphold(posedge CK &&& RB, negedge EB, 0.0, 0.0, flag,,,d_CK, d_EB);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      $recrem(posedge RB, posedge CK &&& flag_two, 0.0, 0.0, flag);

      
      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      specparam mpw_neg_RB = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
      $width(negedge RB, 0.0, 0, flag);
   endspecify
`endprotect

endmodule
`endcelldefine
