module SYN3QDFZRBNLHLMX0P4 (Q, D, TD, CK, SEL, RB);
   reg flag; // Notifier flag
   output Q;
   input D, CK, TD, RB, SEL;
   supply1 vcc;
   reg D_flag;
   wire D_flag1;
   wire d_CK, d_D, d_SEL, d_TD;
   wire ENABLE_CK_AND_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_CK_AND_D_AND_SEL_AND_TD;
   wire ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD;
