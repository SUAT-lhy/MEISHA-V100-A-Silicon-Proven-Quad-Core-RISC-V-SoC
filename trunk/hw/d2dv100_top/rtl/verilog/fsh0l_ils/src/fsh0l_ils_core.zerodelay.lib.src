//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFFRSBLHLMX1 (Q1, Q2, D1, D2, CK, RB, SB);
   reg flag, flag1; // Notifier flag
   output Q1, Q2;
   input D1, D2, CK, RB, SB;

   wire d_CK, d_D1, d_D2;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  SB,  flag1 );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");


// Additional timing wires
wire D1__bar, D2__bar;
wire ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB;
wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB;
wire ENABLE_RB_AND_SB, int_twire_0, int_twire_1;
wire int_twire_2, int_twire_3;

// Additional timing gates
not (D1__bar, D1);
and (ENABLE_RB_AND_SB, RB, SB);
and (int_twire_0, D1__bar, D2, SB);
and (int_twire_1, D1, SB);
or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, int_twire_1, int_twire_0);
and (int_twire_2, D1__bar, RB);
not (D2__bar, D2);
and (int_twire_3, D1, D2__bar, RB);
or (ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_3, int_twire_2);


//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q1 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q2 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q2 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      
      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 0.0, 0.0, flag);





      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFFRSBLHLMX2 (Q1, Q2, D1, D2, CK, RB, SB);
   reg flag, flag1; // Notifier flag
   output Q1, Q2;
   input D1, D2, CK, RB, SB;

   wire d_CK, d_D1, d_D2;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  SB,  flag1 );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");


// Additional timing wires
wire D1__bar, D2__bar;
wire ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB;
wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB;
wire ENABLE_RB_AND_SB, int_twire_0, int_twire_1;
wire int_twire_2, int_twire_3;

// Additional timing gates
not (D1__bar, D1);
and (ENABLE_RB_AND_SB, RB, SB);
and (int_twire_0, D1__bar, D2, SB);
and (int_twire_1, D1, SB);
or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, int_twire_1, int_twire_0);
and (int_twire_2, D1__bar, RB);
not (D2__bar, D2);
and (int_twire_3, D1, D2__bar, RB);
or (ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_3, int_twire_2);


//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q1 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q2 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q2 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      
      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 0.0, 0.0, flag);





      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


