   bufif1   g2 (io_i, i, e_tmp);
   not      g3 (ne,   e_tmp);
   rnmos    g4 (io_i_tmp, io_e, ne);  //-- pull level
   rnmos    g5 (io_i, io_i_tmp, vcc);  //-- added for down scale to weak level   
   nmos     g6 (io,   io_i, vcc);

