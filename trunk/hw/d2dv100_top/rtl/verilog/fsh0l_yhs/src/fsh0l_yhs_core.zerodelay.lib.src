   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc, SB,  flag1 );
   mux2_udp g7(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g8(data2,  d_D2,  qt1,  SEL_ );

	// Additional timing wires
	wire D1__bar, D2__bar, ENABLE_SB, ENABLE_D1_AND_NOT_D2_AND_NOT_SEL;
	wire ENABLE_D1_AND_SB_AND_SEL;
	wire ENABLE_D1_AND_SEL_AND_NOT_TD;
	wire ENABLE_NOT_D1_AND_SB_AND_SEL;
	wire ENABLE_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_NOT_SEL;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
	and (ENABLE_SB_AND_NOT_SEL, SB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_NOT_TD, D1, SEL, TD__bar);
	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, D1, D2__bar, SEL__bar);
	and (ENABLE_D1_AND_SB_AND_SEL, D1, SB, SEL);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL, D1__bar, SB, SEL);
	and (ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, D1__bar, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_NOT_SEL, D1__bar, SEL__bar);




//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D1 or d_D2 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 & d_D2;
    else
        D_flag = d_TD;
  end

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
      (negedge SB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge SB *> (Q2 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;

      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,posedge D1 &&& ENABLE_SB_AND_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,negedge D1 &&& ENABLE_SB_AND_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,posedge D2 &&& ENABLE_SB_AND_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,negedge D2 &&& ENABLE_SB_AND_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_SB, posedge SEL &&& ENABLE_SB, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB, negedge SEL &&& ENABLE_SB, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      //  Recovery Time
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge SB &&& ENABLE_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_NOT_TD, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_SEL, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


