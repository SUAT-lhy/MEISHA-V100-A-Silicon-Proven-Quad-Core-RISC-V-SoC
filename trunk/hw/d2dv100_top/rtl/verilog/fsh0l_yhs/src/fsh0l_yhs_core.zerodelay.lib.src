      if (B1 == 0 && C1 == 1) (A1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge A1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && B1 == 0) (C1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && B1 == 1) (C1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge C1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge C1 *> (O :1'bx)) = (0.0, 0.0);

