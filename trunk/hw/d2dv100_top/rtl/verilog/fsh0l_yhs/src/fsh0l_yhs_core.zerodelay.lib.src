//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZRBLBHMX0P4 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, RB);
   reg flag, flag1, flag2, flag3; // Notifier flag
   output Q1, Q2, Q3, Q4;
   input D1, D2, D3, D4, TD, CK, RB, SEL;
   reg D_flag;
   wire D_flag1;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD;
   supply1 vcc;


//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   buf g5(Q3, qt3);
   buf g6(Q4, qt4);
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  RB,  vcc,  flag3 );
   mux2_udp g9(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g10(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g11(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g12(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
     begin
       if (SEL_ === 1'b0) 
           D_flag = d_D1 | d_D2 | d_D3 | d_D4;
       else
           D_flag = d_TD;
     end

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire ENABLE_RB, ENABLE_D1_AND_NOT_SEL, ENABLE_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SEL, ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_SEL_AND_TD, ENABLE_NOT_CK, ENABLE_NOT_D1_AND_D2_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_TD, ENABLE_NOT_D1_AND_RB_AND_SEL, ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL_AND_TD, ENABLE_NOT_D1_AND_SEL_AND_TD, ENABLE_RB_AND_NOT_SEL;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_TD, D1, RB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, D1, RB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_RB_AND_NOT_SEL_AND_TD, D1, RB, SEL__bar, TD);
	and (ENABLE_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, D1, RB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_TD, D1__bar, RB, SEL, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_TD, D1__bar, RB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, D1__bar, RB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_NOT_SEL, RB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_TD, D1, SEL, TD);
	and (ENABLE_D1_AND_NOT_SEL, D1, SEL__bar);
	and (ENABLE_NOT_D1_AND_SEL_AND_TD, D1__bar, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, D1__bar, D2, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, D1__bar, D2__bar, D3, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, D1__bar, D2__bar, D3__bar, D4, SEL__bar);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_RB_AND_SEL, D1, RB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL, D1__bar, RB, SEL);

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q2 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q3 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q3 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q3 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q4 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q4 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q4 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      specparam setup_D3_CK = 0.0;
      specparam hold_D3_CK = 0.0;
      specparam setup_D4_CK = 0.0;
      specparam hold_D4_CK = 0.0;

      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D1 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D1 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D3 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D3 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D4 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D4 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_RB, posedge SEL &&& ENABLE_RB, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB, negedge SEL &&& ENABLE_RB, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);


      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
	$recrem (posedge RB &&& ENABLE_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_TD, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_D1_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_SEL, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_TD, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


