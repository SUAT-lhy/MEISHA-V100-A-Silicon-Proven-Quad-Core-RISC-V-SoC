     `endif
      (negedge SB *> (Q2 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D1 &&& ENABLE_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D1 &&& ENABLE_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D2 &&& ENABLE_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D2 &&& ENABLE_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      //  Recovery Time
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_OR_NOT_D1, posedge CK &&& ENABLE_D1_AND_NOT_D2_OR_NOT_D1, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


