module QDBAHLBHMX2 (Q, D, GB);
   reg flag; // Notifier flag
   output Q;
   input D, GB;
   supply1 vcc;

   wire d_GB, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   dlhrb_udp g2(qt,  d_D,  ck,  vcc,  flag );
   not g1(ck,  d_GB );

//Specify Block
   specify

      //  Module Path Delay
      (negedge GB *> (Q :1'bx)) = (0.0, 0.0);
      (D *> Q) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_GB = 0.0;
      specparam hold_D_GB = 0.0;
      $setuphold(posedge GB, posedge D, 0.0, 0.0, flag,,,d_GB, d_D);
      $setuphold(posedge GB, negedge D, 0.0, 0.0, flag,,,d_GB, d_D);

      //  Minimum Pulse Width
      specparam mpw_neg_GB = 0.0;
      $width(negedge GB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


