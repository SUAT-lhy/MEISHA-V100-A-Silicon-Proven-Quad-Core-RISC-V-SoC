//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module DBAHRBLBHMX0P4 (Q, QB, D, GB, RB);
   reg flag; // Notifier flag
   output Q, QB;
   input D, GB, RB;

   wire d_GB, d_D;
   wire d_RB;

//Function Block
`protect
   buf g3(Q, qt);
   not g1(QB, qt);
   dlhrb_udp g2(qt,  d_D,  ck,  d_RB,  flag );
   not g4(ck,  d_GB );

//Specify Block
   specify

      //  Module Path Delay
      (negedge GB *> (Q :1'bx)) = (0.0, 0.0);
      (negedge GB *> (QB :1'bx)) = (0.0, 0.0);
      (D *> Q) = (0.0, 0.0);
      (D *> QB) = (0.0, 0.0);
      (RB *> Q) = (0.0, 0.0);
      (RB *> QB) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_GB = 0.0;
      specparam hold_D_GB = 0.0;
      $setuphold(posedge GB &&& RB, posedge D, 0.0, 0.0, flag,,,d_GB, d_D);
      $setuphold(posedge GB &&& RB, negedge D, 0.0, 0.0, flag,,,d_GB, d_D);

      //  Recovery Time
      specparam recovery_RB_GB = 0.0;
      specparam recovery_GB_RB = 0.0;
     // $recovery(posedge RB, posedge GB &&& d_D, recovery_RB_GB, flag);
     // $hold(posedge GB &&& d_D, posedge RB, recovery_GB_RB, flag);
      $recrem(posedge RB, posedge GB &&& d_D, 0.0, 0.0, flag,,,d_RB,d_GB);


      //  Minimum Pulse Width
      specparam mpw_neg_GB = 0.0;
      specparam mpw_neg_RB = 0.0;
      $width(negedge GB, 0.0, 0, flag);
      $width(negedge RB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


