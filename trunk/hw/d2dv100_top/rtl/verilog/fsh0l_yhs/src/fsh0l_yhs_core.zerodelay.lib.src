//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFZCLRBNLBHMX0P4 (QB, D, TD, CK, RB, SEL, LD);
   reg flag; // Notifier flag
   reg  D_flag1, RB_flag1, SEL_flag1, LD_flag1;
   wire D_flag, RB_flag, SEL_flag, LD_flag;
   output QB;
   input D, TD, CK, RB, SEL, LD;
   supply1 vcc;

   wire d_CK, d_D, d_LD, d_RB, d_SEL, d_TD;

//Function Block
`protect
   buf b1 (D_, d_D );      //Avoid MIPD.
   buf b2 (TD_, d_TD );    //Avoid MIPD.
   buf b3 (RB_, d_RB );    //Avoid MIPD.
   buf b4 (SEL_, d_SEL );  //Avoid MIPD.
   buf b5 (LD_, d_LD );    //Avoid MIPD.
   //buf g3(Q, qt);
   not g1(QB, qt);
   dffrsb_udp g2(qt,  d1,  d_CK,  vcc,  vcc,  flag );
   and g4(D_tmp, di, RB_);
   mux2_udp g5(di, qt, D_, LD_);
   mux2_udp g9(d1, D_tmp, TD_, SEL_);
// Define the flag for timing check
  assign D_flag   = D_flag1;    // For Model-Tec complier
  assign LD_flag   = LD_flag1;  // For Model-Tec complier
  assign SEL_flag = SEL_flag1;  // For Model-Tec complier
  assign RB_flag  = RB_flag1;   // For Model-Tec complier
  always @(SEL_ or RB_ or LD_)
    begin
      if ((SEL_ === 1'b0) && (RB_ === 1'b1) && (LD_ === 1'b1))
         D_flag1 = 1'b1;
      else
         D_flag1 = 1'b0;
    end
  always @(SEL_ or di)
    begin
      if ((SEL_ === 1'b0) && (di === 1'b1))
         RB_flag1 = 1'b1;
      else
         RB_flag1 = 1'b0;
    end
  always @(D_tmp or TD_)
    begin
      if (D_tmp !== TD_)
         SEL_flag1 = 1'b1;
      else
         SEL_flag1 = 1'b0;
    end
  always @(D_ or QB or RB_ or SEL_)
    begin
      if ((!D_ !== QB) && (SEL_ === 1'b0) && (RB_ === 1'b1))
         LD_flag1 = 1'b1;
      else
         LD_flag1 = 1'b0;
    end

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_LD_CK = 0.0;
      specparam hold_LD_CK = 0.0;
      specparam setup_RB_CK = 0.0;
      specparam hold_RB_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK, posedge D &&& D_flag, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D &&& D_flag, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, posedge LD &&& LD_flag, 0.0, 0.0, flag,,,d_CK, d_LD);
      $setuphold(posedge CK, negedge LD &&& LD_flag, 0.0, 0.0, flag,,,d_CK, d_LD);
      $setuphold(posedge CK, posedge RB &&& RB_flag, 0.0, 0.0, flag,,,d_CK, d_RB);
      $setuphold(posedge CK, negedge RB &&& RB_flag, 0.0, 0.0, flag,,,d_CK, d_RB);
      $setuphold(posedge CK, posedge SEL &&& SEL_flag, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL &&& SEL_flag, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


