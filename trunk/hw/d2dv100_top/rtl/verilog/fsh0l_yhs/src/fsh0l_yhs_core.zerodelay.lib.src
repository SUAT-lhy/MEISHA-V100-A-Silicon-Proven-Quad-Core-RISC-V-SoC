`timescale 10ps/1ps
`celldefine
module MAO222LBHMX0P4 (O, A1, B1, C1);
   output O;
   input A1, B1, C1;

//Function Block
`protect
   and   g1(o1, A1, B1),
         g2(o2, A1, C1),
         g3(o3, B1, C1);
   nor   g4(o4, o1, o2, o3);
   not   g5(O, o4);

