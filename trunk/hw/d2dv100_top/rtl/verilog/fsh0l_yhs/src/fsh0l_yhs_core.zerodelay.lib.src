   not n1 (on1, d_SB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   not n4 (on4, d_RB);
   not n5 (on5, odlh1);
   
   and a1 (oa1, on1, on4); 
   nand na2 (ona2, d_RB, on2, on1);
   nand na1 (ona1, on4, on2); 
   and a2 (oa2, d_RB, on2, d_SB, d_CK);

