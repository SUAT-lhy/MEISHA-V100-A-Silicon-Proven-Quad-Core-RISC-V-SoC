      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, 0.0, 0.0, flag);
