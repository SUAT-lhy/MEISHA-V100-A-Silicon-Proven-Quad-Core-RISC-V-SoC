	and (ENABLE_D1_AND_RB_AND_SEL, D1, RB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL, D1__bar, RB, SEL);

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
