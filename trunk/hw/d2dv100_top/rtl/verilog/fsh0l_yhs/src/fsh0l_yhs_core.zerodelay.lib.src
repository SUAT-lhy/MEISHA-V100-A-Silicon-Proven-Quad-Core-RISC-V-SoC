or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, ENABLE_D1_AND_RB_AND_SB;
	wire ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB;
	wire ENABLE_NOT_CK_AND_SB, ENABLE_NOT_D1_AND_RB_AND_SB, ENABLE_RB_AND_SB;
	wire int_twire_0, int_twire_1, int_twire_2;
	wire int_twire_3, int_twire_4, int_twire_5;
	wire int_twire_6, int_twire_7;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB, D1, RB, SB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB, D1__bar, RB, SB);
	and (ENABLE_RB_AND_SB, RB, SB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4, SB);
	and (int_twire_1, D1__bar, D2__bar, D3, SB);
	and (int_twire_2, D1__bar, D2, SB);
	and (int_twire_3, D1, SB);
	or (ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, int_twire_3, int_twire_2, int_twire_1, int_twire_0);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (int_twire_4, D1__bar, RB);
	and (int_twire_5, D1, D2__bar, RB);
	and (int_twire_6, D1, D2, D3__bar, RB);
	not (D4__bar, D4);
	and (int_twire_7, D1, D2, D3, D4__bar, RB);
	or (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, int_twire_7, int_twire_6, int_twire_5, int_twire_4);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);




//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q1 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q2 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q2 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q3 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q3 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q3 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q3 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q4 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q4 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q4 :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q4 :1'bx)) = (0.0, 0.0);


      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D1 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D1 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D2 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D2 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 0.0;
      specparam hold_D3_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D3 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D3 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 0.0;
      specparam hold_D4_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge D4 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge D4 &&& ENABLE_RB_AND_SB, 0.0, 0.0, flag3,,,d_CK, d_D4);
      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB, 0.0, 0.0, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_OR_D1_AND_D2_AND_NOT_D3_AND_RB_OR_D1_AND_NOT_D2_AND_RB_OR_NOT_D1_AND_RB, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


