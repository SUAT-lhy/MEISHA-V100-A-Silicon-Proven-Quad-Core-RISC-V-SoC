      ifnone (posedge A1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A1 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 0 && B2 == 1) (A2 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 0 && B2 == 0) (A2 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 1 && B2 == 0) (A2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge A2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A2 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


