      $setuphold(posedge CK &&& ENABLE_RB, negedge SEL &&& ENABLE_RB, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);


      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
	$recrem (posedge RB &&& ENABLE_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_TD, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_D1_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_SEL, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_TD, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, 0.0, 0.0, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
