   assign ENABLE_D_AND_RB_AND_SEL = D & RB & SEL;

//Function Block
`protect
   buf (SEL_, d_SEL );  //Avoid MIPD.

   mux2_udp m1 (d1,  d_D,  d_TD,  SEL_ );
