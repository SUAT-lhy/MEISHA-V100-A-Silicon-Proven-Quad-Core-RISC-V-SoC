//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module OCCDFTLBHMX1 (DFTCK, SCK, CAPEN, SEN, PLLCK, BPOCC);
   reg flag; // Notifier flag
   output DFTCK;
   input SCK, CAPEN, SEN, PLLCK, BPOCC;
   supply1 vcc;

   //wire d_CK, d_D, d_SEL, d_TD;

//Function Block
`protect
   not g0(i0, SEN);
   and g1(i1, CAPEN,i0);   

   dffrsb_udp g2(qt1,  i1,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g3(qt2,  qt1,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g4(qt3,  qt2,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g5(qt4,  qt3,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g6(qt5,  qt4,  PLLCK,  vcc,  vcc,  flag );

   not g7(i2, qt5);
   and g8(i3, qt3,i2); 

   not g9(ckb,  PLLCK );
   or g10(or_o, 1'b0, i3);
   dlhrb_udp g11(qt6,  or_o, ckb,  vcc,  flag );
   and g12(i4, PLLCK, qt6);

   nor g13(i5, SEN, BPOCC);
   mux2_udp g15(DFTCK, SCK, i4, i5);

//Specify Block
   specify

      //  Module Path Delay
      (BPOCC *> DFTCK) = (0.0, 0.0);
      (PLLCK *> DFTCK) = (0.0, 0.0);
      (SCK *> DFTCK) = (0.0, 0.0);
      (SEN *> DFTCK) = (0.0, 0.0);

      //  Setup and Hold Time
      //specparam setup_D_CK = 0.0;
      //specparam hold_D_CK = 0.0;
      //specparam setup_SEL_CK = 0.0;
      //specparam hold_SEL_CK = 0.0;
      //specparam setup_TD_CK = 0.0;
      //specparam hold_TD_CK = 0.0;
