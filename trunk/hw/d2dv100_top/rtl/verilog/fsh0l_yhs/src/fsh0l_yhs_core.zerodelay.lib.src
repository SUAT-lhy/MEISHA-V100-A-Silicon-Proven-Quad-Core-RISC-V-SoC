`celldefine
module AOA112LBHMX0P4 (O, A1, A2, B1, B2);
   output O;
   input A1, A2, B1, B2;

//Function Block
`protect
   and g1(tmp_o1, A1, A2);
   or  g2(tmp_o2, tmp_o1, B1);
   and g3(O, tmp_o2, B2);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (A1 == 0 && A2 == 0) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 0) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 1) (B1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 1 && B1 == 0) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 0 && B1 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 1 && B1 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 1 && B1 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 0 && B1 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B2 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
      (A1 *> (O :1'bx)) = (0.0, 0.0);
      (A2 *> (O :1'bx)) = (0.0, 0.0);
   endspecify
`endprotect
endmodule
`endcelldefine
