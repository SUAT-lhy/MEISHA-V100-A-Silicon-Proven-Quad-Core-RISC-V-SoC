//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGMUX2LBHMX1 (O, S, A, B);
   reg flag; // Notifier flag
   input A, B, S;
   output O;

//Function Block
`protect
   mux2_udp g1(O, A, B, S);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B == 0) (A *> (O :1'bx)) = (0.0, 0.0);
      if (B == 1) (A *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge A *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A *> (O :1'bx)) = (0.0, 0.0);
      if (A == 0) (B *> (O :1'bx)) = (0.0, 0.0);
      if (A == 1) (B *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B *> (O :1'bx)) = (0.0, 0.0);
      if (A == 1 && B == 0) (S *> (O :1'bx)) = (0.0, 0.0);
      if (A == 0 && B == 1) (S *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge S *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge S *> (O :1'bx)) = (0.0, 0.0);
`ifdef delayfix
   pathdelay_enhanced;
`endif
      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGMUX2LBHMX2 (O, S, A, B);
   reg flag; // Notifier flag
   input A, B, S;
   output O;

//Function Block
`protect
   mux2_udp g1(O, A, B, S);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B == 0) (A *> (O :1'bx)) = (0.0, 0.0);
      if (B == 1) (A *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge A *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A *> (O :1'bx)) = (0.0, 0.0);
      if (A == 0) (B *> (O :1'bx)) = (0.0, 0.0);
      if (A == 1) (B *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B *> (O :1'bx)) = (0.0, 0.0);
      if (A == 1 && B == 0) (S *> (O :1'bx)) = (0.0, 0.0);
      if (A == 0 && B == 1) (S *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge S *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge S *> (O :1'bx)) = (0.0, 0.0);
`ifdef delayfix
   pathdelay_enhanced;
`endif
      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


