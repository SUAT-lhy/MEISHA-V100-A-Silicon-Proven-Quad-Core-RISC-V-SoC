      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, posedge CK &&& ENABLE_D1_AND_SB_OR_NOT_D1_AND_D2_AND_SB, 0.0, 0.0, flag);
