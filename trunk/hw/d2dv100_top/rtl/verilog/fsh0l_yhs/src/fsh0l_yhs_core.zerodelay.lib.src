`celldefine
module Q2DFZSBLBHMX0P4 (Q1, Q2, D1, D2, TD, CK, SEL, SB);
   reg flag, flag1; // Notifier flag
   output Q1, Q2;
   input D1, D2, TD, CK, SB, SEL;
   reg D_flag;
