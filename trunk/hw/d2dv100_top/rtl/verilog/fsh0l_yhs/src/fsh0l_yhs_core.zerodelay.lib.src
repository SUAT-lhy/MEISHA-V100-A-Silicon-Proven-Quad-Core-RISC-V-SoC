module QDSFFRSBLBHMX3 (Q, D, CK, RB, SB, SL);
  output Q;
  input D, CK, RB, SB, SL;
  reg flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_SL, on1, on2, on3, on4, on5, oa1, oa2, ona1, ona2;

//Function Block
`protect

   not n1 (on1, d_SB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   not n4 (on4, d_RB);
   not n5 (on5, odlh1);
   
   and a1 (oa1, on1, on4); 
   nand na2 (ona2, d_RB, on2, on1);
   nand na1 (ona1, on4, on2); 
   and a2 (oa2, d_RB, on2, d_SB, d_CK);

   dlhrsb_udp dlh1 (odlh1, d_D, on3, d_RB, d_SB, flag ); 
   dlhrsb_udp dlh2 (qt, on5, oa2, ona2, ona1, flag ); 
   not (Q, qt);


//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);


//Specify Block
  specify
     `ifdef allzero
            (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
            (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
    (negedge RB *> (Q :1'bx)) = (0.0, 0.0);
    (negedge SB *> (Q :1'bx)) = (0.0, 0.0);

//  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_CK_SL = 0.0;
      specparam hold_CK_SL = 0.0;
      specparam setup_RB_SL = 0.0;
      specparam hold_RB_SL = 0.0;
      specparam setup_SB_SL = 0.0;
      specparam hold_SB_SL = 0.0;
      $setuphold(posedge CK &&& _SB_and_RB_, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge SL, posedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
       
      $setuphold(negedge SL, posedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(negedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge RB, posedge CK, 0.0, 0.0, flag);
      $recrem(posedge SB, posedge CK, 0.0, 0.0, flag);
      $recrem(negedge SL, negedge CK, 0.0, 0.0, flag);
      $recrem(posedge SL, posedge CK, 0.0, 0.0, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);

  endspecify

`endprotect
endmodule
`endcelldefine
