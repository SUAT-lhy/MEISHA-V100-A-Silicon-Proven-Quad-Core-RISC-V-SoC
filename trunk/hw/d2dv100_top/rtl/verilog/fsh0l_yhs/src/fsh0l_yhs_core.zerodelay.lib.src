`celldefine
module Q4DFFRBLBHMX3 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, CK, RB);
   reg flag, flag1, flag2, flag3; // Notifier flag
   output Q1, Q2, Q3, Q4;
   input D1, D2, D3, D4, CK, RB;
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_D3, d_D4;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   buf g5(Q3, qt3);
   buf g6(Q4, qt4);
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  vcc,  flag3 );

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire ENABLE_D1_AND_RB, ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, ENABLE_NOT_CK;
	wire ENABLE_RB, ENABLE_NOT_D1_AND_RB, int_twire_0, int_twire_1;
	wire int_twire_2;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	and (ENABLE_D1_AND_RB, D1, RB);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB, D1__bar, RB);
	not (D3__bar, D3);
	not (D2__bar, D2);
	and (int_twire_0, D1__bar, D2__bar, D3__bar, D4);
	and (int_twire_1, D1__bar, D2__bar, D3);
	and (int_twire_2, D1__bar, D2);
	or (ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, D1, int_twire_2, int_twire_1, int_twire_0);
	not (ENABLE_NOT_CK, CK);


//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q2 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q3 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q3 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q3 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q4 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q4 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q4 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D1 &&& ENABLE_RB, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D1 &&& ENABLE_RB, 0.0, 0.0, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D2 &&& ENABLE_RB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D2 &&& ENABLE_RB, 0.0, 0.0, flag1,,,d_CK, d_D2);

      specparam setup_D3_CK = 0.0;
      specparam hold_D3_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D3 &&& ENABLE_RB, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D3 &&& ENABLE_RB, 0.0, 0.0, flag2,,,d_CK, d_D3);
      specparam setup_D4_CK = 0.0;
      specparam hold_D4_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB, posedge D4 &&& ENABLE_RB, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB, negedge D4 &&& ENABLE_RB, 0.0, 0.0, flag3,,,d_CK, d_D4);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      $recrem(posedge RB &&& ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, posedge CK &&& ENABLE_D1_OR_NOT_D1_AND_D2_OR_NOT_D1_AND_NOT_D2_AND_D3_OR_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
