     `ifdef allzero
              (posedge CK *> (Q4 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q4 :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q4 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      specparam setup_D3_CK = 0.0;
      specparam hold_D3_CK = 0.0;
      specparam setup_D4_CK = 0.0;
      specparam hold_D4_CK = 0.0;

      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D1 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D1 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D3 &&& ENABLE_RB_AND_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
