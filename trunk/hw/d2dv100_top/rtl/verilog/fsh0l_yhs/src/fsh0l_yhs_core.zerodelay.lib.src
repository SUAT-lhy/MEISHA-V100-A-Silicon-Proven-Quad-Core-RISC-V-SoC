   wire flag_two;
   wire d_CK, d_D, d_TD, d_EB, d_SEL;

//Function Block
`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.
   buf b4 (EB_, d_EB );    //Avoid MIPD.

   not g1(QB, qt);
   dffrsb_udp g2(qt,  d1,  d_CK,  RB,  vcc,  flag );
   mux3_udp g4(d1,  d_D,  qt,  d_TD, EB_, SEL_ );


// Define the flag for timing check
  assign D_flag = D_flag1;      // For Model-Tec complier
  always @(EB_ or SEL_)
    begin
      if ((EB_ === 1'b0) && (SEL_ === 1'b0))
         D_flag1 = 1'b1;
      else
         D_flag1 = 1'b0;
    end

//Append pseudo gate for timing violation checking
  assign flag_two = flag_two1;      // For Model-Tec complier
  always @(EB_ or SEL_ or D or TD or qt)
    begin
      if (EB_ === 1'b0) begin
        if (SEL_ === 1'b0) 
           flag_two1 = D;
        else
           flag_two1 = TD;
      end
      else begin
        if (SEL_ === 1'b0) 
           flag_two1 = qt;
        else
           flag_two1 = TD;
      end
    end

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (QB :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_EB_CK = 0.0;
      specparam hold_EB_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK &&& RB, posedge D &&& D_flag, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D &&& D_flag, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, posedge EB &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_EB);
      $setuphold(posedge CK &&& RB, negedge EB &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_EB);
      $setuphold(posedge CK &&& RB, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& RB, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      $recrem(posedge RB, posedge CK &&& flag_two, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      specparam mpw_neg_RB = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
      $width(negedge RB, 0.0, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine


