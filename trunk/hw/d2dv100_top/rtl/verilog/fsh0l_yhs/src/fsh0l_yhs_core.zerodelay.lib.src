//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module DLAHLBHMX0P4 (Q, QB, D, G);
   reg flag; // Notifier flag
   output Q, QB;
   input D, G;
   supply1 vcc;

   wire d_G, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   not g1(QB, qt);
   dlhrb_udp g2(qt,  d_D,  d_G,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge G *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge G *> (Q :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge G *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge G *> (QB :1'bx)) = (20, 20);
     `endif
      (D *> Q) = (0.0, 0.0);
      (D *> QB) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_G = 0.0;
      specparam hold_D_G = 0.0;
      $setuphold(negedge G, posedge D, 0.0, 0.0, flag,,,d_G, d_D);
      $setuphold(negedge G, negedge D, 0.0, 0.0, flag,,,d_G, d_D);

      //  Minimum Pulse Width
      specparam mpw_pos_G = 0.0;
      $width(posedge G, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


