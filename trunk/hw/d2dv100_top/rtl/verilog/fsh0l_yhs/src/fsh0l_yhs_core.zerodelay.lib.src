`resetall
`timescale 10ps/1ps
`celldefine
module QDBZRSBNLBHMX0P4 (Q, D, TD, CKB, SEL, RB, SB);
   reg flag; // Notifier flag
   output Q;
   input D, TD, CKB, RB, SB, SEL;
   reg D_flag;
   wire d_CKB, d_D, d_SEL, d_TD, D_flag1;

//Function Block
`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3(Q, qt);
   not g1(qb1, qt);
   dffrsb_udp g2(qt, d1, ck, RB, SB, flag);
   and g4(rb_and_sb, RB, SB);
   or g5(rs, RB, SB);
   //and g6(QB, qb1, rs);
   not g7(ck,  d_CKB );
   mux2_udp g8(d1,  d_D,  d_TD,  SEL_ );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1   = D_flag;    // For Model-Tec complier
always @(SEL_ or d_D or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D;
    else
        D_flag = d_TD;
  end


//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (negedge CKB *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (negedge CKB *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge SB *> (Q :1'bx)) = (0.0, 0.0);
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CKB = 0.0;
      specparam hold_D_CKB = 0.0;
      specparam setup_SEL_CKB = 0.0;
      specparam hold_SEL_CKB = 0.0;
      specparam setup_TD_CKB = 0.0;
      specparam hold_TD_CKB = 0.0;
      $setuphold(negedge CKB &&& _SB_and_RB_, posedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& _SB_and_RB_, negedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& _SB_and_RB_, posedge SEL, 0.0, 0.0, flag,,,d_CKB, d_SEL);
      $setuphold(negedge CKB &&& _SB_and_RB_, negedge SEL, 0.0, 0.0, flag,,,d_CKB, d_SEL);
      $setuphold(negedge CKB &&& _SB_and_RB_, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CKB, d_TD);
      $setuphold(negedge CKB &&& _SB_and_RB_, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CKB, d_TD);

      //  Recovery Time
      specparam recovery_RB_CKB = 0.0;
      specparam recovery_SB_CKB = 0.0;
      specparam recovery_CKB_RB = 0.0;
      specparam recovery_CKB_SB = 0.0;
      $recrem(posedge RB, negedge CKB &&& D_flag1, 0.0, 0.0, flag);
      $recrem(posedge SB, negedge CKB &&& ~D_flag1, 0.0, 0.0, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_SB = 0.0;
      specparam mpw_pos_CKB = 0.0;
      specparam mpw_neg_CKB = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge SB, 0.0, 0, flag);
      $width(posedge CKB, 0.0, 0, flag);
      $width(negedge CKB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


