module AN2QBDFFNLBHMX1 (QB, D1, D2, CK);
   reg flag; // Notifier flag
   output QB;
   input D1, D2, CK;
   supply1 vcc;

   wire d_CK,d_D1,d_D2;

//Function Block
`protect
   and g4 (n1, d_D1, d_D2);
   not g3 (QB, qt);
   dffrsb_udp g2(qt,  n1,  d_CK,  vcc,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK, posedge D1 &&& D2, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, negedge D1 &&& D2, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, posedge D2 &&& D1, 0.0, 0.0, flag,,,d_CK, d_D2);
      $setuphold(posedge CK, negedge D2 &&& D1, 0.0, 0.0, flag,,,d_CK, d_D2);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


