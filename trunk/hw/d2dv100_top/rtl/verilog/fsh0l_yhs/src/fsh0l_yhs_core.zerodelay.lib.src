//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDBFRBNLBHMX0P4 (Q, D, CKB, RB);
   reg flag; // Notifier flag
   output Q;
   input D, CKB, RB;
   supply1 vcc;

   wire d_CKB, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   dffrsb_udp g2(qt,  d_D,  ck,  RB,  vcc,  flag );
   not g7(ck,  d_CKB );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (negedge CKB *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (negedge CKB *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CKB = 0.0;
      specparam hold_D_CKB = 0.0;
      $setuphold(negedge CKB &&& RB, posedge D, 0.0, 0.0, flag,,,d_CKB, d_D);
      $setuphold(negedge CKB &&& RB, negedge D, 0.0, 0.0, flag,,,d_CKB, d_D);

      //  Recovery Time
      specparam recovery_RB_CKB = 0.0;
      specparam recovery_CKB_RB = 0.0;
      $recrem(posedge RB, negedge CKB, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_CKB = 0.0;
      specparam mpw_pos_CKB = 0.0;
      specparam mpw_neg_RB = 0.0;
      $width(negedge CKB, 0.0, 0, flag);
      $width(posedge CKB, 0.0, 0, flag);
      $width(negedge RB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


