//   buf g3(Q, qt);
   not g1(QB, qt);
   dffrsb_udp g2(qt,  d1,  d_CK,  vcc,  vcc,  flag );
   and g4(d1,  d_D,  d_RB );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_RB_CK = 0.0;
      specparam hold_RB_CK = 0.0;
      $setuphold(posedge CK, posedge D &&& RB, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D &&& RB, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, posedge RB &&& D, 0.0, 0.0, flag,,,d_CK, d_RB);
      $setuphold(posedge CK, negedge RB &&& D, 0.0, 0.0, flag,,,d_CK, d_RB);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


