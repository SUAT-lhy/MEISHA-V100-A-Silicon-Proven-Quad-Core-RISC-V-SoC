`resetall
`timescale 10ps/1ps
`celldefine
module AO112LBHMX0P4 (O, A1, B1, C1, C2);
   output O;
   input A1, B1, C1, C2;

//Function Block
`protect
   and g1(o1, C1, C2);
   nor g2(o2, A1, B1, o1);
   not g3(O, o2);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (C1 == 0 && C2 == 0) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (C1 == 1 && C2 == 0) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (C1 == 0 && C2 == 1) (B1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B1 *> (O :1'bx)) = (0.0, 0.0);
      if (C1 == 1 && C2 == 0) (A1 *> (O :1'bx)) = (0.0, 0.0);
      if (C1 == 0 && C2 == 1) (A1 *> (O :1'bx)) = (0.0, 0.0);
