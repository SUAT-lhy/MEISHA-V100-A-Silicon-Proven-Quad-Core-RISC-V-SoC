     `ifdef allzero
              ifnone (posedge CK *> (Q:1'bx)) = (0.0, 0.0);
     `else
              ifnone (posedge CK *> (Q:1'bx)) = (20, 20);
     `endif
      //  Module Path Delay

      //  Setup and Hold Time
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_TD,     posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold   (posedge CK &&& ENABLE_NOT_SEL_AND_TD,     negedge D, 0.0, 0.0, flag,,,d_CK, d_D);
