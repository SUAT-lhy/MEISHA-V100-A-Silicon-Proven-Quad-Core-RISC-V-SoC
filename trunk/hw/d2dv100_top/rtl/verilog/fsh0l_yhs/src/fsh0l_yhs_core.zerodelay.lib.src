//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module GCBESLBHMX0P7 (Q, E, TE, CKB);
   reg flag; // Notifier flag
   output Q;
   input E, TE, CKB;
   supply1 vcc;

   wire d_CKB, d_E, d_TE;

//Function Block
`protect
   or g1(or_o, d_TE, d_E);
   dlhrb_udp g2(qt,  or_o,  d_CKB,  vcc,  flag );
   not g3(qt_bar, qt);
   or g4(Q,  d_CKB,  qt_bar);
   
//Specify Block
   specify

      //  Module Path Delay
      (CKB *> Q) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_E_CKB = 0.0;
      specparam hold_E_CKB = 0.0;
      specparam setup_TE_CKB = 0.0;
      specparam hold_TE_CKB = 0.0;
      $setuphold(negedge CKB, posedge E &&& ~TE, 0.0, 0.0, flag,,,d_CKB, d_E);
      $setuphold(negedge CKB, negedge E &&& ~TE, 0.0, 0.0, flag,,,d_CKB, d_E);
      $setuphold(negedge CKB, posedge TE &&& ~E, 0.0, 0.0, flag,,,d_CKB, d_TE);
      $setuphold(negedge CKB, negedge TE &&& ~E, 0.0, 0.0, flag,,,d_CKB, d_TE);

      //  Minimum Pulse Width
      specparam mpw_pos_CKB = 0.0;
      $width(posedge CKB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine
