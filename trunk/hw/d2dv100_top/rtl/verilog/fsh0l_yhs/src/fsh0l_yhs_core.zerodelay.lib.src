         2'b00 :
         begin
           io_e <= 1'bz;
         end
         2'b11 :
         begin
           #0 ->Event_KEEP;
         end
         default : 
	 begin
	   io_e <= 1'bx; 	 
	 end
       endcase 
     end
   end

   always @(io)
   begin 
     if (e_tmp==1'b0)
     begin
       case ({pu_tmp,pd_tmp})
         2'b10 :
         begin
           if (io===1'b1)
           begin
             disable BlockPU;
             io_e = 1'b1;
           end
           else if (io===1'b0)
           begin
             disable BlockPU;
             io_e = 1'bz;
           end
           else if (io===1'bx)
           begin
             disable BlockPU;
             io_e = 1'bz;
           end
           else if (io===1'bz)
           begin
             disable BlockPU;
             io_e = 1'bz;
