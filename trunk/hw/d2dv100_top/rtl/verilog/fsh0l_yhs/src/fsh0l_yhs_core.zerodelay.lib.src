//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module DLAHRBLBHMX0P4 (Q, QB, D, G, RB);
   reg flag; // Notifier flag
   output Q, QB;
   input D, G, RB;

   wire d_G, d_D;

//Function Block
`protect
   buf g3(Q, qt);
   not g1(QB, qt);
   dlhrb_udp g2(qt,  d_D,  d_G,  RB,  flag );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge G *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge G *> (Q :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge G *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge G *> (QB :1'bx)) = (20, 20);
     `endif
      (D *> Q) = (0.0, 0.0);
      (D *> QB) = (0.0, 0.0);
      (RB *> Q) = (0.0, 0.0);
      (RB *> QB) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_G = 0.0;
      specparam hold_D_G = 0.0;
      $setuphold(negedge G &&& RB, posedge D, 0.0, 0.0, flag,,,d_G, d_D);
      $setuphold(negedge G &&& RB, negedge D, 0.0, 0.0, flag,,,d_G, d_D);

      //  Recovery Time
      specparam recovery_RB_G = 0.0;
      specparam recovery_G_RB = 0.0;
      $recrem(posedge RB, negedge G &&& d_D, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_pos_G = 0.0;
      specparam mpw_neg_RB = 0.0;
      $width(posedge G, 0.0, 0, flag);
      $width(negedge RB, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


