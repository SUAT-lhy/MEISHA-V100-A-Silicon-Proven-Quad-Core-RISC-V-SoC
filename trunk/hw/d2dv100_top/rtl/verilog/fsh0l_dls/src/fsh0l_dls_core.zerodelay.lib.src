`timescale 10ps/1ps
`celldefine
module LVLUDLELMX1 (O, I);
   output O;
   input I;
   

//Function Block
`protect
   buf g1(O, I);

//Specify Block
   specify

      //  Module Path Delay
      (I *> O) = (0.0, 0.0);
   endspecify
`endprotect
endmodule
`endcelldefine


