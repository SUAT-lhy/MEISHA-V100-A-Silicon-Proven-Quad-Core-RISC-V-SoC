   input D, CK, TD, SB, SEL;
   supply1 vcc;
   reg D_flag;
   wire d_CK, d_D, d_SEL, d_TD, D_flag1;

//Function Block
`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3(Q, qt);
   dffrsb_udp g1(qt,  d1,  d_CK,  vcc,  SB,  flag );
   mux2_udp g4(d1,  d_D,  d_TD,  SEL_ );

//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D;
    else
        D_flag = d_TD;
  end


//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge SB *> (Q :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      $setuphold(posedge CK &&& SB, posedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& SB, negedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& SB, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& SB, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge SB, posedge CK &&& ~D_flag1, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


