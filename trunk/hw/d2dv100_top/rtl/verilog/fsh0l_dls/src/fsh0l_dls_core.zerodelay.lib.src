    end
  always @(D_ or QB or RB_)
    begin
      if ((RB_ === 1'b1) && (!D_ !== QB))
         LD_flag1 = 1'b1;
      else
         LD_flag1 = 1'b0;
    end
  always @(di)
    begin
      if (di===1'b1)
         RB_flag1 = 1'b1;
      else
         RB_flag1 = 1'b0;
    end

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (QB :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (QB :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
