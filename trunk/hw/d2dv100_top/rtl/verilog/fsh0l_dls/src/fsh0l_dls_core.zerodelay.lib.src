//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGQDFFRBLELMX1 (Q, D, CK, RB);
   reg flag; // Notifier flag
   output Q;
   input D, CK, RB;
   supply1 vcc;

   wire d_CK, d_D;

//Function Block
`protect
   buf g2(Q, qt);
   dffrsb_udp g1(qt,  d_D,  d_CK,  RB,  vcc,  flag );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      $setuphold(posedge CK &&& RB, posedge D, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D, 0.0, 0.0, flag,,,d_CK, d_D);

      //  Recovery Time
      specparam recovery_RB_CK = 0.0;
      specparam recovery_CK_RB = 0.0;
      $recrem(posedge RB, posedge CK &&& d_D, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge RB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


