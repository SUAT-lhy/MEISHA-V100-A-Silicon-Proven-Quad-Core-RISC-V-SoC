`celldefine
module MGQDFFSBLELMX1 (Q, D, CK, SB);
   reg flag; // Notifier flag
   output Q;
   input D, CK, SB;
   supply1 vcc;
   reg D_flag;
   wire d_CK, d_D;

//Function Block
`protect
   
   buf g3(Q, qt);
   dffrsb_udp g1(qt,  d_D,  d_CK,  vcc,  SB,  flag );


//Specify Block
