              io_e = 1'b0;
            end
            else if (io===1'b1)
            begin
              disable BlockPD;
              io_e = 1'bz;
            end
            else if (io===1'bx)
            begin
              disable BlockPD;
              io_e = 1'bz;
            end
            else if (io===1'bz)
            begin
              disable BlockPD;
              io_e = 1'bz;
              #0 ->Event_PD;
            end
          end
          3'b001,
          3'b111 :
          begin
            // do nothing;
          end
          default : 
          begin
  	  io_e = 1'bx; 	 
          end
        endcase
      end
    end
  end

  always @(Event_DisableAll)
