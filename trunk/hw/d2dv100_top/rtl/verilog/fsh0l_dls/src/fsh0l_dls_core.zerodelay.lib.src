//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGGCKESLELMX1 (Q, E, TE, CK);
   reg flag; // Notifier flag
   output Q;
   input E, TE, CK;
   supply1 vcc;

   wire d_CK, d_E, d_TE;

//Function Block
`protect

   not g1(ckb,  d_CK );
   or g2(or_o, d_TE, d_E);
   dlhrb_udp g3(qt,  or_o, ckb,  vcc,  flag );
   and g4(Q, d_CK, qt);
   
//Specify Block
   specify

      //  Module Path Delay
      (CK *> Q) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_E_CK = 0.0;
      specparam hold_E_CK = 0.0;
      specparam setup_TE_CK = 0.0;
      specparam hold_TE_CK = 0.0;
      $setuphold(posedge CK, posedge E &&& ~TE, 0.0, 0.0, flag,,,d_CK, d_E);
      $setuphold(posedge CK, negedge E &&& ~TE, 0.0, 0.0, flag,,,d_CK, d_E);
      $setuphold(posedge CK, posedge TE &&& ~E, 0.0, 0.0, flag,,,d_CK, d_TE);
      $setuphold(posedge CK, negedge TE &&& ~E, 0.0, 0.0, flag,,,d_CK, d_TE);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine
//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGGCKESLELMX2 (Q, E, TE, CK);
   reg flag; // Notifier flag
   output Q;
   input E, TE, CK;
   supply1 vcc;

   wire d_CK, d_E, d_TE;

//Function Block
`protect

   not g1(ckb,  d_CK );
   or g2(or_o, d_TE, d_E);
   dlhrb_udp g3(qt,  or_o, ckb,  vcc,  flag );
   and g4(Q, d_CK, qt);
   
//Specify Block
   specify

      //  Module Path Delay
      (CK *> Q) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_E_CK = 0.0;
      specparam hold_E_CK = 0.0;
      specparam setup_TE_CK = 0.0;
      specparam hold_TE_CK = 0.0;
      $setuphold(posedge CK, posedge E &&& ~TE, 0.0, 0.0, flag,,,d_CK, d_E);
      $setuphold(posedge CK, negedge E &&& ~TE, 0.0, 0.0, flag,,,d_CK, d_E);
      $setuphold(posedge CK, posedge TE &&& ~E, 0.0, 0.0, flag,,,d_CK, d_TE);
      $setuphold(posedge CK, negedge TE &&& ~E, 0.0, 0.0, flag,,,d_CK, d_TE);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine
