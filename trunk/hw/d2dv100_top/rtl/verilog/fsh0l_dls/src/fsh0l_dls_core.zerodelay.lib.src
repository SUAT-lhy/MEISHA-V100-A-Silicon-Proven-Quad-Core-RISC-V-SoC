      ifnone (posedge A1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 0) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 1) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 1) (B1 *> (O :1'bx)) = (0.0, 0.0);
