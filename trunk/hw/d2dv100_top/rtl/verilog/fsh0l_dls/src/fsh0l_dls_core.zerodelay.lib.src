//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module MGAOI22LELMX1 (O, A1, A2, B1, B2);
   output O;
   input A1, A2, B1, B2;

//Function Block
`protect
   and g1(o1, B1, B2);
   and g3(o2, A1, A2);
   nor g2(O, o1, o2);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B1 == 0 && B2 == 0) (A1 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 1 && B2 == 0) (A1 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 0 && B2 == 1) (A1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge A1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A1 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 0 && B2 == 1) (A2 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 0 && B2 == 0) (A2 *> (O :1'bx)) = (0.0, 0.0);
      if (B1 == 1 && B2 == 0) (A2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge A2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge A2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 1) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 0) (B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 0) (B1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B1 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 0) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 1 && A2 == 0) (B2 *> (O :1'bx)) = (0.0, 0.0);
      if (A1 == 0 && A2 == 1) (B2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge B2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge B2 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


