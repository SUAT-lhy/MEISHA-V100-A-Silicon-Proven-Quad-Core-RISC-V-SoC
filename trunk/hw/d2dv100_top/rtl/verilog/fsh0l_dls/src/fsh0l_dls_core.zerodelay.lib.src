`celldefine
module QDSFZLELMX0P7 (Q, D, TD, CK, SEL, SL);
  output Q;
  input D, TD, CK, SEL, SL;
  reg D_flag, flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_TD, d_SEL, d_SL, D_flag1;
  wire on1, on2, oa1, om1;

//Function Block
`protect

     buf b1 (SEL_, d_SEL );  //Avoid MIPD.
     not n1 (on1, d_CK);
     not n2 (on2, d_SL);
     and a1 (oa1, d_CK, on2);
     mux2_udp m1 (om1,  d_D,  d_TD,  SEL_ );
     dlhrsb_udp dlh1 (odlh1, om1, on1, vcc, vcc, flag ); 
     dlhrsb_udp dlh2 (qt, odlh1, oa1, vcc, vcc, flag ); 
     buf (Q, qt);

//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D or d_TD or SL)
  begin
    if (SL === 1'b0)
      if (SEL_ === 1'b0)
         D_flag = d_D;
      else
         D_flag = d_TD;
    else
      D_flag = 0;     
  end



//Specify Block
  specify 
     `ifdef allzero
            (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
            (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
//  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_CK_SL = 0.0;
      specparam hold_CK_SL = 0.0;
      $setuphold(posedge CK, posedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge SL, posedge CK, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, posedge CK, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK, 0.0, 0.0, flag,,,d_SL, d_CK);

      $recrem(negedge SL, negedge CK, 0.0, 0.0, flag);
      $recrem(posedge SL, posedge CK, 0.0, 0.0, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);

  endspecify  
 
`endprotect
endmodule
`endcelldefine
//-- FTC standard cell revision 1.1 --//
