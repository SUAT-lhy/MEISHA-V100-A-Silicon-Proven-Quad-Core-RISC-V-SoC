   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  SB,  flag1 );
   mux2_udp g7(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g8(data2,  d_D2,  qt1,  SEL_ );

