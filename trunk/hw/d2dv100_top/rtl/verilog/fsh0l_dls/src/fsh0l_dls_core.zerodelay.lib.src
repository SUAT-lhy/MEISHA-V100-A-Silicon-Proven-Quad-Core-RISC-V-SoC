`celldefine
module QDSFZRSBLELMX0P7 (Q, D, TD, CK, SEL, RB, SB, SL);
  output Q;
  input D, TD, CK, SEL, RB, SB, SL;
  reg flag, D_flag; // Notifier flag
  supply1 vcc;
  wire d_CK, d_D, d_TD, d_SEL, d_SL, on1, on2, on3, on4, on5, on6, D_flag1;
  wire oa1, oa2, oa3;

//Function Block
`protect
   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_RB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   not n4 (on4, d_SB);
   not n5 (on5, odlh1);
   not n6 (on6, qt);
   mux2_udp m1 (om1, d_D, d_TD, SEL_);
    
   nand a1 (oa1, on1, on2);
   and a2  (oa2, d_RB, on2, d_SB, d_CK); 
   nand a3 (oa3, d_RB, on2, on4); 
   dlhrsb_udp dlh1 (odlh1, om1, on3, d_RB, d_SB, flag ); 
   dlhrsb_udp dlh2 (qt, on5, oa2, oa3, oa1, flag ); 
   buf (Q, on6);

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1 = D_flag;
always @(SEL_ or d_D or d_TD or SL)
  begin
    if (SL === 1'b0)
      if (SEL_ === 1'b0)
         D_flag = d_D;
      else
         D_flag = d_TD;
    else
      D_flag = 0;     
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");




//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
      (negedge RB *> (Q :1'bx)) = (0.0, 0.0);
      (negedge SB *> (Q :1'bx)) = (0.0, 0.0);

//  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_CK_SL = 0.0;
      specparam hold_CK_SL = 0.0;
      specparam setup_RB_SL = 0.0;
      specparam hold_RB_SL = 0.0;
      specparam setup_SB_SL = 0.0;
      specparam hold_SB_SL = 0.0;
      $setuphold(posedge CK &&& _SB_and_RB_, posedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      //$setuphold(posedge CK &&& _SB_and_RB_, posedge SL, setup_SL_CK, hold_SL_CK, flag,,,d_CK, d_SL);
      $setuphold(posedge SL, posedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& _SB_and_RB_, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, posedge RB, 0.0, 0.0,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
       
