`celldefine
module OAI22M2HLELMX6 (O, A1, A2, B1, B2);
   output O;
   input A1, A2, B1, B2;

//Function Block
`protect
   or g1(o1, B1, B2);
   or g2(o2, A1, A2);
   nand g3(O, o1, o2);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (B1 == 0 && B2 == 1) (A2 *> (O :1'bx)) = (0.0, 0.0);
