   buf g6(Q4, qt4);
   dffrsb_udp g1(qt1,  d_D1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g2(qt2,  d_D2,  d_CK,  vcc,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  vcc,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  vcc,  vcc,  flag3 );

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
