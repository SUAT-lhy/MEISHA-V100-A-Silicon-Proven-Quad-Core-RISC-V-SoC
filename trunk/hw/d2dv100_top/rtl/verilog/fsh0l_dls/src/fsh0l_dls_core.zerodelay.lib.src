   dlhrsb_udp dlh1 (odlh1, om1, on3, vcc, d_SB, flag ); 
   dlhrsb_udp dlh2 (qt, odlh1, oa2, vcc, ona1, flag ); 
   buf (Q, qt);
   


//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D or d_TD or SL)
  begin
  if (SL === 1'b0)
    if (SEL_ === 1'b0)
        D_flag = d_D;
    else
        D_flag = d_TD;
  else
    D_flag = 0;     
  end

//Specify Block
  specify
     `ifdef allzero
            (posedge CK *> (Q :1'bx)) = (0.0, 0.0);
     `else
            (posedge CK *> (Q :1'bx)) = (20, 20);
     `endif
    (negedge SB *> (Q :1'bx)) = (0.0, 0.0);
//  Setup and Hold Time
      specparam setup_D_CK = 0.0;
      specparam hold_D_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_CK_SL = 0.0;
      specparam hold_CK_SL = 0.0;
      specparam setup_SB_SL = 0.0;
      specparam hold_SB_SL = 0.0;
      $setuphold(posedge CK &&& SB, posedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& SB, negedge D &&& ~SEL, 0.0, 0.0, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& SB, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, posedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& SB, negedge TD &&& SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge SL, posedge CK &&& SB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& SB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
       
      $setuphold(negedge SL, posedge CK &&& SB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& SB, 0.0, 0.0, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      $setuphold(negedge SL, posedge SB, 0.0, 0.0,flag,,,d_SL, d_SB);
      //  Recovery Time
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge SB, posedge CK, 0.0, 0.0, flag);
      $recrem(negedge SL, negedge CK, 0.0, 0.0, flag);
      $recrem(posedge SL, posedge CK, 0.0, 0.0, flag);


      

      //  Minimum Pulse Width
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);

  endspecify

`endprotect
endmodule
`endcelldefine
