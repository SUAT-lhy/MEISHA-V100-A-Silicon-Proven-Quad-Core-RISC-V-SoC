      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D2 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D2 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D3 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D3 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D4 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D4 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_D1_AND_SEL, posedge TD &&& ENABLE_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SEL, negedge TD &&& ENABLE_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      $setuphold(posedge CK, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);

      //  Minimum Pulse Width
      specparam mpw_pos_CK = 0.0;
      specparam mpw_neg_CK = 0.0;
      $width(posedge CK, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
