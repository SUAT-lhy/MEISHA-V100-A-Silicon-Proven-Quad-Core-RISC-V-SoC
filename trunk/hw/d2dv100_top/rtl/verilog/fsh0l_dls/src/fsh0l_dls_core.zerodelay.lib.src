`celldefine
module QDLAHSLELMX2 (Q, D, G, S);
   reg flag; // Notifier flag
   input D, G, S;
   output Q;

   wire d_G, d_D;

//Function Block
`protect
   dlhsb_udp g1(qt,  d_D,  d_G,  sb,  flag );
   buf g2(Q, qt);
   not g4(sb, S);

//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge G *> (Q :1'bx)) = (0.0, 0.0);
     `else
              (posedge G *> (Q :1'bx)) = (20, 20);
     `endif
      (D *> Q) = (0.0, 0.0);
      (S *> Q) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D_G = 0.0;
      specparam hold_D_G = 0.0;
      $setuphold(negedge G &&&  ~S, posedge D, 0.0, 0.0, flag,,,d_G, d_D);
      $setuphold(negedge G &&&  ~S, negedge D, 0.0, 0.0, flag,,,d_G, d_D);

      //  Recovery Time
      specparam recovery_S_G = 0.0;
      specparam recovery_G_S = 0.0;
      $recrem(negedge S, negedge G &&& ~d_D, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_pos_G = 0.0;
      specparam mpw_pos_S = 0.0;
      $width(posedge G, 0.0, 0, flag);
      $width(posedge S, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


