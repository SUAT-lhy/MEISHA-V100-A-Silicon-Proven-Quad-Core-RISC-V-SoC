      if (I1 == 0 && I3 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I3 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I3 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I3 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0 && I3 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 1 && I3 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0 && I3 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 1 && I3 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I1 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XOR3LELMX2 (O, I1, I2, I3);
   output O;
   input I1, I2, I3;

//Function Block
`protect
   xor g1(O, I1, I2, I3);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (I1 == 0 && I2 == 0) (I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I2 == 0) (I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I2 == 1) (I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I2 == 1) (I3 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I3 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I3 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I3 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I3 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I3 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0 && I3 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 1 && I3 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0 && I3 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 1 && I3 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I1 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module XOR3LELMX3 (O, I1, I2, I3);
   output O;
   input I1, I2, I3;

//Function Block
`protect
   xor g1(O, I1, I2, I3);

//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (I1 == 0 && I2 == 0) (I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I2 == 0) (I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I2 == 1) (I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I2 == 1) (I3 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I3 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I3 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I3 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I3 == 1) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 0 && I3 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I1 == 1 && I3 == 0) (I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I2 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I2 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0 && I3 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 1 && I3 == 1) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 0 && I3 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      if (I2 == 1 && I3 == 0) (I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (posedge I1 *> (O :1'bx)) = (0.0, 0.0);
      ifnone (negedge I1 *> (O :1'bx)) = (0.0, 0.0);

      //  Module Path Delay
   endspecify
`endprotect
endmodule
`endcelldefine



