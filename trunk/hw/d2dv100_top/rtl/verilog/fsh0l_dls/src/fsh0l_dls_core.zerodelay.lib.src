      (negedge SB *> (Q1 :1'bx)) = (0.0, 0.0);
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif
      (negedge SB *> (Q2 :1'bx)) = (0.0, 0.0);

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D1 &&& ENABLE_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D1 &&& ENABLE_SB, 0.0, 0.0, flag,,,d_CK, d_D1);
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_SB, posedge D2 &&& ENABLE_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB, negedge D2 &&& ENABLE_SB, 0.0, 0.0, flag1,,,d_CK, d_D2);
      //  Recovery Time
      specparam recovery_SB_CK = 0.0;
      specparam recovery_CK_SB = 0.0;
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_OR_NOT_D1, posedge CK &&& ENABLE_D1_AND_NOT_D2_OR_NOT_D1, 0.0, 0.0, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 0.0;
      specparam mpw_neg_CK = 0.0;
      specparam mpw_pos_CK = 0.0;
      $width(negedge SB, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
      $width(posedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFZNLELMX1 (Q1, Q2, D1, D2, TD, CK, SEL);
   reg flag, flag1; // Notifier flag
   output Q1, Q2;
   input D1, D2, CK, TD, SEL;
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_TD, d_SEL;

//Function Block
`protect
   buf g3(Q1, qt1);
   buf g4(Q2, qt2);
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc,  vcc,  flag1 );
   mux2_udp g5(data1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g6(data2,  d_D2,  qt1,  d_SEL );

	// Additional timing wires
	wire D1__bar;
	wire ENABLE_D1_AND_SEL;
	wire ENABLE_NOT_D1_AND_SEL;
	wire ENABLE_NOT_SEL;
	wire ENABLE_NOT_SEL_AND_NOT_TD, ENABLE_NOT_SEL_AND_TD, SEL__bar;
	wire TD__bar;

	// Additional timing gates
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
	and (ENABLE_NOT_SEL_AND_TD, SEL__bar, TD);
	and (ENABLE_NOT_SEL_AND_NOT_TD, SEL__bar, TD__bar);
	not (ENABLE_NOT_SEL, SEL);
	and (ENABLE_D1_AND_SEL, D1, SEL);
	and (ENABLE_NOT_D1_AND_SEL, D1__bar, SEL);


//Specify Block
   specify

      //  Module Path Delay
     `ifdef allzero
              (posedge CK *> (Q1 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q1 :1'bx)) = (20, 20);
     `endif
     `ifdef allzero
              (posedge CK *> (Q2 :1'bx)) = (0.0, 0.0);
     `else
              (posedge CK *> (Q2 :1'bx)) = (20, 20);
     `endif

      //  Setup and Hold Time
      specparam setup_D1_CK = 0.0;
      specparam hold_D1_CK = 0.0;
      specparam setup_D2_CK = 0.0;
      specparam hold_D2_CK = 0.0;
      specparam setup_TD_CK = 0.0;
      specparam hold_TD_CK = 0.0;
      specparam setup_SEL_CK = 0.0;
      specparam hold_SEL_CK = 0.0;
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_TD, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_TD, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 0.0, 0.0, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 0.0, 0.0, flag,,,d_CK, d_D1);

      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D2 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D2 &&& ENABLE_NOT_SEL, 0.0, 0.0, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_D1_AND_SEL, posedge TD &&& ENABLE_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SEL, negedge TD &&& ENABLE_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SEL, 0.0, 0.0, flag,,,d_CK, d_TD);

      $setuphold(posedge CK, posedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL, 0.0, 0.0, flag,,,d_CK, d_SEL);



      //  Minimum Pulse Width
      specparam mpw_pos_CK = 0.0;
      specparam mpw_neg_CK = 0.0;
      $width(posedge CK, 0.0, 0, flag);
      $width(negedge CK, 0.0, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
