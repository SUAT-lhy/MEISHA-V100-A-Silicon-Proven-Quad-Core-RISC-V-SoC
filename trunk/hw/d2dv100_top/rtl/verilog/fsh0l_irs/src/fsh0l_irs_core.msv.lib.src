`resetall
`timescale 10ps/1ps
`celldefine
module OCCDFTLHRMX1 (DFTCK, SCK, CAPEN, SEN, PLLCK, BPOCC, VCCNW, GND, VCC);
   inout VCCNW;
   input CAPEN;
   output DFTCK;
   input PLLCK;
   inout GND;
   inout VCC;
   input SCK;
   input BPOCC;
   input SEN;
   reg flag; // Notifier flag
   supply1 vcc;

   //wire d_CK, d_D, d_SEL, d_TD;

//Function Block
`protect
   not g0(i0, SEN);
   and g1(i1, CAPEN,i0);   

   dffrsb_udp g2(qt1,  i1,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g3(qt2,  qt1,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g4(qt3,  qt2,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g5(qt4,  qt3,  PLLCK,  vcc,  vcc,  flag );
   dffrsb_udp g6(qt5,  qt4,  PLLCK,  vcc,  vcc,  flag );

   not g7(i2, qt5);
   and g8(i3, qt3,i2); 

   not g9(ckb,  PLLCK );
   or g10(or_o, 1'b0, i3);
   dlhrb_udp g11(qt6,  or_o, ckb,  vcc,  flag );
   and g12(i4, PLLCK, qt6);

   nor g13(i5, SEN, BPOCC);
   mux2_udp g15 (DFTCK_pg_tmp, SCK, i4, i5);
   assign DFTCK = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? DFTCK_pg_tmp : 1'bx;

//Specify Block
   specify

      //  Module Path Delay
      (BPOCC *> DFTCK) = (1.00, 1.00);
      (PLLCK *> DFTCK) = (1.00, 1.00);
      (SCK *> DFTCK) = (1.00, 1.00);
      (SEN *> DFTCK) = (1.00, 1.00);

      //  Setup and Hold Time
      //specparam setup_D_CK = 9.20;
      //specparam hold_D_CK = 0.00;
      //specparam setup_SEL_CK = 8.60;
      //specparam hold_SEL_CK = 0.00;
      //specparam setup_TD_CK = 10.20;
