      //  Minimum Pulse Width
      specparam mpw_neg_RB = 3.94;
      specparam mpw_neg_CK = 14.51;
      specparam mpw_pos_CK = 13.64;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine


