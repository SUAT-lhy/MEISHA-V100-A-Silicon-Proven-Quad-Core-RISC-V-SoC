//Function Block
`protect

   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_RB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   mux2_udp m1 (om1,  d_D,  d_TD, SEL_ );
    
   nand a1 (ona1, on1, on2);
   and a2 (oa2, d_RB, on2, d_CK); 
