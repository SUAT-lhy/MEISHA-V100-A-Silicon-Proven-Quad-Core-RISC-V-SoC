      (posedge CK *> (QB2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB2 :1'bx)) = (1.00, 1.00);


      //  Setup and Hold Time
      specparam setup_D1_CK = 6.90;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 6.90;
      specparam hold_D2_CK = 0.00;
      specparam setup_SEL_CK = 9.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 9.50;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& SB, posedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& SB, negedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& SB, posedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& SB, negedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& SB, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& SB, negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_SB_CK = 1.61;
      specparam recovery_CK_SB = 4.00;
      $recrem(posedge SB, posedge CK, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 15.58;
      specparam mpw_neg_CK = 15.85;
      specparam mpw_pos_CK = 15.15;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine

