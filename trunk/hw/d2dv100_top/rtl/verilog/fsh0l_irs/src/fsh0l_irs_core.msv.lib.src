      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.30;
      specparam hold_D2_CK = 0.00;
      specparam setup_TD_CK = 10.30;
      specparam hold_TD_CK = 0.00;
      specparam setup_SEL_CK = 8.60;
      specparam hold_SEL_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);

