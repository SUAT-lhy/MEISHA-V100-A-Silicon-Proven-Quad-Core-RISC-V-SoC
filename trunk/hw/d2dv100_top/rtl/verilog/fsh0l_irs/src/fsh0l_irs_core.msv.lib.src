      if (A1 == 1 && A2 == 1 && B1 == 1) (B2 *> (O :1'bx)) = (1.00, 1.00);
      if (A1 == 0 && A2 == 0 && B1 == 1) (B2 *> (O :1'bx)) = (1.00, 1.00);
      ifnone (posedge B2 *> (O :1'bx)) = (1.00, 1.00);
      ifnone (negedge B2 *> (O :1'bx)) = (1.00, 1.00);

      //  Module Path Delay
      (A1 *> (O :1'bx)) = (1.00, 1.00);
      (A2 *> (O :1'bx)) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine
