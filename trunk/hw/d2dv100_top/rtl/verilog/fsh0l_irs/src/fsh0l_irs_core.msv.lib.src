module QBDFFRBNLHRMX0P4 (QB, D, CK, RB, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input D;
   inout GND;
   input CK;
   inout VCC;

   reg flag; // Notifier flag
   supply1 vcc;
//   reg D_flag;
//   wire D_flag1;

   wire d_CK, d_D;

//Function Block
`protect
   not g3 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dffrsb_udp g2(qt,  d_D,  d_CK,  RB,  vcc,  flag );
   

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 6.30;
      specparam hold_D_CK = 0.00;
      
      $setuphold(posedge CK &&& RB, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      
      //  Recovery Time
