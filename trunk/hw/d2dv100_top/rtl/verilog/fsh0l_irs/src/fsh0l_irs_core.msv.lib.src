      $setuphold (posedge CK &&& ENABLE_SB_AND_NOT_SEL_AND_TD,     negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&& ENABLE_SB_AND_NOT_SEL_AND_NOT_TD, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&& ENABLE_SB_AND_NOT_SEL_AND_NOT_TD, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&& ENABLE_NOT_D_AND_SB_AND_TD,       posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&& ENABLE_NOT_D_AND_SB_AND_TD,       negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&& ENABLE_D_AND_SB_AND_NOT_TD,       posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&& ENABLE_D_AND_SB_AND_NOT_TD,       negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&& ENABLE_NOT_D_AND_SB_AND_SEL,      posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
