   dffrsb_udp g3(qt1,  d1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g4(qt2,  d2,  d_CK,  RB,  vcc,  flag1 );

   mux2_udp g1(d1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g2(d2,  d_D2,  qt1,   d_SEL );

//Append pseudo gate for timing violation checking
assign D_flag1   = D_flag;    // For Model-Tec complier
always @(SEL_ or d_D1 or d_D2 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 | d_D2;
    else
