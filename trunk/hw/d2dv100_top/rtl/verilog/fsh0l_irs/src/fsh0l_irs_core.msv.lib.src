//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDSFZRSBLHRMX2  (RB, VCCNW, SB, SL, TD, D, Q, GND, GNDG, CK, VCCG, VCC, SEL);
   input RB;
   inout VCCNW;
   input SB;
   input SL;
   input TD;
   input D;
   output Q;
   inout GND;
   inout GNDG;
   input CK;
   inout VCCG;
   inout VCC;
   input SEL;
   supply0 GNDPW;

  reg flag, D_flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_TD, d_SEL, d_SL, d_RB, d_SB, D_flag1;
  wire on1, on2, on3, on4, on5, on6, oa1, oa2, oa3, om1;
  wire poweron, Q1;
  reg main;

//Function Block
`protect
   buf b1 (SEL_, d_SEL );  //Avoid MIPD.
   not n1 (on1, d_RB);
   not n2 (on2, d_SL);
   not n3 (on3, d_CK);
   not n4 (on4, d_SB);
   not n5 (on5, odlh1);
   not n6 (on6, qt);
   mux2_udp m1 (om1, d_D, d_TD, SEL_);
    
   nand a1 (oa1, on1, on2);
   and a2  (oa2, d_RB, on2, d_SB, d_CK); 
   nand a3 (oa3, d_RB, on2, on4); 
   dlhrsb_udp dlh1 (odlh1, om1, on3, d_RB, d_SB, flag ); 
   dlhrsb_udp dlh2 (qt, on5, oa2, oa3, oa1, flag ); 
   buf (Q_temp, on6);

//Append pseudo gate for timing violation checking
   and (_SB_and_RB_, SB, RB);
   or (_SB_or_RB_, SB, RB);
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D or d_TD or SL)
   begin
    if (SL === 1'b0)
      if (SEL_ === 1'b0)
         D_flag = d_D;
      else
         D_flag = d_TD;
    else
      D_flag = 0;     
    end

//Timing violation checking statement
   always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
    $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//PG_pin
   assign poweron = ((VCCG === 1'b1) && (GNDG === 1'b0) && (VCCNW === 1'b1) && (GNDPW === 1'b0));
   assign Q1 = ((VCC === 1'b1) && (GND === 1'b0));
   
   always @ (*)
    begin
       if ( poweron == 1 ) begin
          if ( Q1 == 1) begin
             main <= Q_temp;                      
          end
          else begin
             main <= 1'bx;
          end
       end
       else begin
          main <= 1'bx;
       end
   end
   assign Q = main;

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q :1'bx)) = (1.00, 1.00);

//  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      specparam setup_CK_SL = 0.00;
      specparam hold_CK_SL = 0.00;
      specparam setup_RB_SL = 0.00;
      specparam hold_RB_SL = 0.00;
      specparam setup_SB_SL = 0.00;
      specparam hold_SB_SL = 0.00;
      $setuphold(posedge CK &&& _SB_and_RB_, posedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge D &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& _SB_and_RB_, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      //$setuphold(posedge CK &&& _SB_and_RB_, posedge SL, setup_SL_CK, hold_SL_CK, flag,,,d_CK, d_SL);
      $setuphold(posedge SL, posedge CK &&& _SB_and_RB_, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge CK &&& _SB_and_RB_, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(posedge SL, negedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, posedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
      $setuphold(posedge SL, negedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      $setuphold(posedge SL, posedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
       
      $setuphold(negedge SL, posedge CK &&& _SB_and_RB_, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge CK &&& _SB_and_RB_, 1.00, 1.00, flag,,,d_SL, d_CK);
      $setuphold(negedge SL, negedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, posedge RB, 1.00, 1.00,flag,,,d_SL, d_RB);
      $setuphold(negedge SL, negedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);
      $setuphold(negedge SL, posedge SB, 1.00, 1.00,flag,,,d_SL, d_SB);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
      $recrem(posedge RB, posedge CK, 1.00, 1.00, flag);
      $recrem(posedge SB, posedge CK, 1.00, 1.00, flag);
      $recrem(negedge SL, negedge CK, 1.00, 1.00, flag);
      $recrem(posedge SL, posedge CK, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
    
`endprotect
endmodule
`endcelldefine
