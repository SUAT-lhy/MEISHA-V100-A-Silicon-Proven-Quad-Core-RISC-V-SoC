//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QDFFRSBNLHRMX0P4 (Q, D, CK, RB, SB, VCCNW, GND, VCC);
   input RB;
   inout VCCNW;
   input SB;
   input D;
   output Q;
   inout GND;
   input CK;
   inout VCC;
   reg flag; // Notifier flag

   wire d_CK, d_D;

//Function Block
`protect
   buf g2 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   dffrsb_udp g1(qt,  d_D,  d_CK,  RB,  SB,  flag );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 5.90;
      specparam hold_D_CK = 0.00;
      $setuphold(posedge CK &&& _SB_and_RB_, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& _SB_and_RB_, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 9.50;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.26;
      $recrem(posedge RB, posedge CK &&& d_D, 1.00, 1.00, flag);
      $recrem(posedge SB, posedge CK &&& ~d_D, 1.00, 1.00, flag);



      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
