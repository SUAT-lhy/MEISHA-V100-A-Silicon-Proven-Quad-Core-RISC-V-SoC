   wire ENABLE_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD;
   wire ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_NOT_SEL_AND_TD;
   wire ENABLE_NOT_D_AND_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_SEL_AND_TD;
   wire ENABLE_SB_AND_NOT_SEL_AND_TD;
   wire ENABLE_SB_AND_NOT_SEL_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_SB_AND_TD;
   wire ENABLE_D_AND_SB_AND_NOT_TD;
   wire ENABLE_NOT_D_AND_SB_AND_SEL;
   wire ENABLE_D_AND_SB_AND_SEL;

   assign ENABLE_CK_AND_D_AND_NOT_SEL_AND_NOT_TD = CK & D & !SEL & !TD;
   assign ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD = CK & D & !SEL & TD;
   assign ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD = CK & D & SEL & !TD;
   assign ENABLE_CK_AND_D_AND_SEL_AND_TD = CK & D & SEL & TD;
   assign ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD = CK & !D & !SEL & !TD;
   assign ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_TD = CK & !D & !SEL & TD;
   assign ENABLE_CK_AND_NOT_D_AND_SEL_AND_NOT_TD = CK & !D & SEL & !TD;
   assign ENABLE_CK_AND_NOT_D_AND_SEL_AND_TD = CK & !D & SEL & TD;
   assign ENABLE_D_AND_NOT_SEL_AND_NOT_TD = D & !SEL & !TD;
   assign ENABLE_D_AND_NOT_SEL_AND_TD = D & !SEL & TD;
   assign ENABLE_D_AND_SEL_AND_NOT_TD = D & SEL & !TD;
   assign ENABLE_D_AND_SEL_AND_TD = D & SEL & TD;
   assign ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD = !CK & D & !SEL & !TD;
   assign ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD = !CK & D & !SEL & TD;
   assign ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD = !CK & D & SEL & !TD;
   assign ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD = !CK & D & SEL & TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD = !CK & !D & !SEL & !TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD = !CK & !D & !SEL & TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD = !CK & !D & SEL & !TD;
   assign ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD = !CK & !D & SEL & TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD = !D & !SEL & !TD;
   assign ENABLE_NOT_D_AND_NOT_SEL_AND_TD = !D & !SEL & TD;
   assign ENABLE_NOT_D_AND_SEL_AND_NOT_TD = !D & SEL & !TD;
   assign ENABLE_NOT_D_AND_SEL_AND_TD = !D & SEL & TD;
   assign ENABLE_SB_AND_NOT_SEL_AND_TD = SB & !SEL & TD;
   assign ENABLE_SB_AND_NOT_SEL_AND_NOT_TD = SB & !SEL & !TD;
   assign ENABLE_NOT_D_AND_SB_AND_TD = !D & SB & TD;
   assign ENABLE_D_AND_SB_AND_NOT_TD = D & SB & !TD;
   assign ENABLE_NOT_D_AND_SB_AND_SEL = !D & SB & SEL;
   assign ENABLE_D_AND_SB_AND_SEL = D & SB & SEL;

//Function Block
`protect
   buf (SEL_, d_SEL );  //Avoid MIPD.

	mux2_udp m1 (d1,  d_D,  d_TD,  SEL_ );
   dffrsb_udp q1 (qt_1,  d1,   d_CK,  vcc,  SB,  flag );
   dffrsb_udp q2 (qt_2,  qt_1, d_CK,  vcc,  SB,  flag );

	buf  (Q_pg_tmp, qt_2);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;

//Append pseudo gate for timing violation checking
	assign D_flag1 = D_flag;
	always @(SEL_ or d_D or d_TD) begin
		if (SEL_ === 1'b0)
			D_flag = d_D;
		else
      	D_flag = d_TD;
	end


//Specify Block
   specify

      //  Module Path Delay (state dependent)
      if (D == 0 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 0 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 1 && TD == 0) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 0 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 0 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (D == 1 && SEL == 1 && TD == 1) (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      ifnone (posedge CK *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 1 && SEL == 1 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 0 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 1 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 0 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 0 && SEL == 1 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 1 && SEL == 0 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 1 && SEL == 1 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 0 && SEL == 1 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 1 && SEL == 1 && TD == 0) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 0 && SEL == 0 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 0 && SEL == 1 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 1 && SEL == 0 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 0 && SEL == 0 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 1 && SEL == 0 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 1 && D == 0 && SEL == 1 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      if (CK == 0 && D == 1 && SEL == 1 && TD == 1) (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      ifnone (negedge SB *> (Q:1'bx)) = (1.00, 1.00);
      //  Module Path Delay


      //  Setup and Hold Time
      $setuphold (posedge CK &&&  ENABLE_SB_AND_NOT_SEL_AND_TD,     posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_SB_AND_NOT_SEL_AND_TD,     negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_SB_AND_NOT_SEL_AND_NOT_TD, posedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_SB_AND_NOT_SEL_AND_NOT_TD, negedge D, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_SB_AND_TD,       posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_SB_AND_TD,       negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_D_AND_SB_AND_NOT_TD,       posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_D_AND_SB_AND_NOT_TD,       negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_SB_AND_SEL,      posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_NOT_D_AND_SB_AND_SEL,      negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_D_AND_SB_AND_SEL,          posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold (posedge CK &&&  ENABLE_D_AND_SB_AND_SEL,          negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      $recrem (posedge SB, posedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem (posedge SB, posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem (posedge SB, posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem (posedge SB, posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      $width (negedge SB, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_NOT_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_NOT_CK_AND_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_NOT_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge SB &&& ENABLE_CK_AND_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);

      $width (negedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (negedge CK &&& ENABLE_D_AND_SEL_AND_TD, 1.00, 0, flag);
      
      $width (posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_NOT_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_SEL_AND_NOT_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_D_AND_SEL_AND_TD, 1.00, 0, flag);
      $width (posedge CK &&& ENABLE_NOT_D_AND_NOT_SEL_AND_NOT_TD, 1.00, 0, flag);
   endspecify
`endprotect
