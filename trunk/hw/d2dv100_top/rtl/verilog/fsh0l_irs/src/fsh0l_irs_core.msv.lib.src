      $setuphold(posedge CK &&& RB, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& RB, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 63.26;
      specparam recovery_CK_RB = 31.03;
      $recrem(posedge RB, posedge CK &&& flag_two, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_CK = 32.58;
      specparam mpw_pos_CK = 50.23;
      specparam mpw_neg_RB = 106.96;
      $width(negedge CK, 1.00, 0, flag);
