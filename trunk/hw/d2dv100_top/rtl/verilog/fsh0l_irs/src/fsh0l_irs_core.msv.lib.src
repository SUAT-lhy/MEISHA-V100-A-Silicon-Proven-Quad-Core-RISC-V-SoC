//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module AO22QDFFLHRMX0P4 (Q, A1, A2, B1, B2, CK, VCCNW, GND, VCC);
   inout VCCNW;
   output Q;
   inout GND;
   input A1;
   input A2;
   input B1;
   input B2;
   input CK;
   inout VCC;
   reg flag; // Notifier flag
   supply1 vcc;

   wire d_CK, d_A1, d_A2, d_B1, d_B2;

//Function Block
`protect
   and g5(tmp_oa, d_A1, d_A2);
   and g4(tmp_ob, d_B1, d_B2);
   or  g3(tmp_o, tmp_oa, tmp_ob);

   buf g2 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   dffrsb_udp g1(qt, tmp_o,  d_CK,  vcc,  vcc,  flag );

//Specify Block
   specify

     //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
     // Setup and Hold Time
      specparam setup_A1_CK = 9.10;
      specparam hold_A1_CK = 0.00;
      specparam setup_A2_CK = 9.10;
      specparam hold_A2_CK = 0.00;
      specparam setup_B1_CK = 9.10;
      specparam hold_B1_CK = 0.00;
      specparam setup_B2_CK = 9.10;
      specparam hold_B2_CK = 0.00;
      $setuphold(posedge CK, posedge A1, 1.00, 1.00, flag,,,d_CK, d_A1);
      $setuphold(posedge CK, negedge A1, 1.00, 1.00, flag,,,d_CK, d_A1);
      $setuphold(posedge CK, posedge A2, 1.00, 1.00, flag,,,d_CK, d_A2);
      $setuphold(posedge CK, negedge A2, 1.00, 1.00, flag,,,d_CK, d_A2);
      $setuphold(posedge CK, posedge B1, 1.00, 1.00, flag,,,d_CK, d_B1);
      $setuphold(posedge CK, negedge B1, 1.00, 1.00, flag,,,d_CK, d_B1);
      $setuphold(posedge CK, posedge B2, 1.00, 1.00, flag,,,d_CK, d_B2);
      $setuphold(posedge CK, negedge B2, 1.00, 1.00, flag,,,d_CK, d_B2);
      //  Minimum Pulse Width
      specparam mpw_neg_CK = 13.86;
      specparam mpw_pos_CK = 12.21;
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine
