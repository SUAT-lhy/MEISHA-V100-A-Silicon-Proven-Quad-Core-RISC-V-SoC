///////////////////////////////////////////////////////////////////////////////////////
//
//   Note : This library uses delayed signals to support negative
//          timing checks.
//          Please add command-line options
//             "+neg_tchk" and "+nowarnNTCDSN" when runnning simulation with Verilog-XL
//             "+neg_tchk" when runnning simulation with NC-verilog & VCS
//          to support negative timing checks.
//
///////////////////////////////////////////////////////////////////////////////////////

`timescale 10ps / 1ps

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module A2ISOESDLHRMX1  (VCCNW, SLB, I, O, GND, VCC);
   inout VCCNW;
   input SLB;
   input I;
   output O;
   inout GND;
   inout VCC;
   supply0 GNDPW;

//Function Block
`protect
   and g1(O_temp, I, SLB);

   assign O = ((VCC !== 1'b1) || (GND !== 1'b0) || (VCCNW !== 1'b1) || (GNDPW !== 1'b0))? 1'bx : O_temp;

//Specify Block
   specify

      //  Module Path Delay
      (I *> O) = (1.00, 1.00);
      (SLB *> O) = (1.00, 1.00);
   endspecify
`endprotect
endmodule
`endcelldefine


