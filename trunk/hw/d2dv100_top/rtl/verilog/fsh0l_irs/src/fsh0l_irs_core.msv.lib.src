	and (ENABLE_NOT_SEL_AND_NOT_TD, SEL__bar, TD__bar);
	not (ENABLE_NOT_SEL, SEL);
	and (ENABLE_D1_AND_SEL, D1, SEL);
	and (ENABLE_NOT_D1_AND_SEL, D1__bar, SEL);


