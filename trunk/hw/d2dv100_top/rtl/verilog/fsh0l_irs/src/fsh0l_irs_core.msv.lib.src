             main <= 1'bx;
          end
       end
       else begin
          main <= 1'bx;
       end
   end
   assign Q = main;

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q :1'bx)) = (1.00, 1.00);

//  Setup and Hold Time
