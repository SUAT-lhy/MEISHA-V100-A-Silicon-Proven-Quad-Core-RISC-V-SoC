//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QBDFZERBNLHRMX3 (QB, D, TD, CK, SEL, EB, RB, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input TD;
   input D;
   inout GND;
   input CK;
   input EB;
   inout VCC;
   input SEL;
   reg flag; // Notifier flag
   supply1 vcc;
   reg  D_flag1;
   wire D_flag;
   reg flag_two1;
   wire flag_two;
   wire d_CK, d_D, d_TD, d_EB, d_SEL;

//Function Block
`protect
   buf b3 (SEL_, d_SEL );  //Avoid MIPD.
   buf b4 (EB_, d_EB );    //Avoid MIPD.

   not g1 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dffrsb_udp g2(qt,  d1,  d_CK,  RB,  vcc,  flag );
   mux3_udp g4(d1,  d_D,  qt,  d_TD, EB_, SEL_ );


// Define the flag for timing check
  assign D_flag = D_flag1;      // For Model-Tec complier
  always @(EB_ or SEL_)
    begin
      if ((EB_ === 1'b0) && (SEL_ === 1'b0))
         D_flag1 = 1'b1;
      else
         D_flag1 = 1'b0;
    end

//Append pseudo gate for timing violation checking
  assign flag_two = flag_two1;      // For Model-Tec complier
  always @(EB_ or SEL_ or D or TD or qt)
    begin
      if (EB_ === 1'b0) begin
        if (SEL_ === 1'b0) 
           flag_two1 = D;
        else
           flag_two1 = TD;
      end
      else begin
        if (SEL_ === 1'b0) 
           flag_two1 = qt;
        else
           flag_two1 = TD;
      end
    end

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 33.05;
      specparam hold_D_CK = 4.97;
      specparam setup_EB_CK = 34.40;
      specparam hold_EB_CK = 9.62;
      specparam setup_SEL_CK = 34.40;
      specparam hold_SEL_CK = 9.62;
      specparam setup_TD_CK = 34.40;
      specparam hold_TD_CK = 9.62;
      $setuphold(posedge CK &&& RB, posedge D &&& D_flag, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D &&& D_flag, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, posedge EB &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_EB);
      $setuphold(posedge CK &&& RB, negedge EB &&& ~SEL, 1.00, 1.00, flag,,,d_CK, d_EB);
      $setuphold(posedge CK &&& RB, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, posedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& RB, negedge TD &&& SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 63.26;
      specparam recovery_CK_RB = 31.03;
      $recrem(posedge RB, posedge CK &&& flag_two, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_CK = 32.58;
      specparam mpw_pos_CK = 50.23;
      specparam mpw_neg_RB = 106.96;
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
      $width(negedge RB, 1.00, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine


