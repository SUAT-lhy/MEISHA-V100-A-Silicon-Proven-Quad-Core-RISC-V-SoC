`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZRBLHRMX3 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, RB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag;
   wire D_flag1;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD;
   supply1 vcc;


//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g5 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g6 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  RB,  vcc,  flag3 );
   mux2_udp g9(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g10(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g11(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g12(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
   assign D_flag1 = D_flag;
   always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
     begin
       if (SEL_ === 1'b0) 
           D_flag = d_D1 | d_D2 | d_D3 | d_D4;
       else
           D_flag = d_TD;
     end

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire ENABLE_RB, ENABLE_D1_AND_NOT_SEL, ENABLE_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SEL, ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_SEL_AND_TD, ENABLE_NOT_CK, ENABLE_NOT_D1_AND_D2_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_TD, ENABLE_NOT_D1_AND_RB_AND_SEL, ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL_AND_TD, ENABLE_NOT_D1_AND_SEL_AND_TD, ENABLE_RB_AND_NOT_SEL;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_RB, RB);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_TD, D1, RB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, D1, RB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_RB_AND_NOT_SEL_AND_TD, D1, RB, SEL__bar, TD);
	and (ENABLE_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, D1, RB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_TD, D1__bar, RB, SEL, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_TD, D1__bar, RB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL_AND_NOT_TD, D1__bar, RB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_NOT_SEL, RB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_TD, D1, SEL, TD);
	and (ENABLE_D1_AND_NOT_SEL, D1, SEL__bar);
	and (ENABLE_NOT_D1_AND_SEL_AND_TD, D1__bar, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, D1__bar, D2, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, D1__bar, D2__bar, D3, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, D1__bar, D2__bar, D3__bar, D4, SEL__bar);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_RB_AND_SEL, D1, RB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL, D1__bar, RB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D1 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D1 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D3 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D3 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, posedge D4 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_NOT_SEL, negedge D4 &&& ENABLE_RB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_RB, posedge SEL &&& ENABLE_RB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB, negedge SEL &&& ENABLE_RB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);


      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_CK_RB = 8.80;
	$recrem (posedge RB &&& ENABLE_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_D1_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_NOT_SEL, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZRSBLHRMX1 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag_or, D_flag_and;
   wire D_flag1, D_flag2;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD ;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g6 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g9 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  RB,  SB,  flag3 );
   mux2_udp g10(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g11(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g12(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g13(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1 = D_flag_or;
assign D_flag2 = D_flag_and;
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0) begin
        D_flag_or = d_D1 | d_D2 | d_D3 | d_D4;
        D_flag_and = d_D1 & d_D2 & d_D3 & d_D4;
    end
    else begin
        D_flag_or = d_TD;
        D_flag_and = d_TD;
    end
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL;
	wire ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SB_AND_SEL, ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB, ENABLE_NOT_CK_AND_SB;
	wire ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_RB_AND_SB;
	wire ENABLE_RB_AND_SB_AND_NOT_SEL, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_TD, D1, RB, SB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, D1, RB, SB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD, D1, RB, SB, SEL__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1, RB, SB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_TD, D1__bar, RB, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, D1__bar, RB, SB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD, D1__bar, RB, SB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1__bar, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, RB, SB, SEL__bar, TD);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL, RB, SB, SEL__bar);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL, D1, SB, SEL__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, D1__bar, D2, SB, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, D1__bar, D2__bar, D3, SB, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, D1__bar, D2__bar, D3__bar, D4, SB, SEL__bar);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, D1, RB, SEL, TD__bar);
	not (D4__bar, D4);
	and (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, D1, D2, D3, D4__bar, RB, SEL__bar);
	and (ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, D1, D2, D3__bar, RB, SEL__bar);
	and (ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, D1, D2__bar, RB, SEL__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, D1__bar, RB, SEL__bar);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);
	and (ENABLE_RB_AND_SB, RB, SB);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL, D1, RB, SB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, D1__bar, RB, SB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D3 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D3 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D4 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D4 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);

      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
	$recrem (posedge RB &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_D1_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
       $recrem (posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZRSBLHRMX2 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag_or, D_flag_and;
   wire D_flag1, D_flag2;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD ;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g6 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g9 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  RB,  SB,  flag3 );
   mux2_udp g10(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g11(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g12(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g13(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1 = D_flag_or;
assign D_flag2 = D_flag_and;
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0) begin
        D_flag_or = d_D1 | d_D2 | d_D3 | d_D4;
        D_flag_and = d_D1 & d_D2 & d_D3 & d_D4;
    end
    else begin
        D_flag_or = d_TD;
        D_flag_and = d_TD;
    end
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL;
	wire ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SB_AND_SEL, ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB, ENABLE_NOT_CK_AND_SB;
	wire ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_RB_AND_SB;
	wire ENABLE_RB_AND_SB_AND_NOT_SEL, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_TD, D1, RB, SB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, D1, RB, SB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD, D1, RB, SB, SEL__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1, RB, SB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_TD, D1__bar, RB, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, D1__bar, RB, SB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD, D1__bar, RB, SB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1__bar, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, RB, SB, SEL__bar, TD);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL, RB, SB, SEL__bar);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL, D1, SB, SEL__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, D1__bar, D2, SB, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, D1__bar, D2__bar, D3, SB, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, D1__bar, D2__bar, D3__bar, D4, SB, SEL__bar);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, D1, RB, SEL, TD__bar);
	not (D4__bar, D4);
	and (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, D1, D2, D3, D4__bar, RB, SEL__bar);
	and (ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, D1, D2, D3__bar, RB, SEL__bar);
	and (ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, D1, D2__bar, RB, SEL__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, D1__bar, RB, SEL__bar);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);
	and (ENABLE_RB_AND_SB, RB, SB);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL, D1, RB, SB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, D1__bar, RB, SB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D3 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D3 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D4 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D4 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);

      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
	$recrem (posedge RB &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_D1_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
       $recrem (posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZRSBLHRMX3 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   input RB;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag_or, D_flag_and;
   wire D_flag1, D_flag2;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD ;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g6 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g9 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  SB,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  RB,  SB,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  RB,  SB,  flag3 );
   mux2_udp g10(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g11(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g12(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g13(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1 = D_flag_or;
assign D_flag2 = D_flag_and;
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0) begin
        D_flag_or = d_D1 | d_D2 | d_D3 | d_D4;
        D_flag_and = d_D1 & d_D2 & d_D3 & d_D4;
    end
    else begin
        D_flag_or = d_TD;
        D_flag_and = d_TD;
    end
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire D3__bar, D4__bar, ENABLE_CK_AND_RB;
	wire ENABLE_CK_AND_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL;
	wire ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SB_AND_SEL, ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_CK, ENABLE_NOT_CK_AND_RB, ENABLE_NOT_CK_AND_SB;
	wire ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_RB_AND_SB;
	wire ENABLE_RB_AND_SB_AND_NOT_SEL, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_TD, D1, RB, SB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, D1, RB, SB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD, D1, RB, SB, SEL__bar, TD);
	and (ENABLE_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1, RB, SB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_TD, D1__bar, RB, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL_AND_NOT_TD, D1__bar, RB, SB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_TD, D1__bar, RB, SB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1__bar, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, RB, SB, SEL__bar, TD);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL, RB, SB, SEL__bar);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL, D1, SB, SEL__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, D1__bar, D2, SB, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, D1__bar, D2__bar, D3, SB, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, D1__bar, D2__bar, D3__bar, D4, SB, SEL__bar);
	and (ENABLE_CK_AND_SB, CK, SB);
	not (CK__bar, CK);
	and (ENABLE_NOT_CK_AND_SB, CK__bar, SB);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, D1, RB, SEL, TD__bar);
	not (D4__bar, D4);
	and (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, D1, D2, D3, D4__bar, RB, SEL__bar);
	and (ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, D1, D2, D3__bar, RB, SEL__bar);
	and (ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, D1, D2__bar, RB, SEL__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, D1__bar, RB, SEL__bar);
	and (ENABLE_CK_AND_RB, CK, RB);
	and (ENABLE_NOT_CK_AND_RB, CK__bar, RB);
	and (ENABLE_RB_AND_SB, RB, SB);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL, D1, RB, SB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, D1__bar, RB, SB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D3 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D3 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D4 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D4 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);

      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
	$recrem (posedge RB &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_D1_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_D3_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge RB &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_D2_AND_NOT_D3_AND_D4_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
       $recrem (posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZSBLHRMX1 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD, D_flag1;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g6 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g9 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc, SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc, SB,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  vcc, SB,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  vcc, SB,  flag3 );
   mux2_udp g10(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g11(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g12(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g13(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 & d_D2 & d_D3 & d_D4;
    else
        D_flag = d_TD;
  end

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire D4__bar, ENABLE_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL;
	wire ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_SB_AND_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_SEL_AND_NOT_TD, ENABLE_NOT_CK, ENABLE_NOT_D1_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_TD, ENABLE_NOT_D1_AND_SB_AND_SEL;
	wire ENABLE_NOT_D1_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_NOT_D1_AND_SEL_AND_NOT_TD;
	wire ENABLE_SB_AND_NOT_SEL, SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_NOT_TD, D1, SB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL_AND_TD, D1, SB, SEL__bar, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1, SB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_NOT_TD, D1__bar, SB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_TD, D1__bar, SB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1__bar, SB, SEL__bar, TD__bar);
	and (ENABLE_SB_AND_NOT_SEL, SB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_NOT_TD, D1, SEL, TD__bar);
	not (D4__bar, D4);
	and (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, D1, D2, D3, D4__bar, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, D1, D2, D3__bar, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, D1, D2__bar, SEL__bar);
	and (ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, D1__bar, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_NOT_SEL, D1__bar, SEL__bar);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_SB_AND_SEL, D1, SB, SEL);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL, D1__bar, SB, SEL);



//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;


      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D3 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D3 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D4 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D4 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_SB, posedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB, negedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);


      //  Recovery Time
      specparam recovery_SB_CK = 5.90;
      specparam recovery_CK_SB = 8.80;
	$recrem (posedge SB &&& ENABLE_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_SEL, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZSBLHRMX2 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD, D_flag1;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g6 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g9 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc, SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc, SB,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  vcc, SB,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  vcc, SB,  flag3 );
   mux2_udp g10(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g11(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g12(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g13(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 & d_D2 & d_D3 & d_D4;
    else
        D_flag = d_TD;
  end

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire D4__bar, ENABLE_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL;
	wire ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_SB_AND_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_SEL_AND_NOT_TD, ENABLE_NOT_CK, ENABLE_NOT_D1_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_TD, ENABLE_NOT_D1_AND_SB_AND_SEL;
	wire ENABLE_NOT_D1_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_NOT_D1_AND_SEL_AND_NOT_TD;
	wire ENABLE_SB_AND_NOT_SEL, SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_NOT_TD, D1, SB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL_AND_TD, D1, SB, SEL__bar, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1, SB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_NOT_TD, D1__bar, SB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_TD, D1__bar, SB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1__bar, SB, SEL__bar, TD__bar);
	and (ENABLE_SB_AND_NOT_SEL, SB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_NOT_TD, D1, SEL, TD__bar);
	not (D4__bar, D4);
	and (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, D1, D2, D3, D4__bar, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, D1, D2, D3__bar, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, D1, D2__bar, SEL__bar);
	and (ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, D1__bar, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_NOT_SEL, D1__bar, SEL__bar);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_SB_AND_SEL, D1, SB, SEL);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL, D1__bar, SB, SEL);



//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;


      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D3 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D3 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D4 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D4 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_SB, posedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB, negedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);


      //  Recovery Time
      specparam recovery_SB_CK = 5.90;
      specparam recovery_CK_SB = 8.80;
	$recrem (posedge SB &&& ENABLE_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_SEL, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q4DFZSBLHRMX3 (Q1, Q2, Q3, Q4, D1, D2, D3, D4, TD, CK, SEL, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   output Q3;
   output Q4;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   reg D_flag;
   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_SEL, d_TD, D_flag1;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   buf g6 (Q3_pg_tmp, qt3);
   assign Q3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q3_pg_tmp : 1'bx;
   buf g9 (Q4_pg_tmp, qt4);
   assign Q4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q4_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc, SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc, SB,  flag1 );
   dffrsb_udp g7(qt3,  data3,  d_CK,  vcc, SB,  flag2 );
   dffrsb_udp g8(qt4,  data4,  d_CK,  vcc, SB,  flag3 );
   mux2_udp g10(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g11(data2,  d_D2,  qt1,  SEL_ );
   mux2_udp g12(data3,  d_D3,  qt2,  SEL_ );
   mux2_udp g13(data4,  d_D4,  qt3,  SEL_ );

//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 & d_D2 & d_D3 & d_D4;
    else
        D_flag = d_TD;
  end

	// Additional timing wires
	wire D1__bar, D2__bar, D3__bar;
	wire D4__bar, ENABLE_SB, ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL;
	wire ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_NOT_SEL_AND_TD;
	wire ENABLE_D1_AND_SB_AND_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_D1_AND_SEL_AND_NOT_TD, ENABLE_NOT_CK, ENABLE_NOT_D1_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_TD, ENABLE_NOT_D1_AND_SB_AND_SEL;
	wire ENABLE_NOT_D1_AND_SB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_NOT_D1_AND_SEL_AND_NOT_TD;
	wire ENABLE_SB_AND_NOT_SEL, SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	not (TD__bar, TD);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_NOT_TD, D1, SB, SEL, TD__bar);
	not (SEL__bar, SEL);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL_AND_TD, D1, SB, SEL__bar, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1, SB, SEL__bar, TD__bar);
	not (D1__bar, D1);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_NOT_TD, D1__bar, SB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_TD, D1__bar, SB, SEL__bar, TD);
	and (ENABLE_NOT_D1_AND_SB_AND_NOT_SEL_AND_NOT_TD, D1__bar, SB, SEL__bar, TD__bar);
	and (ENABLE_SB_AND_NOT_SEL, SB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_NOT_TD, D1, SEL, TD__bar);
	not (D4__bar, D4);
	and (ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, D1, D2, D3, D4__bar, SEL__bar);
	not (D3__bar, D3);
	and (ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, D1, D2, D3__bar, SEL__bar);
	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, D1, D2__bar, SEL__bar);
	and (ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, D1__bar, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_NOT_SEL, D1__bar, SEL__bar);
	not (ENABLE_NOT_CK, CK);
	and (ENABLE_D1_AND_SB_AND_SEL, D1, SB, SEL);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL, D1__bar, SB, SEL);



//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 9.00;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.00;
      specparam hold_D4_CK = 0.00;


      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D3 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D3 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, posedge D4 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL, negedge D4 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& ENABLE_SB, posedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB, negedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);


      //  Recovery Time
      specparam recovery_SB_CK = 5.90;
      specparam recovery_CK_SB = 8.80;
	$recrem (posedge SB &&& ENABLE_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_D3_AND_NOT_D4_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_D2_AND_NOT_D3_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
	$recrem (posedge SB &&& ENABLE_NOT_D1_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_SEL, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QB2DFZLHRMX1 (QB1, QB2, D1, D2, TD, CK, SEL, VCCNW, GND, VCC);
   output QB1;
   output QB2;
   inout VCCNW;
   input TD;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1; // Notifier flag
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_TD, d_SEL;

//Function Block
`protect
   not g5 (QB1_pg_tmp, qt1);
   assign QB1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB1_pg_tmp : 1'bx;
   not g6 (QB2_pg_tmp, qt2);
   assign QB2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB2_pg_tmp : 1'bx;

   dffrsb_udp g3(qt1,  d1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g4(qt2,  d2,  d_CK,  vcc,  vcc,  flag1 );

   mux2_udp g1(d1,  d_D1,  d_TD, d_SEL );
   mux2_udp g2(d2,  d_D2,  qt1,  d_SEL );


//Specify Block
   specify
//  Module Path Delay
      (posedge CK *> (QB1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (QB2 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.30;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.30;
      specparam hold_D2_CK = 0.00;
      specparam setup_TD_CK = 10.30;
      specparam hold_TD_CK = 0.00;
      specparam setup_SEL_CK = 8.60;
      specparam hold_SEL_CK = 0.00;
      $setuphold(posedge CK, posedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, negedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK, posedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK, negedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK, posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK, negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);

      //  Minimum Pulse Width
      specparam mpw_pos_CK = 15.64;
      specparam mpw_neg_CK = 17.40;
      $width(posedge CK, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);

   endspecify
`endprotect
endmodule
`endcelldefine

//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QB2DFZLHRMX2 (QB1, QB2, D1, D2, TD, CK, SEL, VCCNW, GND, VCC);
   output QB1;
   output QB2;
   inout VCCNW;
   input TD;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1; // Notifier flag
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_TD, d_SEL;

//Function Block
`protect
   not g5 (QB1_pg_tmp, qt1);
