      $setuphold(posedge CK &&& RB, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& RB, posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& RB, negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 4.30;
      specparam recovery_CK_RB = 9.00;
      $recrem(posedge RB, posedge CK, 1.00, 1.00, flag);


