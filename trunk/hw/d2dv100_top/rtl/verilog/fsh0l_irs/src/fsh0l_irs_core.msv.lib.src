//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module QB4DFZSBLHRMX3 (QB1, QB2, QB3, QB4, D1, D2, D3, D4, TD, CK, SEL, SB, VCCNW, GND, VCC);
   output QB1;
   output QB2;
   output QB3;
   output QB4;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input D3;
   input D4;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1, flag2, flag3; // Notifier flag
   supply1 vcc;
   reg D_flag;
   wire D_flag1;

   wire d_CK, d_D1, d_D2, d_D3, d_D4, d_TD, d_SEL;

//Function Block
`protect
   buf b13 (SEL_, SEL );  //Avoid MIPD.

   not g1 (QB1_pg_tmp, qt1);
   assign QB1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB1_pg_tmp : 1'bx;
   not g2 (QB2_pg_tmp, qt2);
   assign QB2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB2_pg_tmp : 1'bx;
   not g3 (QB3_pg_tmp, qt3);
   assign QB3 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB3_pg_tmp : 1'bx;
   not g4 (QB4_pg_tmp, qt4);
   assign QB4 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB4_pg_tmp : 1'bx;

   dffrsb_udp g5(qt1,  d1,  d_CK,  vcc,  SB,  flag );
   dffrsb_udp g6(qt2,  d2,  d_CK,  vcc,  SB,  flag1 );
   dffrsb_udp g7(qt3,  d3,  d_CK,  vcc,  SB,  flag2 );
   dffrsb_udp g8(qt4,  d4,  d_CK,  vcc,  SB,  flag3 );

   mux2_udp g9(d1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g10(d2,  d_D2,  qt1,  d_SEL );
   mux2_udp g11(d3,  d_D3,  qt2,  d_SEL );
   mux2_udp g12(d4,  d_D4,  qt3,  d_SEL );


//Append pseudo gate for timing violation checking
assign D_flag1   = D_flag;    // For Model-Tec complier
always @(SEL_ or d_D1 or d_D2 or d_D3 or d_D4 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 & d_D2 & d_D3 & d_D4;
    else
        D_flag = d_TD;
  end

//Specify Block
   specify
   //  Module Path Delay
      (posedge CK *> (QB1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (QB2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB2 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (QB3 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB3 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (QB4 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (QB4 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 6.90;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 6.90;
      specparam hold_D2_CK = 0.00;
      specparam setup_D3_CK = 6.90;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 6.90;
      specparam hold_D4_CK = 0.00;
      specparam setup_SEL_CK = 9.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 9.50;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& SB, posedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& SB, negedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& SB, posedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& SB, negedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& SB, posedge D3, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& SB, negedge D3, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK &&& SB, posedge D4, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK &&& SB, negedge D4, 1.00, 1.00, flag3,,,d_CK, d_D4);

      $setuphold(posedge CK &&& SB, posedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, negedge SEL, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& SB, posedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& SB, negedge TD, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_SB_CK = 1.61;
      specparam recovery_CK_SB = 4.00;
      $recrem(posedge SB, posedge CK, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_SB = 15.58;
      specparam mpw_neg_CK = 15.85;
      specparam mpw_pos_CK = 15.15;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine
