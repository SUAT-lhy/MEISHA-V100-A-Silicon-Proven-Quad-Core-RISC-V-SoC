module QDSFZLHRMX0P7  (VCCNW, SL, TD, D, Q, GND, GNDG, CK, VCCG, VCC, SEL);
   inout VCCNW;
   input SL;
   input TD;
   input D;
   output Q;
   inout GND;
   inout GNDG;
   input CK;
   inout VCCG;
   inout VCC;
   input SEL;
   supply0 GNDPW;

  reg D_flag, flag; // Notifier flag
  supply1 vcc;

  wire d_CK, d_D, d_TD, d_SEL, d_SL, D_flag1;
  wire on1, on2, oa1, om1;
  wire poweron, Q1;
  reg main;

//Function Block
`protect

     buf b1 (SEL_, d_SEL );  //Avoid MIPD.
     not n1 (on1, d_CK);
     not n2 (on2, d_SL);
     and a1 (oa1, d_CK, on2);
     mux2_udp m1 (om1,  d_D,  d_TD,  SEL_ );
     dlhrsb_udp dlh1 (odlh1, om1, on1, vcc, vcc, flag ); 
     dlhrsb_udp dlh2 (qt,  odlh1, oa1, vcc, vcc, flag ); 
     buf (Q_temp, qt);

//Append pseudo gate for timing violation checking
     assign D_flag1 = D_flag;
     always @(SEL_ or d_D or d_TD or SL)
     begin
       if (SL === 1'b0)
       if (SEL_ === 1'b0)
          D_flag = d_D;
       else
          D_flag = d_TD;
       else
       D_flag = 0;     
    end

//PG_pin
    assign poweron = ((VCCG === 1'b1) && (GNDG === 1'b0) && (VCCNW === 1'b1) && (GNDPW === 1'b0));
    assign Q1 = ((VCC === 1'b1) && (GND === 1'b0));

    always @ (*)
    begin
       if ( poweron == 1 ) begin
          if ( Q1 == 1) begin
             main <= Q_temp;                      
          end
          else begin
             main <= 1'bx;
          end
       end
       else begin
          main <= 1'bx;
       end
   end
   assign Q = main;

//Specify Block
  specify 
    (posedge CK *> (Q :1'bx)) = (1.00, 1.00);
//  Setup and Hold Time
      specparam setup_D_CK = 9.00;
