   dffrsb_udp g2(qt2,  d_D2,  d_CK,  RB,  vcc,  flag1 );
   dffrsb_udp g7(qt3,  d_D3,  d_CK,  RB,  vcc,  flag2 );
   dffrsb_udp g8(qt4,  d_D4,  d_CK,  RB,  vcc,  flag3 );

	// Additional timing wires
