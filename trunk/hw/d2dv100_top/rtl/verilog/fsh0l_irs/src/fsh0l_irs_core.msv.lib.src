      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.10;
      specparam hold_D2_CK = 0.00;

      specparam setup_D3_CK = 9.10;
      specparam hold_D3_CK = 0.00;
      specparam setup_D4_CK = 9.10;
      specparam hold_D4_CK = 0.00;

