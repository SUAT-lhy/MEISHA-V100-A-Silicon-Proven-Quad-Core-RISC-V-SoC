//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFZLHRMX1 (Q1, Q2, D1, D2, TD, CK, SEL, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   inout VCCNW;
   input TD;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1; // Notifier flag
   supply1 vcc;

   wire d_CK, d_D1, d_D2, d_TD, d_SEL;

//Function Block
`protect
   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc,  vcc,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc,  vcc,  flag1 );
   mux2_udp g5(data1,  d_D1,  d_TD,  d_SEL );
   mux2_udp g6(data2,  d_D2,  qt1,  d_SEL );

	// Additional timing wires
	wire D1__bar;
	wire ENABLE_D1_AND_SEL;
	wire ENABLE_NOT_D1_AND_SEL;
	wire ENABLE_NOT_SEL;
	wire ENABLE_NOT_SEL_AND_NOT_TD, ENABLE_NOT_SEL_AND_TD, SEL__bar;
	wire TD__bar;

	// Additional timing gates
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
	and (ENABLE_NOT_SEL_AND_TD, SEL__bar, TD);
	and (ENABLE_NOT_SEL_AND_NOT_TD, SEL__bar, TD__bar);
	not (ENABLE_NOT_SEL, SEL);
	and (ENABLE_D1_AND_SEL, D1, SEL);
	and (ENABLE_NOT_D1_AND_SEL, D1__bar, SEL);


//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.30;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.30;
      specparam hold_D2_CK = 0.00;
      specparam setup_TD_CK = 10.30;
      specparam hold_TD_CK = 0.00;
      specparam setup_SEL_CK = 8.60;
      specparam hold_SEL_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);

      $setuphold(posedge CK &&& ENABLE_NOT_SEL, posedge D2 &&& ENABLE_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_NOT_SEL, negedge D2 &&& ENABLE_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);

