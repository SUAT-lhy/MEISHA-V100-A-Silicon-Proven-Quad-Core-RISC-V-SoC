`timescale 10ps/1ps
`celldefine
module QBDFCLRBNLHRMX0P4 (QB, D, CK, RB, LD, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input D;
   inout GND;
   input CK;
   inout VCC;
   input LD;
   reg flag; // Notifier flag
   reg  D_flag1, LD_flag1, RB_flag1;
   wire D_flag, LD_flag, RB_flag;
   supply1 vcc;

   wire d_CK, d_D, d_LD, d_RB;

//Function Block
`protect
   buf b1 (D_, d_D );
   buf b2 (LD_, d_LD );
   buf b3 (RB_, d_RB );
   //buf g3(Q, qt);
   not g1 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dffrsb_udp g2(qt,  d1,  d_CK,  vcc,  vcc,  flag );
   and g4(d1, di, RB_);
   mux2_udp g5(di, qt, D_, LD_);
// Define the flag for timing check
  assign D_flag  = D_flag1;   // For Model-Tec complier
  assign LD_flag = LD_flag1;  // For Model-Tec complier
  assign RB_flag = RB_flag1;  // For Model-Tec complier
  always @(LD_ or RB_)
    begin
      if ((LD_ === 1'b1) && (RB_ === 1'b1))
         D_flag1 = 1'b1;
      else
         D_flag1 = 1'b0;
    end
  always @(D_ or QB or RB_)
    begin
      if ((RB_ === 1'b1) && (!D_ !== QB))
         LD_flag1 = 1'b1;
      else
         LD_flag1 = 1'b0;
    end
  always @(di)
    begin
      if (di===1'b1)
         RB_flag1 = 1'b1;
      else
         RB_flag1 = 1'b0;
    end

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (QB :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 9.00;
      specparam hold_D_CK = 0.00;
      specparam setup_LD_CK = 14.52;
      specparam hold_LD_CK = 0.00;
      specparam setup_RB_CK = 11.20;
      specparam hold_RB_CK = 0.00;
      $setuphold(posedge CK, posedge D &&& D_flag, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK, negedge D &&& D_flag, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK, posedge LD &&& LD_flag, 1.00, 1.00, flag,,,d_CK, d_LD);
      $setuphold(posedge CK, negedge LD &&& LD_flag, 1.00, 1.00, flag,,,d_CK, d_LD);
      $setuphold(posedge CK, posedge RB &&& RB_flag, 1.00, 1.00, flag,,,d_CK, d_RB);
      $setuphold(posedge CK, negedge RB &&& RB_flag, 1.00, 1.00, flag,,,d_CK, d_RB);

      //  Minimum Pulse Width
      specparam mpw_neg_CK = 22.89;
      specparam mpw_pos_CK = 18.89;
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


