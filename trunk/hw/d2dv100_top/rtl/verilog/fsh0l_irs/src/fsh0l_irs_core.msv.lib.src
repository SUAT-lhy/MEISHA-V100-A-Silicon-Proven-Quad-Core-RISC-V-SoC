	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, D1, D2__bar, RB, SEL__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, D1__bar, RB, SEL__bar);
	and (ENABLE_RB_AND_SB, RB, SB);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL, D1, RB, SB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, D1__bar, RB, SB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFZRSBLHRMX3 (Q1, Q2, D1, D2, TD, CK, SEL, RB, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   input RB;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1; // Notifier flag
   reg D_flag_or, D_flag_and;
   wire D_flag1, D_flag2;
   wire d_CK, d_D1, d_D2, d_SEL, d_TD ;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  RB,  SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  RB,  SB,  flag1 );
   mux2_udp g7(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g8(data2,  d_D2,  qt1,  SEL_ );

//Append pseudo gate for timing violation checking
and (_SB_and_RB_, SB, RB);
or (_SB_or_RB_, SB, RB);
assign D_flag1 = D_flag_or;
assign D_flag2 = D_flag_and;
always @(SEL_ or d_D1 or d_D2 or d_TD)
  begin
    if (SEL_ === 1'b0) begin
        D_flag_or = d_D1 | d_D2;
        D_flag_and = d_D1 & d_D2;
    end
    else begin
        D_flag_or = d_TD;
        D_flag_and = d_TD;
    end
  end

//Timing violation checking statement
always @(negedge _SB_or_RB_) if(_SB_or_RB_ === 0)
  $display($time, " ****Warning! Set and Reset of %m are low simultaneously");

	// Additional timing wires
	wire CK__bar, D1__bar, D2__bar;
	wire ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL;
	wire ENABLE_D1_AND_RB_AND_SB_AND_SEL;
	wire ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD;
	wire ENABLE_D1_AND_SB_AND_NOT_SEL, ENABLE_D1_AND_SB_AND_SEL_AND_TD;
	wire ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_NOT_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL;
	wire ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, ENABLE_RB_AND_SB;
	wire ENABLE_RB_AND_SB_AND_NOT_SEL, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, RB, SB, SEL__bar, TD);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, RB, SB, SEL__bar, TD__bar);
	and (ENABLE_RB_AND_SB_AND_NOT_SEL, RB, SB, SEL__bar);
	and (ENABLE_D1_AND_SB_AND_SEL_AND_TD, D1, SB, SEL, TD);
	and (ENABLE_D1_AND_SB_AND_NOT_SEL, D1, SB, SEL__bar);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, D1__bar, SB, SEL, TD);
	and (ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, D1__bar, D2, SB, SEL__bar);
	not (CK__bar, CK);
	and (ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, D1, RB, SEL, TD__bar);
	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, D1, D2__bar, RB, SEL__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, D1__bar, RB, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, D1__bar, RB, SEL__bar);
	and (ENABLE_RB_AND_SB, RB, SB);
	and (ENABLE_D1_AND_RB_AND_SB_AND_SEL, D1, RB, SB, SEL);
	and (ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, D1__bar, RB, SB, SEL);

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (Q2 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, posedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, negedge D1 &&& ENABLE_RB_AND_SB_AND_NOT_SEL_AND_NOT_TD, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, posedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB_AND_NOT_SEL, negedge D2 &&& ENABLE_RB_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, posedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_RB_AND_SB, negedge SEL &&& ENABLE_RB_AND_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_RB_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);

      //  Recovery Time
      specparam recovery_RB_CK = 5.90;
      specparam recovery_SB_CK = 10.35;
      specparam recovery_CK_RB = 8.80;
      specparam recovery_CK_SB = 1.29;
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_D1_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL_AND_TD, 1.00, 1.00, flag);
      $recrem(posedge RB &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_D2_AND_SB_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_RB_AND_NOT_SEL, 1.00, 1.00, flag);


      //  Minimum Pulse Width
      specparam mpw_neg_RB = 7.17;
      specparam mpw_neg_SB = 20.89;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge RB, 1.00, 0, flag);
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
   endspecify
`endprotect
endmodule
`endcelldefine


//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module Q2DFZSBLHRMX1 (Q1, Q2, D1, D2, TD, CK, SEL, SB, VCCNW, GND, VCC);
   output Q1;
   output Q2;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1; // Notifier flag
   reg D_flag;
   wire d_CK, d_D1, d_D2, d_SEL, d_TD, D_flag1;
   supply1 vcc;

//Function Block
`protect
   buf b5 (SEL_, d_SEL );  //Avoid MIPD.

   buf g3 (Q1_pg_tmp, qt1);
   assign Q1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q1_pg_tmp : 1'bx;
   buf g4 (Q2_pg_tmp, qt2);
   assign Q2 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q2_pg_tmp : 1'bx;
   dffrsb_udp g1(qt1,  data1,  d_CK,  vcc, SB,  flag );
   dffrsb_udp g2(qt2,  data2,  d_CK,  vcc, SB,  flag1 );
   mux2_udp g7(data1,  d_D1,  d_TD,  SEL_ );
   mux2_udp g8(data2,  d_D2,  qt1,  SEL_ );

	// Additional timing wires
	wire D1__bar, D2__bar, ENABLE_SB, ENABLE_D1_AND_NOT_D2_AND_NOT_SEL;
	wire ENABLE_D1_AND_SB_AND_SEL;
	wire ENABLE_D1_AND_SEL_AND_NOT_TD;
	wire ENABLE_NOT_D1_AND_SB_AND_SEL;
	wire ENABLE_SB_AND_NOT_SEL, ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, ENABLE_NOT_D1_AND_NOT_SEL;
	wire SEL__bar, TD__bar;


	// Additional timing gates
	buf (ENABLE_SB, SB);
	not (TD__bar, TD);
	not (SEL__bar, SEL);
	not (D1__bar, D1);
	and (ENABLE_SB_AND_NOT_SEL, SB, SEL__bar);
	and (ENABLE_D1_AND_SEL_AND_NOT_TD, D1, SEL, TD__bar);
	not (D2__bar, D2);
	and (ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, D1, D2__bar, SEL__bar);
	and (ENABLE_D1_AND_SB_AND_SEL, D1, SB, SEL);
	and (ENABLE_NOT_D1_AND_SB_AND_SEL, D1__bar, SB, SEL);
	and (ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, D1__bar, SEL, TD__bar);
	and (ENABLE_NOT_D1_AND_NOT_SEL, D1__bar, SEL__bar);




//Append pseudo gate for timing violation checking
assign D_flag1 = D_flag;
always @(SEL_ or d_D1 or d_D2 or d_TD)
  begin
    if (SEL_ === 1'b0)
        D_flag = d_D1 & d_D2;
    else
        D_flag = d_TD;
  end

//Specify Block
   specify

      //  Module Path Delay
      (posedge CK *> (Q1 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q2 :1'bx)) = (1.00, 1.00);
      (negedge SB *> (Q2 :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D1_CK = 9.00;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 9.00;
      specparam hold_D2_CK = 0.00;

      specparam setup_SEL_CK = 8.50;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.71;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,posedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,negedge D1 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,posedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& ENABLE_SB_AND_NOT_SEL ,negedge D2 &&& ENABLE_SB_AND_NOT_SEL, 1.00, 1.00, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK &&& ENABLE_SB, posedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_SB, negedge SEL &&& ENABLE_SB, 1.00, 1.00, flag,,,d_CK, d_SEL);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, posedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      $setuphold(posedge CK &&& ENABLE_NOT_D1_AND_SB_AND_SEL, negedge TD &&& ENABLE_NOT_D1_AND_SB_AND_SEL, 1.00, 1.00, flag,,,d_CK, d_TD);
      //  Recovery Time
      specparam recovery_SB_CK = 5.90;
      specparam recovery_CK_SB = 8.80;
      $recrem(posedge SB &&& ENABLE_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, posedge CK &&& ENABLE_D1_AND_NOT_D2_AND_NOT_SEL, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, posedge CK &&& ENABLE_NOT_D1_AND_SEL_AND_NOT_TD, 1.00, 1.00, flag);
      $recrem(posedge SB &&& ENABLE_NOT_D1_AND_NOT_SEL, posedge CK &&& ENABLE_NOT_D1_AND_NOT_SEL, 1.00, 1.00, flag);

      //  Minimum Pulse Width
      specparam mpw_neg_SB = 7.17;
      specparam mpw_neg_CK = 15.11;
      specparam mpw_pos_CK = 13.02;
      $width(negedge SB, 1.00, 0, flag);
      $width(negedge CK, 1.00, 0, flag);
