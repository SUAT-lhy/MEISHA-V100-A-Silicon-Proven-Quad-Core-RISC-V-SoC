   inout VCCNW;
   input D;
   output Q;
   inout GND;
   input CK;
   input EB;
   inout VCC;

  reg flag; // Notifier flag
  supply1 vcc;
  reg flag_two1;
  wire d_CK, d_D, d_EB, flag_two;

//Function Block
`protect
  buf b3 (EB_, d_EB );    //Avoid MIPD.

  mux2_udp g1(qt_i,  d_D,  qt,  d_EB );
  dffrsb_udp g2(qt,  qt_i,  d_CK,  RB,  vcc,  flag );  
  buf g3 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;

//Append pseudo gate for timing violation checking
  assign flag_two = flag_two1;      // For Model-Tec complier
  always @(EB_ or d_D or qt)
    begin
      if (EB_ === 1'b0)
           flag_two1 = d_D;
      else
           flag_two1 = qt;
    end


//Specify Block
   specify

      //  Module Path Delay
      (negedge RB *> (Q :1'bx)) = (1.00, 1.00);
      (posedge CK *> (Q :1'bx)) = (1.00, 1.00);

      //  Setup and Hold Time
      specparam setup_D_CK = 33.05;
      specparam hold_D_CK = 4.97;
      specparam setup_EB_CK = 34.40;
      specparam hold_EB_CK = 9.62;
      $setuphold(posedge CK &&& RB, posedge D &&& ~EB, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, negedge D &&& ~EB, 1.00, 1.00, flag,,,d_CK, d_D);
      $setuphold(posedge CK &&& RB, posedge EB, 1.00, 1.00, flag,,,d_CK, d_EB);
      $setuphold(posedge CK &&& RB, negedge EB, 1.00, 1.00, flag,,,d_CK, d_EB);

      //  Recovery Time
      specparam recovery_RB_CK = 63.26;
      specparam recovery_CK_RB = 31.03;
      $recrem(posedge RB, posedge CK &&& flag_two, 1.00, 1.00, flag);

      
      //  Minimum Pulse Width
      specparam mpw_neg_CK = 32.58;
      specparam mpw_pos_CK = 50.23;
      specparam mpw_neg_RB = 106.96;
      $width(negedge CK, 1.00, 0, flag);
      $width(posedge CK, 1.00, 0, flag);
      $width(negedge RB, 1.00, 0, flag);
   endspecify
`endprotect

endmodule
`endcelldefine
