module QB2DFZSBLHRMX3 (QB1, QB2, D1, D2, TD, CK, SEL, SB, VCCNW, GND, VCC);
   output QB1;
   output QB2;
   inout VCCNW;
   input SB;
   input TD;
   inout GND;
   input D1;
   input D2;
   input CK;
   inout VCC;
   input SEL;
   reg flag, flag1; // Notifier flag
   supply1 vcc;
   reg D_flag;
   wire D_flag1;

   wire d_CK, d_D1, d_D2, d_TD, d_SEL;

//Function Block
`protect
   buf b3 (SEL_, SEL );  //Avoid MIPD.

   not g5 (QB1_pg_tmp, qt1);
   assign QB1 = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB1_pg_tmp : 1'bx;
   not g6 (QB2_pg_tmp, qt2);
