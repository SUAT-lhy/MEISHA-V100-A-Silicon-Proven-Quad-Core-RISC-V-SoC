//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module AN2B1LHRMX0P4 (O, I1, B1, VCCNW, GND, VCC);
   inout VCCNW;
   output O;
   inout GND;
   input B1;
   input I1;
   inout VCC;

//Function Block
`protect
   not g0(i2, B1);
   and g1 (O_pg_tmp, I1, i2);
   assign O = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? O_pg_tmp : 1'bx;

//Specify Block
