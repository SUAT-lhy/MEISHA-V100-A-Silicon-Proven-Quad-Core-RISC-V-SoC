      $setuphold(posedge CK, negedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);

      $setuphold(posedge CK, posedge D3, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK, negedge D3, 1.00, 1.00, flag2,,,d_CK, d_D3);
      $setuphold(posedge CK, posedge D4, 1.00, 1.00, flag3,,,d_CK, d_D4);
      $setuphold(posedge CK, negedge D4, 1.00, 1.00, flag3,,,d_CK, d_D4);


      //  Minimum Pulse Width
      specparam mpw_neg_CK = 13.86;
      specparam mpw_pos_CK = 12.21;
