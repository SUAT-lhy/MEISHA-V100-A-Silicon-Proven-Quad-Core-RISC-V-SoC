  end

//Specify Block
   specify
//  Module Path Delay
      (posedge CK *> (QB1 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB1 :1'bx)) = (1.00, 1.00);
      (posedge CK *> (QB2 :1'bx)) = (1.00, 1.00);
      (negedge RB *> (QB2 :1'bx)) = (1.00, 1.00);


      //  Setup and Hold Time
      specparam setup_D1_CK = 6.30;
      specparam hold_D1_CK = 0.00;
      specparam setup_D2_CK = 6.30;
      specparam hold_D2_CK = 0.00;
      specparam setup_SEL_CK = 8.28;
      specparam hold_SEL_CK = 0.00;
      specparam setup_TD_CK = 8.28;
      specparam hold_TD_CK = 0.00;
      $setuphold(posedge CK &&& RB, posedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& RB, negedge D1, 1.00, 1.00, flag,,,d_CK, d_D1);
      $setuphold(posedge CK &&& RB, posedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
      $setuphold(posedge CK &&& RB, negedge D2, 1.00, 1.00, flag1,,,d_CK, d_D2);
