//-- FTC standard cell revision 1.1 --//
`resetall
`timescale 10ps/1ps
`celldefine
module DBAHRBLHRMX0P4 (Q, QB, D, GB, RB, VCCNW, GND, VCC);
   output QB;
   input RB;
   inout VCCNW;
   input D;
   output Q;
   inout GND;
   input GB;
   inout VCC;
   reg flag; // Notifier flag

   wire d_GB, d_D;
   wire d_RB;

//Function Block
`protect
   buf g3 (Q_pg_tmp, qt);
   assign Q = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? Q_pg_tmp : 1'bx;
   not g1 (QB_pg_tmp, qt);
   assign QB = (VCCNW === 1'b1 && GND === 1'b0 && VCC === 1'b1)? QB_pg_tmp : 1'bx;
   dlhrb_udp g2(qt,  d_D,  ck,  d_RB,  flag );
   not g4(ck,  d_GB );

//Specify Block
   specify

      //  Module Path Delay
      (negedge GB *> (Q :1'bx)) = (1.00, 1.00);
      (negedge GB *> (QB :1'bx)) = (1.00, 1.00);
      (D *> Q) = (1.00, 1.00);
      (D *> QB) = (1.00, 1.00);
      (RB *> Q) = (1.00, 1.00);
      (RB *> QB) = (1.00, 1.00);

