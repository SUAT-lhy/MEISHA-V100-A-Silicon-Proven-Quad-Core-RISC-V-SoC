cell( INNO_FNPLL_TOP ) {
  pg_pin (vcca) {
    pg_type : primary_power;
    voltage_name : vcca;
    direction : inout;
  }
  pg_pin (vccdcore) {
    pg_type : primary_power;
    voltage_name : vccdcore;
  }
  pg_pin (vccdpost) {
    pg_type : primary_power;
    voltage_name : vccdpost;
    direction : inout;
  }
  pg_pin (vssa) {
    pg_type : primary_ground;
    voltage_name : vssa;
  }
  area : 81000 ;
  dont_use : true ;
  dont_touch : true ;
  interface_timing : true;
  timing_model_type : "extracted";
  is_macro_cell : true;
