//----------------------------------------------------------------------
// File Name: INNO_PLL_TOP.v
// Description: pll verilog model for customer evaluation
// Change History:
// v0.1 - May 6,2020 - initial
// Copyright(c) 2006 - 2020, Innosilicon Technology Ltd.
// All Rights Reserved
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// In order to run fast simulation for PLL(output clock becomes stable
// within reduced time), customers might define the macro in script,
// such as: +define+INNO_PLL_FAST_SIM
// To simulate with random jitter superposition over output clocks,
// customers might define the macto in script, such as:
// +define+INNO_PLL_JITTER_EN
// Note: this jitter simulation will be much slowed down.
//----------------------------------------------------------------------
`timescale 1ns/1fs
module INNO_FNPLL_TOP (/*autoarg*/
   // Outputs
   lock, testout,
   clko0,
   clko1,
   clko2,
   // Inouts
   vcca, vccdcore, vssa, vccdpost,
   // Inputs
   refclk, pd, prediv, fbdiv, frac,
   postdiv0_0, postdiv1_0,
   postdiv0_1, postdiv1_1,
   postdiv0_2, postdiv1_2,
   gvco_bias, cpp_bias, cpi_bias, dacpd, dsmpd, testen, testsel
   
   );

parameter PREDIV_W  = 5;
parameter FBDIV_W   = 12;
parameter FRAC_W    = 24;
parameter POSTDIV_W0 = 3;
parameter POSTDIV_W1 = 3;
parameter POSTDIV_REAL_W = (POSTDIV_W0+1) + (POSTDIV_W1+1);
// parameter REFCLK_FREQ = 100.00;//MHz
parameter CLKVCO_MAX= 3000.000;//MHz
parameter CLKVCO_MIN= 1000.000;//MHz


// power & ground
inout                      vcca       ; 
inout                      vccdcore   ; 
inout                      vssa       ; 
inout                      vccdpost   ; 

input                      refclk     ; 
input                      pd         ; 
input[PREDIV_W-1:0]        prediv     ; 
input[FBDIV_W -1:0]        fbdiv      ; 
input[FRAC_W-1:0]          frac       ; 
input[POSTDIV_W0-1:0]      postdiv0_0 ; 
input[POSTDIV_W1-1:0]      postdiv1_0 ; 
input[POSTDIV_W0-1:0]      postdiv0_1 ; 
input[POSTDIV_W1-1:0]      postdiv1_1 ; 
input[POSTDIV_W0-1:0]      postdiv0_2 ;
input[POSTDIV_W0-1:0]      postdiv1_2 ;



input[1:0]                 gvco_bias  ; 
input[2:0]                 cpp_bias   ; 
input[2:0]                 cpi_bias   ; 
input                      dacpd      ; 
input                      dsmpd      ; 
input                      testen     ; 
input[1:0]                 testsel    ; 

output                     lock       ; 
output                     clko0      ; 
output                     clko1      ; 
output                     clko2      ; 
output                     testout    ; 
`protected
